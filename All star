local function safeStatus(text)
	pcall(function()
		if _G.MoMoStatus then
			_G.MoMoStatus(text)
		end
	end)
end

local function getAffordableTower()
	local result = {
		Success = false,
		Card = nil,
		Reason = nil,
	}

	local deckResult = getDeckSnapshot()
	if not deckResult.Success then
		result.Reason = deckResult.Reason
		return result
	end

	local moneyObj = LocalPlayer:FindFirstChild("Money")
	local moneyValue = moneyObj and tonumber(moneyObj.Value) or 0

	for _, card in ipairs(deckResult.Cards) do
		local placedCount = countOwnedUnitsByName(card.Name)

		if not (knownLimits[card.Name] and placedCount >= knownLimits[card.Name]) then
			if moneyValue >= (tonumber(card.Cost) or math.huge) then
				result.Success = true
				result.Card = card
				result.Reason = "OK"
				return result
			end
		end
	end

	result.Reason = "NoAffordableTower"
	return result
end

local function buildFallbackPositions(bestPosition)
	local out = {}
	if typeof(bestPosition) ~= "Vector3" then
		return out
	end

	table.insert(out, bestPosition + Vector3.new(4, 0, 0))
	table.insert(out, bestPosition + Vector3.new(-4, 0, 0))
	table.insert(out, bestPosition + Vector3.new(0, 0, 4))

	return out
end

-- [[ 🛡️ SCOPE HELPERS ]] 
local function GetOwnedUnits()
	local units = {}
	local unitFolder = workspace:FindFirstChild("Unit")
	if not unitFolder then
		return units
	end

	for _, unit in ipairs(unitFolder:GetChildren()) do
		local ok = pcall(function()
			return unit:FindFirstChild("Owner") and unit.Owner.Value == LocalPlayer
		end)

		if ok and unit:FindFirstChild("Owner") and unit.Owner.Value == LocalPlayer then
			table.insert(units, unit)
		end
	end

	return units
end

local function FindNewestOwnedUnitByName(unitName)
    local unitFolder = workspace:FindFirstChild("Unit")
    if not unitFolder then return nil end

    local newest = nil
    for _, unit in ipairs(unitFolder:GetChildren()) do
        local ok = pcall(function()
            return unit:FindFirstChild("Owner") and unit.Owner.Value == LocalPlayer and unit.Name == unitName
        end)

        if ok and unit:FindFirstChild("Owner") and unit.Owner.Value == LocalPlayer and unit.Name == unitName then
            newest = unit
        end
    end

    return newest
end

local function GetUnitUpgradeLevel(unit)
    if not unit then return 0 end
    local upgradeTag = unit:FindFirstChild("UpgradeTag")
    return (upgradeTag and tonumber(upgradeTag.Value)) or 0
end

-- ✅ ย้ายมาอยู่ตรงนี้ก่อน TryUpgradeSpecificUnit
local function FindFirstUpgradeCost(unitInstance)
    if not unitInstance then return nil end
    local ok, cost = pcall(function()
        return tonumber(unitInstance:GetAttribute("UpgradeCost") 
            or unitInstance:GetAttribute("NextUpgradeCost"))
    end)
    if ok and cost and cost > 0 then return cost end
    return nil
end

-- ✅ ตอนนี้ FindFirstUpgradeCostมีอยู่แล้วก่อนถูกเรียก
local function TryUpgradeSpecificUnit(unit)
    if not unit or unit.Parent == nil then
        return false, "NoUnit"
    end

    local cost = FindFirstUpgradeCost(unit)
    local moneyObj = LocalPlayer:FindFirstChild("Money")
    local money = moneyObj and tonumber(moneyObj.Value) or 0
    if not cost or money < cost then
        return false, "NotEnoughMoney"
    end

    local beforeLevel = GetUnitUpgradeLevel(unit)

    local ok, err = pcall(function()
        serverRemote:InvokeServer("Upgrade", unit)
    end)
    if not ok then
        return false, tostring(err)
    end

    task.wait(0.25)

    local afterLevel = GetUnitUpgradeLevel(unit)
    if afterLevel > beforeLevel then
        return true, "OK"
    end

    return false, "UpgradeNotConfirmed"
end

function ModuleX.StartCoordinator()
	if coordinatorStarted then
		return {
			Success = true,
			Reason = "AlreadyStarted",
			Runtime = coordinatorRuntime,
		}
	end

	coordinatorStarted = true
	mxLog("Coordinator started")

	-- Enemy Tracking: 100ms
	task.spawn(function()
		while task.wait(0.1) do
			if not _G.AutoPlayActive then
				continue
			end

			local ok, err = pcall(function()
				Module3.TrackEnemies()
				coordinatorRuntime.LastEnemyTrackAt = os.clock()
			end)

			if not ok then
				mxWarn("EnemyTrackingLoop:", tostring(err))
			end
		end
	end)

	-- Path Rescan: every 30s
	task.spawn(function()
		while task.wait(30) do
			if not _G.AutoPlayActive then
				continue
			end

			local ok, err = pcall(function()
				Module3.ScanPathTrajectory()
				coordinatorRuntime.LastPathRescanAt = os.clock()
			end)

			if not ok then
				mxWarn("PathRescanLoop:", tostring(err))
			end
		end
	end)

	-- [[ 🛡️ LOCAL HELPERS ]] 
	local function safeCall(tag, fn, ...)
		if typeof(fn) ~= "function" then
			warn("[ModuleX]", tag, "is nil or not a function")
			return false, { Success = false, Reason = "NilFunction", Tag = tag }
		end
		local ok, result = pcall(fn, ...)
		if not ok then
			warn("[ModuleX]", tag, "failed:", result)
			return false, { Success = false, Reason = "RuntimeError", Tag = tag, Error = tostring(result) }
		end
		return true, result
	end

	local function doUpgradeAll()
		local status = { Success = false, Count = 0 }
		local uF = workspace:FindFirstChild("Unit")
		local moneyObj = LocalPlayer:FindFirstChild("Money")
		local currentMoney = moneyObj and tonumber(moneyObj.Value) or 0
		if not uF then return status end

		for _, u in pairs(uF:GetChildren()) do
			local owner = u:FindFirstChild("Owner")
			if owner and owner.Value == LocalPlayer then
				local cost = tonumber(u:GetAttribute("UpgradeCost") or u:GetAttribute("NextUpgradeCost") or 150)
				if currentMoney >= cost then
					local ok = pcall(function() serverRemote:InvokeServer("Upgrade", u) end)
					if ok then
						currentMoney -= cost
						status.Count += 1
						status.Success = true
						task.wait(0.1)
					end
				end
			end
		end
		return status
	end

	-- Unified Combat Director: 0.6s
	task.spawn(function()
		while task.wait(0.6) do
			if not _G.AutoPlayEnabled or not _G.AutoPlayActive then
				continue
			end

			if EmergencyState.ProtocolEngaged then
				ELog("Standard combat routine paused by emergency protocol")
				continue
			end

			local ok, err = pcall(function()
				coordinatorRuntime.LastDecisionAt = os.clock()

				local enemiesFolder = workspace:FindFirstChild("Enemies")
				local hasEnemies = enemiesFolder and #enemiesFolder:GetChildren() > 0
				local totalOwned = #GetOwnedUnits()

				-- ✅ Protection: วางตัวละครได้แค่ 1 ตัวก่อนศัตรูมา (ป้องกัน Spawn Spam)
				if not hasEnemies and totalOwned >= 1 then
					coordinatorRuntime.LastPlacementReason = "NoEnemyYet"
					return
				end

				-- 1. Leak Detection (Check State)
				local _, leakStatus = safeCall("Module3.DetectLeak", Module3 and Module3.DetectLeak)
				leakStatus = leakStatus or { State = "Handled", Reason = "Fallback" }

				if leakStatus.State == "Leaking" then
					mxLog("Leak detected! LeaderPathIndex =", tostring(leakStatus.PathIndex))
					safeStatus("⚠️ ศัตรูหลุด! กำลังวางตัวสกัด...")

					-- ป้องกันวางซ้ำเร็วเกินไปและวางเกิน limit
					local now = os.clock()
					local sinceLastLeak = now - leakResponseState.LastLeakPlacementAt
					local overLimit = leakResponseState.TotalLeakPlacements >= leakResponseState.MaxLeakPlacements
					local onCooldown = sinceLastLeak < leakResponseState.LeakPlacementCooldown

					if overLimit then
						mxLog("Leak: max leak placements reached, skipping")
						-- ยังมีเงิน? อัปเกรด unit ที่มีอยู่แทน
						safeCall("doUpgradeAll", doUpgradeAll)
						return
					end

					if onCooldown then
						mxLog("Leak: cooldown active, remaining =", math.floor(leakResponseState.LeakPlacementCooldown - sinceLastLeak) .. "s")
						-- ระหว่างรอ cooldown ให้อัปเกรด unit ที่มีอยู่ก่อน
						safeCall("doUpgradeAll", doUpgradeAll)
						return
					end

					-- ตรวจสอบเงินและ card ที่วางได้
					local _, affordable = safeCall("getAffordableTower", getAffordableTower)
					if not (affordable and affordable.Success and affordable.Card) then
						mxLog("Leak: no affordable card, upgrading instead")
						safeCall("doUpgradeAll", doUpgradeAll)
						return
					end

					local card = affordable.Card

					-- ✅ ใช้ FindSpotForEmergency เพื่อดักหน้าศัตรูโดยตรง
					local interceptSpot = nil
					local interceptType = "Base"

					if leakStatus.LeadingEnemy then
						local spotOk, spotResult = pcall(function()
							return FindSpotForEmergency(leakStatus.LeadingEnemy)
						end)
						if spotOk and spotResult then
							interceptSpot = spotResult
							-- FindSpotForEmergency return (cf, placeType) — รับตัวที่ 2 ด้วย
							local _, pt = pcall(function()
								return FindSpotForEmergency(leakStatus.LeadingEnemy)
							end)
							if pt and type(pt) == "string" then
								interceptType = pt
							end
						end
					end

					-- Fallback: ถ้าดักหน้าไม่ได้ ให้ใช้ CalculatePlacementPosition ปกติ
					if not interceptSpot then
						mxLog("Leak: no intercept spot, falling back to standard placement")
						local learnedType = learnedPlacements[card.Name] or "Base"
						local _, calculation = safeCall(
							"Module3.CalculatePlacementPosition",
							Module3.CalculatePlacementPosition,
							card.Name, learnedType, 25
						)
						if calculation and calculation.Success then
							interceptSpot = calculation.BestCFrame
							interceptType = learnedType
						end
					end

					if not interceptSpot then
						mxLog("Leak: cannot find any valid spot, upgrading instead")
						safeCall("doUpgradeAll", doUpgradeAll)
						return
					end

					-- ยิง Summon
					local preCount = countOwnedUnitsByName(card.Name)
					local summonOk, summonErr = pcall(function()
						inputRemote:FireServer("Summon", {
							Rotation = 0,
							cframe = interceptSpot,
							Unit = card.Name
						})
					end)

					if not summonOk then
						mxWarn("Leak summon failed:", tostring(summonErr))
						return
					end

					-- รอยืนยัน
					task.wait(0.4)
					local postCount = countOwnedUnitsByName(card.Name)
					local moneyObj = LocalPlayer:FindFirstChild("Money")
					local moneyAfter = moneyObj and tonumber(moneyObj.Value) or 0

					if postCount > preCount then
						learnedPlacements[card.Name] = interceptType
						leakResponseState.LastLeakPlacementAt = os.clock()
						leakResponseState.TotalLeakPlacements += 1
						mxLog("✅ Leak intercept placed:", card.Name, 
						      "| total leak placements =", leakResponseState.TotalLeakPlacements)
						safeStatus("✅ วางตัวสกัดสำเร็จ! (" .. card.Name .. ")")

						-- ✅ หลังวางสำเร็จ ถ้ามีเงินเหลือให้อัปเกรดทันที
						task.wait(0.3)
						local leakUnit = FindNewestOwnedUnitByName(card.Name)
						if leakUnit then
							for _ = 1, 5 do
								local okUp, _ = TryUpgradeSpecificUnit(leakUnit)
								if not okUp then break end
								task.wait(0.2)
							end
						end
					else
						mxLog("Leak summon not confirmed (money check:", moneyAfter, ")")
						-- ถ้าวางไม่ได้ เป็นไปได้ว่าติด limit → บันทึก knownLimits
						knownLimits[card.Name] = preCount
					end

					return
				end

				-- 2. Standard State (Handled)
				local _, upgraded = safeCall("doUpgradeAll", doUpgradeAll)

				local totalOwned = #GetOwnedUnits()
				local enemiesCount = enemiesFolder and #enemiesFolder:GetChildren() or 0

				-- ถ้ามีตัวที่เพิ่งวาง และยังต้องอัปเกรดก่อนวางตัวถัดไป
				if placementProgress.RequireUpgradeBeforeNextPlace and placementProgress.LastPlacedUnit then
					local upgradedOk, reason = TryUpgradeSpecificUnit(placementProgress.LastPlacedUnit)
					if upgradedOk then
						placementProgress.LastPlacedUpgradeCount += 1
						placementProgress.RequireUpgradeBeforeNextPlace = false
						mxLog("Last placed unit upgraded at least once, next placement unlocked")
					else
						coordinatorRuntime.LastPlacementReason = "WaitingUpgrade:" .. tostring(reason)
						return
					end
				end

				-- วางตัวเพิ่มได้ ก็ต่อเมื่อไม่มีภารกิจบังคับอัปเกรดค้างอยู่
				if enemiesCount > 0 and totalOwned < 4 and not placementProgress.RequireUpgradeBeforeNextPlace then
					local _, affordable = safeCall("getAffordableTower", getAffordableTower)
					if affordable and affordable.Success and affordable.Card then
						local card = affordable.Card
						local learnedType = learnedPlacements[card.Name] or "Base"

						local _, calculation = safeCall(
							"Module3.CalculatePlacementPosition",
							Module3.CalculatePlacementPosition,
							card.Name,
							learnedType,
							25
						)

						if calculation and calculation.Success then
							local _, placement = safeCall(
								"Module4.RetryPlacementWithFallback",
								Module4.RetryPlacementWithFallback,
								card.Index,
								calculation.BestCFrame,
								buildFallbackPositions(calculation.BestPosition),
								learnedType
							)

							if placement and placement.Success then
								mxLog("Normal placement successful")

								task.wait(0.3)
								local placedUnit = FindNewestOwnedUnitByName(card.Name)
								if placedUnit then
									placementProgress.LastPlacedUnit = placedUnit
									placementProgress.LastPlacedUpgradeCount = 0
									placementProgress.RequireUpgradeBeforeNextPlace = true

									-- หลังวาง ถ้ามีเงินเหลือให้ลองอัปเกรดทันที
									local instantUpgradeOk = false
									for _ = 1, 3 do
										local okUpgrade = TryUpgradeSpecificUnit(placedUnit)
										if okUpgrade then
											placementProgress.LastPlacedUpgradeCount += 1
											instantUpgradeOk = true
											placementProgress.RequireUpgradeBeforeNextPlace = false
										else
											break
										end
										task.wait(0.2)
									end

									if instantUpgradeOk then
										mxLog("Freshly placed unit upgraded immediately after placement")
									end
								end
							end
						end
					end
				end

				coordinatorRuntime.LastPlacementReason = "HandledMode"
			end)

			if not ok then
				mxWarn("UnifiedCombatLoop:", tostring(err))
			end
		end
	end)

	return {
		Success = true,
		Reason = "OK",
		Runtime = coordinatorRuntime,
	}
end



