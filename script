local recentFailedSpots = {}

-- =========================
-- Anti-lag throttle
-- =========================
local lastAutoActionAt = 0
local lastPlaceAttemptAt = 0
local lastFarmAttemptAt = 0
local lastUpgradeBurstAt = 0
local placementFailStreak = 0

local AUTO_LOOP_INTERVAL = 0.75
local GLOBAL_ACTION_COOLDOWN = 0.85
local PLACE_COOLDOWN = 1.35
local FARM_COOLDOWN = 1
local UPGRADE_BURST_COOLDOWN = 1
local FAIL_BACKOFF_BASE = 0.9
local FAIL_BACKOFF_MAX = 3.0

local function getFailBackoff()
    return math.min(FAIL_BACKOFF_BASE + (placementFailStreak * 0.35), FAIL_BACKOFF_MAX)
end

local function canDoGlobalAction()
    return (tick() - lastAutoActionAt) >= GLOBAL_ACTION_COOLDOWN
end

local function markGlobalAction()
    lastAutoActionAt = tick()
end

local function canAttemptFarm()
    return (tick() - lastFarmAttemptAt) >= FARM_COOLDOWN and canDoGlobalAction()
end

local function canAttemptPlacement()
    return (tick() - lastPlaceAttemptAt) >= (PLACE_COOLDOWN + getFailBackoff()) and canDoGlobalAction()
end

local function canBurstUpgrade()
    return (tick() - lastUpgradeBurstAt) >= UPGRADE_BURST_COOLDOWN and canDoGlobalAction()
end

local function markFarmAttempt(success)
    lastFarmAttemptAt = tick()
    markGlobalAction()
    if success then
        placementFailStreak = 0
    else
        placementFailStreak += 1
    end
end

local function markPlacementAttempt(success)
    lastPlaceAttemptAt = tick()
    markGlobalAction()
    if success then
        placementFailStreak = 0
    else
        placementFailStreak += 1
    end
end

local function markUpgradeBurst()
    lastUpgradeBurstAt = tick()
    markGlobalAction()
end

-- =========================
-- Failed spot memory
-- =========================
local function trimFailedSpots()
    local now = tick()
    local kept = {}
    for _, item in ipairs(recentFailedSpots) do
        if now - item.t < 8 then
            table.insert(kept, item)
        end
    end
    recentFailedSpots = kept
end

local function markFailedSpot(pos)
    if pos then
        table.insert(recentFailedSpots, {pos = pos, t = tick()})
    end
end

local function isNearFailedSpot(pos, radius)
    radius = radius or 4
    trimFailedSpots()
    for _, item in ipairs(recentFailedSpots) do
        if (item.pos - pos).Magnitude <= radius then
            return true
        end
    end
    return false
end

