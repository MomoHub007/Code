local function getAffordableTower()
	local result = {
		Success = false,
		Card = nil,
		Reason = nil,
	}

	local deckResult = getDeckSnapshot()
	if not deckResult.Success then
		result.Reason = deckResult.Reason
		return result
	end

	local moneyObj = LocalPlayer:FindFirstChild("Money")
	local moneyValue = moneyObj and tonumber(moneyObj.Value) or 0

	for _, card in ipairs(deckResult.Cards) do
		local placedCount = countOwnedUnitsByName(card.Name)

		if not (knownLimits[card.Name] and placedCount >= knownLimits[card.Name]) then
			if moneyValue >= (tonumber(card.Cost) or math.huge) then
				result.Success = true
				result.Card = card
				result.Reason = "OK"
				return result
			end
		end
	end

	result.Reason = "NoAffordableTower"
	return result
end

local function buildFallbackPositions(bestPosition)
	local out = {}
	if typeof(bestPosition) ~= "Vector3" then
		return out
	end

	table.insert(out, bestPosition + Vector3.new(4, 0, 0))
	table.insert(out, bestPosition + Vector3.new(-4, 0, 0))
	table.insert(out, bestPosition + Vector3.new(0, 0, 4))

	return out
end

function ModuleX.StartCoordinator()
	if coordinatorStarted then
		return {
			Success = true,
			Reason = "AlreadyStarted",
			Runtime = coordinatorRuntime,
		}
	end

	coordinatorStarted = true
	mxLog("Coordinator started")

	-- Enemy Tracking: 100ms
	task.spawn(function()
		while task.wait(0.1) do
			if not _G.AutoPlayActive then
				continue
			end

			local ok, err = pcall(function()
				Module3.TrackEnemies()
				coordinatorRuntime.LastEnemyTrackAt = os.clock()
			end)

			if not ok then
				mxWarn("EnemyTrackingLoop:", tostring(err))
			end
		end
	end)

	-- Path Rescan: every 30s
	task.spawn(function()
		while task.wait(30) do
			if not _G.AutoPlayActive then
				continue
			end

			local ok, err = pcall(function()
				Module3.ScanPathTrajectory()
				coordinatorRuntime.LastPathRescanAt = os.clock()
			end)

			if not ok then
				mxWarn("PathRescanLoop:", tostring(err))
			end
		end
	end)

	-- Main Logic: 300ms
	task.spawn(function()
		while task.wait(0.3) do
			if not _G.AutoPlayEnabled or not _G.AutoPlayActive then
				continue
			end

			local ok, err = pcall(function()
				coordinatorRuntime.LastDecisionAt = os.clock()

				local affordable = getAffordableTower()
				if not affordable.Success or not affordable.Card then
					coordinatorRuntime.LastPlacementReason = affordable.Reason or "NoAffordableTower"
					return
				end

				local card = affordable.Card
				local learnedType = learnedPlacements[card.Name] or "Base"

				safeStatus("กำลังคำนวณตำแหน่ง " .. tostring(card.Name) .. "...")

				local calculation = Module3.CalculatePlacementPosition(card.Name, learnedType, 25)
				if not calculation or not calculation.Success or not calculation.BestPosition then
					if learnedPlacements[card.Name] == nil then
						learnedPlacements[card.Name] = (learnedType == "Base") and "Hill" or "Base"
					end
					coordinatorRuntime.LastPlacementReason = calculation and calculation.Reason or "CalculationFailed"
					return
				end

				safeStatus("กำลังวาง " .. tostring(card.Name) .. "...")

				local placement = Module4.RetryPlacementWithFallback(
					card.Index,
					calculation.BestCFrame or calculation.BestPosition,
					buildFallbackPositions(calculation.BestPosition),
					calculation.TowerType or learnedType
				)

				if placement and placement.Success then
					learnedPlacements[card.Name] = calculation.TowerType or learnedType
					coordinatorRuntime.LastPlacementReason = "Placed"
					mxLog("Placed tower:", card.Name, "| slot:", card.Index)
				else
					if learnedPlacements[card.Name] == nil then
						learnedPlacements[card.Name] = (learnedType == "Base") and "Hill" or "Base"
					else
						local placedCount = countOwnedUnitsByName(card.Name)
						knownLimits[card.Name] = placedCount
					end

					coordinatorRuntime.LastPlacementReason = placement and placement.Reason or "PlacementFailed"
				end
			end)

			if not ok then
				coordinatorRuntime.LastPlacementReason = tostring(err)
				mxWarn("MainLogicLoop:", tostring(err))
			end
		end
	end)

	return {
		Success = true,
		Reason = "OK",
		Runtime = coordinatorRuntime,
	}
end

