task.spawn(function()
    while true do
        RunService.Heartbeat:Wait()

        if not MoMoConfig.OpFarmAllMap then
            if _G.TargetMob then
                _G.TargetMob = nil
            end
            continue
        end

        local selectedList = getSelectedOpIslands()
        if #selectedList == 0 then
            _G.TargetMob = nil
            task.wait(0.2)
            continue
        end

        if _G.OpIslandRoundRobinIndex > #selectedList then
            _G.OpIslandRoundRobinIndex = 1
        end

        local currentIsland = selectedList[_G.OpIslandRoundRobinIndex]
        local foundMob = getClosestTargetMobForIsland(currentIsland)

        if foundMob then
            _G.TargetMob = foundMob

            local hum = foundMob:FindFirstChild("Humanoid")
            while MoMoConfig.OpFarmAllMap
                and _G.TargetMob == foundMob
                and foundMob.Parent
                and hum
                and hum.Parent
                and hum.Health > 0 do

                RunService.Heartbeat:Wait()
                hum = foundMob:FindFirstChild("Humanoid")
            end

            if _G.TargetMob == foundMob then
                _G.TargetMob = nil
            end
        else
            _G.TargetMob = nil
            _G.OpIslandRoundRobinIndex = (_G.OpIslandRoundRobinIndex % #selectedList) + 1
            local nextIsland = selectedList[_G.OpIslandRoundRobinIndex]

            if currentIsland ~= nextIsland then
                pcall(function()
                    RS:WaitForChild("Remotes")
                      :WaitForChild("TeleportToPortal")
                      :FireServer(nextIsland)
                end)

                local timeout = tick() + 5
                while tick() < timeout do
                    if not MoMoConfig.OpFarmAllMap then
                        break
                    end

                    local newMob = getClosestTargetMobForIsland(nextIsland)
                    if newMob then
                        _G.TargetMob = newMob
                        break
                    end

                    RunService.Heartbeat:Wait()
                end
            else
                task.wait(0.2)
            end
        end
    end
end)
