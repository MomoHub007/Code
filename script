-- 💰 [อัปเกรด V7]: ระบบสแกนกระเป๋าตังค์แบบทะลุทะลวง (Deep Find)
local function getRealMoney()
    local m = 0
    pcall(function()
        -- 1. เจาะเข้าไปที่หน้าต่าง hotbarGui
        local gui = LocalPlayer.PlayerGui:FindFirstChild("hotbarGui")
        
        -- 2. สแกนหา Object ที่ชื่อ "yen" แบบเจาะลึกทุกชั้น (true)
        local yenNode = gui and gui:FindFirstChild("yen", true)
        
        if yenNode then
            -- 3. หา TextLabel ที่ชื่อ "value"
            local label = yenNode:FindFirstChild("value")
            if label and label:IsA("TextLabel") then
                -- 4. ใช้ %D เพื่อล้าง "ทุกอย่าง" ที่ไม่ใช่ตัวเลข (ลบลูกน้ำ, ช่องว่าง, ตัวอักษร)
                local cleanNumber = label.Text:gsub("%D", "")
                m = tonumber(cleanNumber) or 0
            end
        end
    end)
    return m
end

local function getDeckUUIDs()
    local deck = {}
    pcall(function()
        local container = LocalPlayer.PlayerGui.hotbarGui.scalingFrame.background.container
        for _, slot in pairs(container:GetChildren()) do
            -- 1. สกัดเลข Slot
            local slotStr = slot.Name:match("%d+") 
            local slotNum = slotStr and tonumber(slotStr) or nil
            
            -- 2. ดึง UUID
            local uuid = slot:GetAttribute("heroUUID")
            
            if uuid and slotNum then
                local cost = 0
                
                -- 🌟 3. ดึงราคาจาก Object "PlacementPrice" ที่เราสแกนเจอ
                local priceLabel = slot:FindFirstChild("PlacementPrice", true)
                if priceLabel and priceLabel:IsA("TextLabel") then
                    -- ใช้ gsub("%D", "") เพื่อลบอักษรทุกตัวที่ไม่ใช่ตัวเลขออก (ลบ ¥ และ ,)
                    cost = tonumber(priceLabel.Text:gsub("%D", "")) or 0
                end
                
                -- 4. ตั้งชื่อจำลอง (เพราะเกมไม่มี Text ชื่อตัวละคร)
                local unitName = "Unit " .. slotNum
                
                table.insert(deck, {UUID = uuid, Cost = cost, Slot = slotNum, Name = unitName})
            end
        end
    end)
    return deck
end

