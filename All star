function Module3.ScanPathTrajectory()
	local result = {
		Success = false,
		Count = 0,
		Points = {},
		Reason = nil,
	}

	local folders = {"Paths", "2Paths", "3Paths", "4Paths"}
	local collected = {}

	for _, folderName in ipairs(folders) do
		local folder = workspace:FindFirstChild(folderName)
		if folder then
			local parts = {}
			for _, obj in ipairs(folder:GetDescendants()) do
				if obj:IsA("BasePart") then
					table.insert(parts, obj)
				end
			end

			table.sort(parts, function(a, b)
				return (tonumber(a.Name) or 0) < (tonumber(b.Name) or 0)
			end)

			for _, part in ipairs(parts) do
				table.insert(collected, {
					Name = part.Name,
					Position = part.Position,
					Part = part,
				})
			end
		end
	end

	placementState.PathPoints = collected
	placementState.LastPathScan = os.clock()

	result.Success = #collected > 0
	result.Count = #collected
	result.Points = collected
	result.Reason = result.Success and "OK" or "NoPathPoints"

	if result.Success then
		m3Log("ScanPathTrajectory success | points =", #collected)
	else
		m3Warn("ScanPathTrajectory failed | no path points")
	end

	return result
end

function Module3.TrackEnemies()
	local result = {
		Success = true,
		Count = 0,
		Enemies = {},
		Reason = "OK",
	}

	local enemiesFolder = workspace:FindFirstChild("Enemies")
	local tracked = {}

	if enemiesFolder then
		for _, enemy in ipairs(enemiesFolder:GetChildren()) do
			local hrp = enemy:FindFirstChild("HumanoidRootPart")
			if hrp then
				tracked[enemy] = {
					Model = enemy,
					Name = enemy.Name,
					Position = hrp.Position,
				}
				result.Count += 1
			end
		end
	end

	placementState.EnemyTracking = tracked
	placementState.LastEnemyScan = os.clock()
	result.Enemies = tracked

	return result
end

local function getCoverageEnemies(position, radius)
	local hits = {}

	for _, enemyData in pairs(placementState.EnemyTracking) do
		if enemyData and enemyData.Position then
			local distance = (enemyData.Position - position).Magnitude
			if distance <= radius then
				table.insert(hits, {
					Name = enemyData.Name,
					Distance = distance,
					Position = enemyData.Position,
				})
			end
		end
	end

	table.sort(hits, function(a, b)
		return a.Distance < b.Distance
	end)

	return hits
end

function Module3.ValidatePlacementCell(candidatePosition, towerType, coverageRadius)
	local result = {
		Success = false,
		InputPosition = candidatePosition,
		TowerType = towerType or "Base",
		CoverageRadius = tonumber(coverageRadius) or 25,
		FinalPosition = nil,
		CFrame = nil,
		Checks = {
			Ground = false,
			Collision = false,
			Coverage = false,
			TowerType = false,
			PathDistance = false,
		},
		Reason = nil,
		Score = 0,
		CoveredEnemies = 0,
		NearestEnemyDistance = math.huge,
		NearestPathDistance = math.huge,
	}

	if typeof(candidatePosition) ~= "Vector3" then
		result.Reason = "InvalidPosition"
		return result
	end

	local placeableFolder = getPlaceableFolder(result.TowerType)
	if not placeableFolder then
		result.Reason = "PlaceableFolderMissing"
		return result
	end
	result.Checks.TowerType = true

	local rayParams = RaycastParams.new()
	rayParams.FilterType = Enum.RaycastFilterType.Include
	rayParams.FilterDescendantsInstances = {placeableFolder}

	local rayResult = nil
	local rayOk, rayErr = pcall(function()
		rayResult = workspace:Raycast(
			candidatePosition + Vector3.new(0, 60, 0),
			Vector3.new(0, -120, 0),
			rayParams
		)
	end)

	if not rayOk then
		result.Reason = "GroundRaycastFailed:" .. tostring(rayErr)
		dwarn("Reject:", result.Reason)
		return result
	end

	if not rayResult then
		result.Reason = "GroundInvalid"
		dlog("Reject:", result.Reason, "| towerType =", result.TowerType)
		return result
	end

	result.Checks.Ground = true
	result.FinalPosition = rayResult.Position
	result.CFrame = CFrame.new(rayResult.Position)

	-- กันชิด path เกินไป
	for _, point in ipairs(placementState.PathPoints) do
		if point and point.Position then
			local dist = (point.Position - result.FinalPosition).Magnitude
			if dist < result.NearestPathDistance then
				result.NearestPathDistance = dist
			end
		end
	end

	if result.NearestPathDistance < 4 then
		result.Reason = "TooCloseToPath"
		dlog("Reject:", result.Reason, "| dist =", math.floor(result.NearestPathDistance * 100) / 100)
		return result
	end
	result.Checks.PathDistance = true

	-- ขยาย collision box ให้เข้มขึ้น
	local overlapParams = OverlapParams.new()
	overlapParams.FilterType = Enum.RaycastFilterType.Include
	if workspace:FindFirstChild("Unit") then
		overlapParams.FilterDescendantsInstances = {workspace.Unit}
	else
		overlapParams.FilterDescendantsInstances = {}
	end

	local collisionCount = 0
	local overlapOk, overlapErr = pcall(function()
		collisionCount = #workspace:GetPartBoundsInBox(result.CFrame, Vector3.new(6, 6, 6), overlapParams)
	end)

	if not overlapOk then
		result.Reason = "CollisionCheckFailed:" .. tostring(overlapErr)
		dwarn("Reject:", result.Reason)
		return result
	end

	if collisionCount > 0 then
		result.Reason = "BlockedByTower"
		dlog("Reject:", result.Reason, "| collisions =", collisionCount)
		return result
	end
	result.Checks.Collision = true

	local hits = getCoverageEnemies(result.FinalPosition, result.CoverageRadius)
	result.CoveredEnemies = #hits
	if #hits <= 0 then
		result.Reason = "NoCoverage"
		dlog("Reject:", result.Reason)
		return result
	end
	result.Checks.Coverage = true

	result.NearestEnemyDistance = hits[1] and hits[1].Distance or result.CoverageRadius

	-- ให้ score ชอบจุดที่ไม่ชิด path เกินไป และมี coverage ดี
	result.Score = (#hits * 100) - result.NearestEnemyDistance + math.min(result.NearestPathDistance, 15)

	result.Success = true
	result.Reason = "OK"

	dlog(
		"Accept:",
		"towerType =", result.TowerType,
		"| coverage =", result.CoveredEnemies,
		"| enemyDist =", math.floor(result.NearestEnemyDistance * 100) / 100,
		"| pathDist =", math.floor(result.NearestPathDistance * 100) / 100,
		"| score =", math.floor(result.Score * 100) / 100
	)

	return result
end

function Module3.CalculatePlacementPosition(towerName, towerType, coverageRadius)
	local result = {
		Success = false,
		TowerName = towerName,
		TowerType = towerType or "Base",
		CoverageRadius = tonumber(coverageRadius) or 25,
		Phase = nil,
		BestPosition = nil,
		BestCFrame = nil,
		BestScore = -math.huge,
		BestValidation = nil,
		CandidatesChecked = 0,
		Reason = nil,
	}

	local pathPoints = placementState.PathPoints
	if #pathPoints == 0 then
		local scanResult = Module3.ScanPathTrajectory()
		pathPoints = scanResult.Points or {}
	end

	if #pathPoints == 0 then
		result.Reason = "NoPathPoints"
		return result
	end

	local bestValidation = nil
	local radii = {8, 10, 12}
	local angles = {0, 45, 90, 135, 180, 225, 270, 315}

	for i = 1, #pathPoints, 3 do
		local point = pathPoints[i]
		if point and point.Position then
			for _, radius in ipairs(radii) do
				for _, angle in ipairs(angles) do
					local rad = math.rad(angle)
					local candidate = point.Position + Vector3.new(math.cos(rad) * radius, 0, math.sin(rad) * radius)

					local validateResult = Module3.ValidatePlacementCell(candidate, result.TowerType, result.CoverageRadius)
					result.CandidatesChecked += 1

					if validateResult.Success then
						if (not bestValidation) or validateResult.Score > bestValidation.Score then
							bestValidation = validateResult
							result.BestPosition = validateResult.FinalPosition
							result.BestCFrame = validateResult.CFrame
							result.BestValidation = validateResult
							result.BestScore = validateResult.Score
							result.Phase = "Phase1"
						end
					end
				end
				task.wait()
			end
		end
	end

	if bestValidation then
		result.Success = true
		result.Reason = "OK"
		dlog("Best placement chosen:", towerName, "| phase =", result.Phase, "| score =", result.BestScore)
		return result
	end

	result.Reason = "NoValidPlacement"
	dwarn("NoValidPlacement for", tostring(towerName), "| checked =", result.CandidatesChecked)
	return result
end

