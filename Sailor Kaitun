-- 🛡️ [ ANTI-ANTI-CHEAT & STABILITY ]
pcall(function()
    local mt = getrawmetatable(game)
    local original = _G.MoMoOriginalNamecall or mt.__namecall
    if not _G.MoMoOriginalNamecall then _G.MoMoOriginalNamecall = original end
    
    if _G.MoMoHookedOnce then return end
    _G.MoMoHookedOnce = true

    setreadonly(mt, false)
    mt.__namecall = newcclosure(function(self, ...)
        local method = getnamecallmethod()
        if not checkcaller() then
            if method == "Kick" or method == "kick" then return nil end
            if method == "FireServer" or method == "InvokeServer" then
                local ok, name = pcall(function() return self.Name:lower() end)
                if ok and name then
                    if string.find(name, "kick") or string.find(name, "ban") or string.find(name, "cheat") or string.find(name, "exploit") or string.find(name, "log") or string.find(name, "flag") then
                        return nil
                    end
                end
            end
        end
        return original(self, ...)
    end)
    setreadonly(mt, true)
    print("[MOMO HUB] Anti-Cheat Bypass Loaded Successfully.")
end)

local function isQuestActive()
    local ok, active = pcall(function()
        local gui = LP.PlayerGui:FindFirstChild("QuestUI")
        if gui then
            local q1 = gui:FindFirstChild("Quest")
            local q2 = q1 and q1:FindFirstChild("Quest")
            if q2 and q2.Visible then
                local holder = q2:FindFirstChild("Holder")
                if holder and holder.Visible then
                    local title = holder:FindFirstChild("QuestTitle", true)
                    local req = holder:FindFirstChild("QuestRequirement", true)
                    if title and title:IsA("TextLabel") and title.Text ~= "" and title.Text ~= "Quest Title" then
                        -- ✅ ตรวจสอบตัวเลข (เช่น 5/5 หรือ 0/5)
                        if req and req.Text ~= "" then
                            local n, m = req.Text:match("(%d+)%s*/%s*(%d+)")
                            if n and m then
                                -- ถ้าเลขหน้า >= เลขหลัง (เช่น 5/5) แปลว่าจบแล้ว!
                                if tonumber(n) >= tonumber(m) then return false end
                            end
                        end
                        return true
                    end
                end
            end
        end
        return false
    end)
    return ok and active
end

