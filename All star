local function ScanForModifier(modifierString)
	local enemiesFolder = workspace:FindFirstChild("Enemies")
	if not enemiesFolder then
		return false, nil
	end

	for _, enemy in ipairs(enemiesFolder:GetChildren()) do
		local ok, found = pcall(function()
			-- 1. Check Metadata BBGUI (TITLE_BBGUI)
			local head = enemy:FindFirstChild("Head")
			if head then
				local bb = head:FindFirstChild("TITLE_BBGUI")
				if bb then
					for _, label in ipairs(bb:GetDescendants()) do
						if label:IsA("TextLabel") and label.Text == modifierString then
							return true
						end
					end
				end
			end

			-- 2. Check Attributes & Tags
			if enemy:GetAttribute("Modifier") == modifierString or enemy:FindFirstChild(modifierString) then
				return true
			end

			-- 3. High HP Check (Substitutes for Powerful/Boss)
			local hum = enemy:FindFirstChildOfClass("Humanoid")
			if hum and hum.MaxHealth > 100000 then -- ตัวอย่างค่า HP สำหรับบอส
				return true
			end

			-- 4. Name Pattern
			if enemy.Name:find(modifierString) then
				return true
			end
			
			return false
		end)

		if ok and found then
			ELog("Threat detected:", modifierString, "| Enemy =", enemy.Name)
			return true, enemy
		end
	end

	return false, nil
end

local function HasUpgradedDefenders(enemyInstance)
	-- [FIX-EMG-1] อย่าจบ Emergency เร็วเกินไปแค่เพราะมีตัว level >= 2 อยู่ใกล้ศัตรู
	-- ต้องเช็คต่อว่า "ยังมีเงินพอให้อัปเกรดต่อ" หรือไม่ ถ้ายังอัปเกรดได้ให้คืน false เพื่อบังคับ Emergency ทำงานต่อ
	if not enemyInstance then return false end
	local enemyHrp = enemyInstance:FindFirstChild("HumanoidRootPart")
	if not enemyHrp then return false end
	
	local enemyPos = enemyHrp.Position
	local threatRadius = 40
	local moneyObj = LocalPlayer:FindFirstChild("Money")
	local money = moneyObj and tonumber(moneyObj.Value) or 0
	local TARGET_LEVEL = 2

	for _, unit in ipairs(GetOwnedUnits()) do
		local ok, handled = pcall(function()
			local hrp = unit:FindFirstChild("HumanoidRootPart")
			local upgradeTag = unit:FindFirstChild("UpgradeTag")
			if not hrp or not upgradeTag then return false end

			local distToEnemy = (hrp.Position - enemyPos).Magnitude
			local level = tonumber(upgradeTag.Value) or 0
			local nextCost = FindFirstUpgradeCost(unit)

			if distToEnemy > threatRadius then
				return false
			end

			if nextCost and money >= nextCost then
				ELog("[FIX-EMG-1] Defender near threat can still be upgraded:", unit.Name, "| level =", level, "| money =", money, "| nextCost =", nextCost)
				return false
			end

			if level >= TARGET_LEVEL then
				ELog("[FIX-EMG-1] Board ready with sufficiently upgraded defender near threat:", unit.Name, "| level =", level)
				return true
			end

			return false
		end)

		if ok and handled then
			return true
		end
	end

	return false
end

