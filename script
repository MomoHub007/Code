    -- ─── Throttle State ────────────────────────────────
    local _lastAutoAt     = 0
    local _lastPlaceAt    = 0
    local _lastFarmAt     = 0
    local _lastUpgradeAt  = 0
    local _failStreak     = 0
    local _recentFailed   = {}
    local _lastJoinAt     = 0

    local LOOP_RATE          = 0.75
    local GLOBAL_COOLDOWN    = 0.80
    local PLACE_COOLDOWN     = 1.30
    local FARM_COOLDOWN      = 1.60
    local UPGRADE_COOLDOWN   = 2.20
    local FAIL_BACKOFF_BASE  = 0.80
    local FAIL_BACKOFF_MAX   = 2.80

    -- ─── Helpers ───────────────────────────────────────
    local function failBackoff()
        return math.min(FAIL_BACKOFF_BASE + _failStreak * 0.30, FAIL_BACKOFF_MAX)
    end

    local function canGlobal()   return (tick() - _lastAutoAt)    >= GLOBAL_COOLDOWN    end
    local function canPlace()    return (tick() - _lastPlaceAt)   >= PLACE_COOLDOWN + failBackoff() and canGlobal() end
    local function canFarm()     return (tick() - _lastFarmAt)    >= FARM_COOLDOWN  and canGlobal() end
    local function canUpgrade()  return (tick() - _lastUpgradeAt) >= UPGRADE_COOLDOWN   and canGlobal() end

    local function touchGlobal()   _lastAutoAt = tick() end
    local function touchPlace(ok)  _lastPlaceAt = tick(); touchGlobal(); if ok then _failStreak = 0 else _failStreak += 1 end end
    local function touchFarm(ok)   _lastFarmAt = tick();  touchGlobal(); if ok then _failStreak = 0 else _failStreak += 1 end end
    local function touchUpgrade()  _lastUpgradeAt = tick(); touchGlobal() end

    local function trimFailed()
        local now, kept = tick(), {}
        for _, v in ipairs(_recentFailed) do
            if now - v.t < 9 then table.insert(kept, v) end
        end
        _recentFailed = kept
    end

    local function markFailed(pos)
        if pos then table.insert(_recentFailed, {pos = pos, t = tick()}) end
    end

    local function nearFailed(pos, r)
        r = r or 4
        trimFailed()
        for _, v in ipairs(_recentFailed) do
            if (v.pos - pos).Magnitude <= r then return true end
        end
        return false
    end

    -- ─── Field Scan ────────────────────────────────────
    local function scanField(farmSlot)
        local placedFolder = workspace:FindFirstChild("placedTowers")
        local enemies      = workspace:FindFirstChild("enemiesModels")

        local s = {
            towerCount       = placedFolder and #placedFolder:GetChildren() or 0,
            enemyCount       = enemies      and #enemies:GetChildren()      or 0,
            attackTowers     = {},
            farmTowers       = {},
            attackCount      = 0,
            farmCount        = 0,
            nearestEnemyDist = math.huge,
            closeThreats     = 0,
            poorlyGuarded    = 0,
            wellGuarded      = 0,
            maxSupport       = 0,
            leaking          = false,
        }

        if placedFolder then
            for _, obj in pairs(placedFolder:GetChildren()) do
                if obj:IsA("Model") and obj.Name:match("^tower%-") then
                    local pos = obj:GetPivot().Position
                    local isFarm = false
                    for _, fp in ipairs(farmPositions) do
                        if (pos - fp).Magnitude < 3 then isFarm = true; break end
                    end
                    if isFarm then
                        s.farmCount += 1
                        table.insert(s.farmTowers, {obj = obj, pos = pos})
                    else
                        s.attackCount += 1
                        table.insert(s.attackTowers, {obj = obj, pos = pos})
                    end
                end
            end
        end

        s.leaking = isDefenseBreached()

        if #s.attackTowers > 0 and enemies then
            for _, enemy in pairs(enemies:GetChildren()) do
                local hrp = enemy:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local ep  = hrp.Position
                    local best, support = math.huge, 0
                    for _, t in ipairs(s.attackTowers) do
                        local d = (ep - t.pos).Magnitude
                        if d < best then best = d end
                        if d <= 18 then support += 1 end
                    end
                    if best < s.nearestEnemyDist then
                        s.nearestEnemyDist = best
                        s.maxSupport = support
                    end
                    if best <= 12 then
                        s.closeThreats += 1
                        if support >= 3 then s.wellGuarded  += 1
                        else                 s.poorlyGuarded += 1 end
                    end
                end
            end
        end

        return s
    end

    -- ─── Danger State ──────────────────────────────────
    local function getDanger(deck, farmSlot)
        local s = scanField(farmSlot)

        if s.attackCount == 0 then return "EMERGENCY", 100, s end

        local score = 0
        if s.leaking then score += 30 end

        local d = s.nearestEnemyDist
        if     d <= 8  then score += 22
        elseif d <= 14 then score += 12
        elseif d <= 22 then score +=  6
        elseif d <= 32 then score +=  2 end

        score += math.min(s.poorlyGuarded * 8, 24)
        score -= math.min(s.wellGuarded   * 6, 18)

        if     s.maxSupport >= 4 then score -= 10
        elseif s.maxSupport >= 3 then score -=  6
        elseif s.maxSupport >= 2 then score -=  2 end

        if     s.attackCount == 1 then score += 10
        elseif s.attackCount == 2 then score +=  4 end

        if farmSlot > 0 and (placedTracking[farmSlot] or 0) >= 1 and not s.leaking then
            score -= 5
        end

        if s.attackCount >= 2 and s.poorlyGuarded == 0 and not s.leaking then
            score -= 8
        end

        if score >= 55 then return "EMERGENCY", score, s
        elseif score >= 24 then return "PRESSURE", score, s
        else return "SAFE", score, s end
    end

    -- ─── Attack Placed Count ───────────────────────────
    local function attackPlacedCount(deck, farmSlot)
        local n = 0
        for _, card in ipairs(deck) do
            if card.Slot ~= farmSlot then
                n += (placedTracking[card.Slot] or 0)
            end
        end
        return n
    end

    -- ─── Cheapest Attack ───────────────────────────────
    local function cheapestAttack(deck, farmSlot)
        local min = math.huge
        for _, card in ipairs(deck) do
            if card.Slot ~= farmSlot then
                local lim = MoMoConfig.UnitLimits[card.Slot] or 0
                local pl  = placedTracking[card.Slot] or 0
                if pl < lim and card.Cost > 0 and card.Cost < min then
                    min = card.Cost
                end
            end
        end
        return min == math.huge and 0 or min
    end

    -- ─── Nearby Tower Count ────────────────────────────
    local function nearbyTowerCount(pos, radius)
        local pf = workspace:FindFirstChild("placedTowers")
        if not pf or not pos then return 0 end
        local n = 0
        for _, obj in pairs(pf:GetChildren()) do
            if obj:IsA("Model") and obj.Name:match("^tower%-") then
                local tp = obj:GetPivot().Position
                local isF = false
                for _, fp in ipairs(farmPositions) do
                    if (tp - fp).Magnitude < 3 then isF = true; break end
                end
                if not isF and (tp - pos).Magnitude <= (radius or 12) then n += 1 end
            end
        end
        return n
    end

    -- ─── Soft Resync ───────────────────────────────────
    local function resync()
        local pf   = workspace:FindFirstChild("placedTowers")
        local live = pf and #pf:GetChildren() or 0
        local tracked = 0
        for i = 1, 6 do tracked += (placedTracking[i] or 0) end

        if live == 0 then
            placedTracking = {0,0,0,0,0,0}
            farmPositions  = {}
            _recentFailed  = {}
            _failStreak    = 0
            _lastAutoAt    = 0
            _lastPlaceAt   = 0
            _lastFarmAt    = 0
            _lastUpgradeAt = 0
            return
        end

        if tracked > live + 2 then
            placedTracking = {0,0,0,0,0,0}
            farmPositions  = {}
            _recentFailed  = {}
            _failStreak    = 0
            print("♻️ [v3] Tracking desync reset")
        end
    end

    -- ─── Place Farm ────────────────────────────────────
    local function placeFarm(sync, farmCard, pf, limit, danger, deck)
        if not sync or not farmCard or not canFarm() then return false end

        local placed = placedTracking[farmCard.Slot] or 0
        if placed >= limit then return false end
        if danger == "EMERGENCY" then return false end

        local money    = getRealMoney()
        local atkCount = attackPlacedCount(deck, farmCard.Slot)
        local cheap    = cheapestAttack(deck, farmCard.Slot)
        local leaking  = isDefenseBreached()

        -- บังคับวางฟาร์มตัวแรกถ้ามีตัวกันบ้านอย่างน้อย 1 และไม่ leak
        local forcedFirst = atkCount >= 1 and placed == 0 and not leaking

        if not forcedFirst and danger == "PRESSURE" and cheap > 0 then
            local reserve = atkCount >= 1 and math.floor(cheap * 0.35) or cheap
            if money < (farmCard.Cost + reserve) then
                touchFarm(false)
                return false
            end
        end

        if money < farmCard.Cost then
            touchFarm(false)
            return false
        end

        local ok, success = false, false
        for _ = 1, 4 do
            local spot = findFarmSpot()
            if spot and not nearFailed(spot.Position, 5) then
                local before = pf and #pf:GetChildren() or 0
                ok = pcall(function()
                    sync.clientTowerPlacement.call(farmCard.UUID, spot)
                end)
                if ok then
                    task.wait(0.9)
                    local after = pf and #pf:GetChildren() or 0
                    if after > before then
                        placedTracking[farmCard.Slot] = (placedTracking[farmCard.Slot] or 0) + 1
                        table.insert(farmPositions, spot.Position)
                        success = true
                        print("🤑 [v3] Farm placed (" .. placedTracking[farmCard.Slot] .. "/" .. limit .. ")")
                        break
                    else
                        markFailed(spot.Position)
                    end
                else
                    if spot then markFailed(spot.Position) end
                end
            end
        end

        touchFarm(success)
        return success
    end

    -- ─── Sort Attack Deck ──────────────────────────────
    local function sortedAttack(deck, danger, farmSlot)
        local list = {}
        for _, c in ipairs(deck) do table.insert(list, c) end

        table.sort(list, function(a, b)
            if a.Slot == farmSlot then return false end
            if b.Slot == farmSlot then return true  end
            local sa, sb = 0, 0
            local la = MoMoConfig.UnitLimits[a.Slot] or 0
            local lb = MoMoConfig.UnitLimits[b.Slot] or 0
            local pa = placedTracking[a.Slot] or 0
            local pb = placedTracking[b.Slot] or 0
            if pa >= la then return false end
            if pb >= lb then return true  end
            if danger == "EMERGENCY" then
                sa = -a.Cost
                sb = -b.Cost
            else
                sa = (la - pa) * 4 + a.Cost * 0.05
                sb = (lb - pb) * 4 + b.Cost * 0.05
                if pa == 0 then sa += 6 end
                if pb == 0 then sb += 6 end
            end
            return sa > sb
        end)
        return list
    end

    -- ─── Place Attack ──────────────────────────────────
    local function placeAttack(sync, deck, farmSlot, danger, pf)
        if not sync or #deck == 0 or not canPlace() then return false end

        local money   = getRealMoney()
        local success = false

        for _, card in ipairs(sortedAttack(deck, danger, farmSlot)) do
            local lim = MoMoConfig.UnitLimits[card.Slot] or 0
            local pl  = placedTracking[card.Slot] or 0
            if card.Slot ~= farmSlot and pl < lim and money >= card.Cost then
                local bestSpot, bestScore = nil, -math.huge
                for _ = 1, 6 do
                    local spot = findSpot()
                    if spot and spot.Position and not nearFailed(spot.Position, 4) then
                        local nearby = nearbyTowerCount(spot.Position, 12)
                        local sc = danger == "EMERGENCY" and (-nearby * 4) or (-nearby * 8)
                        if sc > bestScore then bestScore = sc; bestSpot = spot end
                    end
                end

                if bestSpot and bestSpot.Position and bestScore > -100 then
                    local before = pf and #pf:GetChildren() or 0
                    local ok = pcall(function()
                        sync.clientTowerPlacement.call(card.UUID, bestSpot)
                    end)
                    if ok then
                        task.wait(0.9)
                        local after = pf and #pf:GetChildren() or 0
                        if after > before then
                            placedTracking[card.Slot] = (placedTracking[card.Slot] or 0) + 1
                            success = true
                            print("✅ [v3] Attack placed slot " .. card.Slot .. " (" .. placedTracking[card.Slot] .. "/" .. lim .. ")")
                            break
                        else
                            markFailed(bestSpot.Position)
                        end
                    else
                        markFailed(bestSpot.Position)
                    end
                end
            end
            if success then break end
        end

        touchPlace(success)
        return success
    end

    -- ─── Smart Upgrade ─────────────────────────────────
    local function smartUpgrade(danger, atkTowers, farmTowers, deck, farmSlot)
        if not canUpgrade() then return false end

        local targets, done = {}, false

        if danger == "SAFE" then
            for _, t in ipairs(farmTowers) do table.insert(targets, t) end
            for _, t in ipairs(atkTowers)  do table.insert(targets, t) end
        else
            for _, t in ipairs(atkTowers) do table.insert(targets, t) end
            if danger == "PRESSURE" then
                for _, t in ipairs(farmTowers) do table.insert(targets, t) end
            end
        end

        local maxTries = danger == "EMERGENCY" and 1 or 2
        local count = 0
        for _, t in ipairs(targets) do
            if count >= maxTries then break end
            local ok = pcall(function()
                ReplicatedStorage.towers.towers_RELIABLE:FireServer(
                    buffer.fromstring("\001\031+\000" .. t.obj.Name), {}
                )
            end)
            if ok then done = true; count += 1; task.wait(0.12) end
        end

        touchUpgrade()
        return done
    end

    -- ─── Main Loop ─────────────────────────────────────
    task.spawn(function()
        while true do
            task.wait(LOOP_RATE)

            -- Auto Join
            if MoMoConfig.AutoJoin and isInLobby() and tick() - _lastJoinAt > 10 then
                _lastJoinAt = tick()
                AutoJoinMatch(
                    MoMoConfig.SelectedMode, MoMoConfig.SelectedMap,
                    MoMoConfig.SelectedAct,  MoMoConfig.SelectedDifficulty
                )
                continue
            end

            if not MoMoConfig.AutoPlay then continue end

            resync()

            local sync = getSync()
            local deck = getDeckUUIDs()
            if not sync or #deck == 0 then continue end

            -- Classify towers
            local pf = workspace:FindFirstChild("placedTowers")
            local atkTowers, farmTowers = {}, {}
            if pf then
                for _, obj in pairs(pf:GetChildren()) do
                    if obj:IsA("Model") and obj.Name:match("^tower%-") then
                        local pos, isF = obj:GetPivot().Position, false
                        for _, fp in ipairs(farmPositions) do
                            if (pos - fp).Magnitude < 3 then isF = true; break end
                        end
                        if isF then table.insert(farmTowers, {obj=obj,pos=pos})
                        else         table.insert(atkTowers,  {obj=obj,pos=pos}) end
                    end
                end
            end

            -- Get config
            local farmSlot = MoMoConfig.FarmUnit or 0
            local farmCard = nil
            if farmSlot > 0 then
                for _, c in ipairs(deck) do
                    if c.Slot == farmSlot then farmCard = c; break end
                end
            end

            local farmLimit   = farmSlot > 0 and (MoMoConfig.UnitLimits[farmSlot] or 0) or 0
            local atkPlaced   = attackPlacedCount(deck, farmSlot)
            local placedFarm  = farmSlot > 0 and (placedTracking[farmSlot] or 0) or 0
            local leaking     = isDefenseBreached()
            local danger, _, _ = getDanger(deck, farmSlot)

            -- ── Priority 0: Emergency only ──────────────────
            if danger == "EMERGENCY" then
                if placeAttack(sync, deck, farmSlot, "EMERGENCY", pf) then continue end
            end

            -- ── Priority 1: Place FARM first ────────────────
            -- วางฟาร์มก่อนเป็นอันดับแรกสุดเสมอ
            -- เงื่อนไข: ยังไม่ครบ limit AND ไม่ leak AND (ปลอดภัย หรือ มีตัวกันบ้านอย่างน้อย 1 แล้ว)
            if farmCard and placedFarm < farmLimit then
                local allowFarm = not leaking and (
                    danger == "SAFE" or
                    (danger == "PRESSURE" and atkPlaced >= 1)
                )
                if allowFarm then
                    if placeFarm(sync, farmCard, pf, farmLimit, danger, deck) then continue end
                end
            end

            -- ── Priority 2: Place first defense tower ────────
            -- ถ้ายังไม่มีตัวกันบ้านเลย ให้วางก่อน (ไม่งั้นจะไม่มีทางเปิดฟาร์มได้)
            if atkPlaced == 0 then
                if placeAttack(sync, deck, farmSlot, danger, pf) then continue end
            end

            -- ── Priority 3: Pressure defense ─────────────────
            if danger == "PRESSURE" then
                if placeAttack(sync, deck, farmSlot, danger, pf) then continue end
            end

            -- ── Priority 4: Upgrades ─────────────────────────
            local cheap = cheapestAttack(deck, farmSlot)
            local money = getRealMoney()
            local doUpgrade = false

            if danger == "SAFE" then
                doUpgrade = true
            elseif danger == "PRESSURE" then
                doUpgrade = true
            else
                doUpgrade = cheap == 0 or money > cheap * 1.8
            end

            if doUpgrade then
                smartUpgrade(danger, atkTowers, farmTowers, deck, farmSlot)
            end

            -- ── Priority 5: Safe fill towers ─────────────────
            if danger == "SAFE" then
                placeAttack(sync, deck, farmSlot, "SAFE", pf)
            end

            -- Debug log
            if not _G._v3dbg or tick() - _G._v3dbg > 4 then
                _G._v3dbg = tick()
                local s = scanField(farmSlot)
                print(string.format(
                    "🧠 [v3] %s | atk=%d farm=%d/%d | enemy=%d nearDist=%.0f | leaking=%s",
                    danger, s.attackCount,
                    placedFarm, farmLimit,
                    s.enemyCount,
                    s.nearestEnemyDist == math.huge and 999 or s.nearestEnemyDist,
                    tostring(s.leaking)
                ))
            end
        end
    end)
