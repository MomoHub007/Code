local function GetDeckWithStars()
    local deck = {}
    local hud = LocalPlayer.PlayerGui:FindFirstChild("HUD")
    if not hud then return deck end
    
    local bottomFrame = hud:FindFirstChild("BottomFrame") or hud:FindFirstChild("Main")
    if not bottomFrame then return deck end
    
    local unitFrame = bottomFrame:FindFirstChild("Unit")
    if not unitFrame then return deck end

    -- อ้างอิงไปที่โฟลเดอร์เก็บข้อมูลดาวของเกม
    local unitStarsFolder = game:GetService("ReplicatedStorage"):FindFirstChild("UnitStars")

    for _, slotName in ipairs({"One","Two","Three","Four","Five","Six"}) do
        local slot = unitFrame:FindFirstChild(slotName)
        if slot and slot:FindFirstChild("Unit") and slot.Unit.Value ~= "" then
            local unitName = slot.Unit.Value
            local cost = 9999
            
            -- 1. หาค่า Cost จาก UI (เพราะราคาในเกมตอนเล่นอาจจะเปลี่ยนได้)
            for _, obj in ipairs(slot:GetDescendants()) do
                if (obj:IsA("TextLabel") or obj:IsA("TextButton")) and obj.Text then
                    local n = tonumber(obj.Text:match("%d+"))
                    if n and n > 0 and n < cost then cost = n end
                end
            end
            
            -- 2. หาค่า Stars จาก ReplicatedStorage โดยตรง (แม่นยำ 100%)
            local stars = 6 -- ค่าเริ่มต้นถ้าเกิดหาไม่เจอจริงๆ
            if unitStarsFolder then
                local starData = unitStarsFolder:FindFirstChild(unitName)
                if starData and starData:IsA("IntValue") then
                    stars = starData.Value
                end
            end

            table.insert(deck, {
                Name     = unitName,
                Cost     = cost,
                Stars    = stars,
                SlotName = slotName,
            })
        end
    end
    
    return deck
end

local function FindOptimalEmergencyCard(maxStars)
	local deck = GetDeckWithStars()
	if #deck == 0 then
		EWarn("No cards found in deck")
		return nil
	end

	local filtered = {}
	for _, card in ipairs(deck) do
		if (tonumber(card.Stars) or 6) <= maxStars then
			table.insert(filtered, card)
		end
	end

	local pool = (#filtered > 0) and filtered or deck
	table.sort(pool, function(a, b)
		local aCost = tonumber(a.Cost) or math.huge
		local bCost = tonumber(b.Cost) or math.huge
		if aCost == bCost then
			return (tonumber(a.Stars) or 99) < (tonumber(b.Stars) or 99)
		end
		return aCost < bCost
	end)

	local picked = pool[1]
	if picked then
		ELog("Emergency card selected:", picked.Name, "| Cost =", picked.Cost, "| Stars =", picked.Stars)
	end

	return picked
end


local function FindOwnedUnitByName(name)
	local unitFolder = workspace:FindFirstChild("Unit")
	if not unitFolder then
		return nil
	end

	for _, u in ipairs(unitFolder:GetChildren()) do
		local ok = pcall(function()
			return u:FindFirstChild("Owner") and u.Owner.Value == LocalPlayer and u.Name == name
		end)

		if ok then
			local pass = false
			pcall(function()
				pass = u:FindFirstChild("Owner") and u.Owner.Value == LocalPlayer and u.Name == name
			end)
			if pass then
				return u
			end
		end
	end

	return nil
end

local function FindSpotForEmergency(enemyInstance)
	if not enemyInstance then return nil, "NoEnemyProvided" end
	local enemyHrp = enemyInstance:FindFirstChild("HumanoidRootPart")
	if not enemyHrp then return nil, "NoHrp" end

	local enemyPos = enemyHrp.Position
	local travelDir = Vector3.new(0, 0, 0)

	-- คำนวณทิศทาง (Toward Base/Nearest Path)
	local pathPoints = placementState.PathPoints
	if #pathPoints > 0 then
		local nearestPt = 1
		local minDist = math.huge
		for i, pt in ipairs(pathPoints) do
			local d = (pt.Position - enemyPos).Magnitude
			if d < minDist then
				minDist = d
				nearestPt = i
			end
		end
		
		-- ทิศทางไปจุดถัดไป
		local nextPt = pathPoints[nearestPt + 1] or pathPoints[nearestPt]
		travelDir = (nextPt.Position - enemyPos).Unit
	end

	local placeableRoot = workspace:FindFirstChild("Placeable")
	if not placeableRoot then return nil, "NoPlaceableRoot" end

	-- ✅ Intercept Logic: ดักหน้าศัตรู 20/35/50 studs
	local interceptDistances = {20, 35, 50}

	for _, dist in ipairs(interceptDistances) do
		local interceptPoint = enemyPos + (travelDir * dist)

		for _, placeType in ipairs({"Base", "Hill"}) do
			local placeableFolder = placeableRoot:FindFirstChild(placeType)
			if placeableFolder then
				local rayParams = RaycastParams.new()
				rayParams.FilterType = Enum.RaycastFilterType.Include
				rayParams.FilterDescendantsInstances = {placeableFolder}

				local ray = workspace:Raycast(interceptPoint + Vector3.new(0, 50, 0), Vector3.new(0, -100, 0), rayParams)
				if ray then
					local cf = CFrame.new(ray.Position)
					local overlap = OverlapParams.new()
					overlap.FilterType = Enum.RaycastFilterType.Include
					if workspace:FindFirstChild("Unit") then overlap.FilterDescendantsInstances = {workspace.Unit} end

					local blocked = false
					pcall(function() blocked = #workspace:GetPartBoundsInBox(cf, Vector3.new(6,6,6), overlap) > 0 end)

					if not blocked then
						ELog("Intercept spot found at distance:", dist)
						return cf, placeType
					end
				end
			end
		end
	end

	return nil, "NoInterceptSpot"
end

local function RetryPendingEmergencyUpgrade()
	for i = #EmergencyState.PendingUpgradeInstances, 1, -1 do
		local unit = EmergencyState.PendingUpgradeInstances[i]

		if not unit or unit.Parent == nil then
			table.remove(EmergencyState.PendingUpgradeInstances, i)
			continue
		end

		local threatStillActive = ScanForModifier("Powerful")
		if not threatStillActive then
			ELog("Threat disappeared during pending upgrade retry")
			EmergencyState.ProtocolEngaged = false
			EmergencyState.IsThreatActive = false
			EmergencyState.TargetEmergencyUnit = nil
			table.clear(EmergencyState.PendingUpgradeInstances)
			return true
		end

		local currentTier = nil
		pcall(function()
			local upgradeTag = unit:FindFirstChild("UpgradeTag")
			if upgradeTag then
				currentTier = tonumber(upgradeTag.Value)
			end
		end)

		if currentTier and currentTier >= 1 then
			ELog("Pending emergency unit already upgraded:", unit.Name)
			table.remove(EmergencyState.PendingUpgradeInstances, i)
			EmergencyState.ProtocolEngaged = false
			EmergencyState.TargetEmergencyUnit = nil
			return true
		end

		local moneyObj = LocalPlayer:FindFirstChild("Money")
		local money = moneyObj and tonumber(moneyObj.Value) or 0
		local upgradeCost = FindFirstUpgradeCost(unit) or 150

		if money >= upgradeCost then
			local ok, err = pcall(function()
				serverRemote:InvokeServer("Upgrade", unit)
			end)

			if ok then
				ELog("Retried emergency upgrade:", unit.Name, "| Cost =", upgradeCost)
			else
				EWarn("Retry emergency upgrade failed:", tostring(err))
			end
		end
	end

	return false
end

local function ExecuteEmergencyDeployment(cardData, enemyInstance)
	if not cardData then
		EWarn("[FIX-EMG-2] ExecuteEmergencyDeployment: cardData missing")
		return false, "NoCardData"
	end

	local threatStillActive, currentThreat = ScanForModifier("Powerful")
	if not threatStillActive then
		ELog("[FIX-EMG-2] Threat already gone before deployment")
		return false, "ThreatGone"
	end

	local targetEnemy = enemyInstance or currentThreat
	local enemyHrp = targetEnemy and targetEnemy:FindFirstChild("HumanoidRootPart")
	local existing = nil
	local moneyObj = LocalPlayer:FindFirstChild("Money")

	-- [FIX-EMG-2] ห้ามใช้ FindOwnedUnitByName แบบ global search เดี่ยว ๆ
	-- ให้คัดเฉพาะยูนิตชื่อเดียวกันที่ "อยู่ใกล้ Powerful จริง" ภายใน 40 studs
	if enemyHrp then
		local enemyPos = enemyHrp.Position
		local nearestDist = math.huge
		for _, unit in ipairs(GetOwnedUnits()) do
			local ok = pcall(function()
				return unit.Name == cardData.Name and unit:FindFirstChild("HumanoidRootPart") ~= nil
			end)
			if ok and unit.Name == cardData.Name then
				local unitHrp = unit:FindFirstChild("HumanoidRootPart")
				if unitHrp then
					local dist = (unitHrp.Position - enemyPos).Magnitude
					if dist <= 40 and dist < nearestDist then
						existing = unit
						nearestDist = dist
					end
				end
			end
		end
		if existing then
			ELog("[FIX-EMG-2] Found nearby existing defender:", existing.Name, "| distToThreat =", math.floor(nearestDist * 100) / 100)
		else
			ELog("[FIX-EMG-2] No nearby existing defender within 40 studs; allowing new intercept summon for", cardData.Name)
		end
	else
		EWarn("[FIX-EMG-2] Target enemy has no HRP; fallback to fresh summon path")
	end

	local placedUnit = nil

	if existing then
		local upgradeTagValue = nil
		pcall(function()
			local upgradeTag = existing:FindFirstChild("UpgradeTag")
			if upgradeTag then
				upgradeTagValue = tonumber(upgradeTag.Value)
			end
		end)

		if not table.find(EmergencyState.PendingUpgradeInstances, existing) then
			table.insert(EmergencyState.PendingUpgradeInstances, existing)
		end

		ELog("[FIX-EMG-2] Reusing nearby existing defender:", cardData.Name, "| currentUpgrade =", tostring(upgradeTagValue))
		placedUnit = existing
	else
		local spot, placeType = FindSpotForEmergency(targetEnemy)
		if not spot then
			EWarn("[FIX-EMG-2] No emergency intercept spot:", tostring(placeType or "NoSpot"))
			return false, tostring(placeType or "NoSpot")
		end

		local firstUpgradeCost = 150
		local moneyValue = moneyObj and tonumber(moneyObj.Value) or 0
		local totalRequired = (tonumber(cardData.Cost) or math.huge) + firstUpgradeCost

		if moneyValue < totalRequired then
			ELog("[FIX-EMG-2] Waiting for emergency budget:", moneyValue, "/", totalRequired)
			return false, "InsufficientBudget"
		end

		local preCount = 0
		for _, u in ipairs(GetOwnedUnits()) do
			if u.Name == cardData.Name then
				preCount += 1
			end
		end

		local summonOk, summonErr = pcall(function()
			inputRemote:FireServer("Summon", {
				Rotation = 0,
				cframe = spot,
				Unit = cardData.Name
			})
		end)

		if not summonOk then
			EWarn("[FIX-EMG-2] Emergency summon failed:", tostring(summonErr))
			return false, "SummonFailed"
		end

		ELog("[FIX-EMG-2] Emergency summon fired:", cardData.Name, "| Type =", tostring(placeType))

		for _ = 1, 12 do
			task.wait(0.25)
			local threatCheck = ScanForModifier("Powerful")
			if not threatCheck then
				ELog("[FIX-EMG-2] Threat disappeared after summon")
				return false, "ThreatGoneAfterSummon"
			end

			local matches = {}
			for _, u in ipairs(GetOwnedUnits()) do
				if u.Name == cardData.Name then
					table.insert(matches, u)
				end
			end

			if #matches > preCount then
				placedUnit = matches[#matches]
				break
			end
		end

		if not placedUnit then
			EWarn("[FIX-EMG-2] Emergency summon not confirmed")
			return false, "SummonNotConfirmed"
		end

		if not table.find(EmergencyState.PendingUpgradeInstances, placedUnit) then
			table.insert(EmergencyState.PendingUpgradeInstances, placedUnit)
		end
	end

	if not placedUnit or placedUnit.Parent == nil then
		EWarn("[FIX-EMG-3] No valid placedUnit for emergency upgrade loop")
		return false, "NoPlacedUnit"
	end

	-- [FIX-EMG-3] Continuous Emergency Upgrading
	local upgradedAtLeastOnce = false
	while true do
		local stillPowerful = ScanForModifier("Powerful")
		if not stillPowerful then
			ELog("[FIX-EMG-3] Threat gone during continuous upgrade loop")
			break
		end

		if not placedUnit or placedUnit.Parent == nil then
			EWarn("[FIX-EMG-3] placedUnit destroyed during emergency loop")
			break
		end

		local upgradeCost = FindFirstUpgradeCost(placedUnit)
		if not upgradeCost or upgradeCost <= 0 then
			ELog("[FIX-EMG-3] No further upgrade cost available; unit may be maxed:", placedUnit.Name)
			break
		end

		local currentMoney = moneyObj and tonumber(moneyObj.Value) or 0
		if currentMoney < upgradeCost then
			ELog("[FIX-EMG-3] Waiting for more money to continue emergency upgrades:", currentMoney, "/", upgradeCost)
			break
		end

		local upgradeOk, upgradeErr = pcall(function()
			serverRemote:InvokeServer("Upgrade", placedUnit)
		end)

		if not upgradeOk then
			EWarn("[FIX-EMG-3] Emergency upgrade invoke failed:", tostring(upgradeErr))
			break
		end

		upgradedAtLeastOnce = true
		local currentTier = nil
		pcall(function()
			local upgradeTag = placedUnit:FindFirstChild("UpgradeTag")
			if upgradeTag then
				currentTier = tonumber(upgradeTag.Value)
			end
		end)
		ELog("[FIX-EMG-3] Emergency upgraded:", placedUnit.Name, "| nextTier =", tostring(currentTier), "| nextCheckIn = 0.5s")
		task.wait(0.5)
	end

	for i = #EmergencyState.PendingUpgradeInstances, 1, -1 do
		if EmergencyState.PendingUpgradeInstances[i] == placedUnit then
			table.remove(EmergencyState.PendingUpgradeInstances, i)
		end
	end

	if upgradedAtLeastOnce then
		ELog("[FIX-EMG-3] Emergency deployment complete:", cardData.Name)
		return true, "Success"
	end

	return false, "UpgradePendingSync"
end

function EmergencyCoordinator.LockStandardRoutine()
	if not EmergencyState.ProtocolEngaged then
		ELog("Locking standard routine")
	end
	EmergencyState.ProtocolEngaged = true
end

function EmergencyCoordinator.ReleaseStandardRoutine()
	if EmergencyState.ProtocolEngaged then
		ELog("Releasing standard routine")
	end
	EmergencyState.ProtocolEngaged = false
	EmergencyState.TargetEmergencyUnit = nil
end

function EmergencyCoordinator.EvaluateThreatLevel()
	local active, enemy = ScanForModifier("Powerful")
	EmergencyState.IsThreatActive = active
	EmergencyState.IsBoardReady = HasUpgradedDefenders(enemy)

	if (not EmergencyState.IsThreatActive) or EmergencyState.IsBoardReady then
		EmergencyCoordinator.ReleaseStandardRoutine()
		return false, nil
	end

	EmergencyCoordinator.LockStandardRoutine()
	return true, enemy
end

function EmergencyCoordinator.Tick()
	if not _G.AutoPlayActive then
		return false
	end

	-- [FIX-EMG-4] Deadlock watchdog: ถ้าไม่มี Powerful แล้วให้ปลด lock ทันทีทุกกรณี
	local powerfulActive, powerfulEnemy = ScanForModifier("Powerful")
	if not powerfulActive then
		if EmergencyState.ProtocolEngaged or EmergencyState.TargetEmergencyUnit then
			ELog("[FIX-EMG-4] No Powerful found – force releasing emergency lock")
		end
		EmergencyState.ProtocolEngaged = false
		EmergencyState.IsThreatActive = false
		EmergencyState.IsBoardReady = false
		EmergencyState.TargetEmergencyUnit = nil
		table.clear(EmergencyState.PendingUpgradeInstances)
		return false
	end

	if tick() - (EmergencyState.LastScan or 0) < 0.5 then
		return EmergencyState.ProtocolEngaged
	end
	EmergencyState.LastScan = tick()

	if RetryPendingEmergencyUpgrade() then
		return true
	end

	local emergencyNeeded, threatEnemy = EmergencyCoordinator.EvaluateThreatLevel()
	threatEnemy = threatEnemy or powerfulEnemy
	if not emergencyNeeded then
		return false
	end

	local cardData = FindOptimalEmergencyCard(4)
	if not cardData then
		EWarn("Emergency failed: no usable card found")
		return true
	end

	EmergencyState.TargetEmergencyUnit = cardData.Name

	if tick() - (EmergencyState.LastAction or 0) < 0.5 then
		return true
	end
	EmergencyState.LastAction = tick()

	local success, reason = ExecuteEmergencyDeployment(cardData, threatEnemy)
	ELog("Emergency Tick Result:", tostring(success), "|", tostring(reason))

	if success then
		EmergencyCoordinator.ReleaseStandardRoutine()
	end

	return true
end

function EmergencyCoordinator.Start()
	task.spawn(function()
		while task.wait(0.5) do
			pcall(function()
				EmergencyCoordinator.Tick()
			end)
		end
	end)
end

