    -- CombatService
    function CombatService.IsAlive(monster)
        if not (monster and monster.Parent) then return false end
        local cached = Shared.Caches.monsterAlive[monster]
        if cached and (now() - cached.timestamp) <= Shared.Config.MonsterStateCacheLifetime then return cached.alive end
        local alive = monster:GetAttribute("Attackable") == true and monster:GetAttribute("Turnable") == true
        Shared.Caches.monsterAlive[monster] = { alive = alive, timestamp = now() }
        return alive
    end
    function CombatService.GetDistanceToTarget(player, monster)
        local root = getRootPart(getCharacter())
        local monsterRoot = getMonsterRoot(monster)
        if not root or not monsterRoot then return math.huge end
        return (root.Position - monsterRoot.Position).Magnitude
    end

    -- TeleportationService
    function TeleportationService.CanTeleport()
        return (nowMs() - Shared.GlobalState.lastPlacementAt) >= Shared.Config.PlacementCooldownMs
    end
    function TeleportationService.TeleportToMonster(monster, offsets)
        if not monster or not monster.Parent then return false, "INVALID_MONSTER" end
        local root = getRootPart(getCharacter())
        local monsterRoot = getMonsterRoot(monster)
        if not root then return false, "PLAYER_ROOT_MISSING" end
        if not monsterRoot then return false, "MONSTER_ROOT_MISSING" end
        if not TeleportationService.CanTeleport() then return false, "TELEPORT_COOLDOWN" end
        offsets = type(offsets) == "table" and offsets or Shared.Config.TeleportOffsets
        for i = 1, #offsets do
            local ok = pcall(function() root.CFrame = monsterRoot.CFrame * CFrame.new(offsets[i]) end)
            if ok then Shared.GlobalState.lastPlacementAt = nowMs() return true end
        end
        return false, "TELEPORT_FAILED"
    end
    function TeleportationService.IsInRaidMap()
        local root = getRootPart(getCharacter())
        if not root then return false end
        local raid = workspace:FindFirstChild("WisteriaRaid")
        local raid1 = raid and raid:FindFirstChild("Raid1")
        local raidPart = raid1 and raid1:FindFirstChild("Part")
        if not raidPart or not raidPart:IsA("BasePart") then return false end
        return (root.Position - raidPart.Position).Magnitude <= 150
    end
    local function waitForRaidMap(timeoutSeconds)
        local deadline = now() + (timeoutSeconds or Shared.Config.RaidMapWaitTimeout)
        while now() < deadline do
            if TeleportationService.IsInRaidMap() then return true end
            task.wait(0.25)
        end
        return false
    end
    function TeleportationService.TeleportToRaid()
        if TeleportationService.IsInRaidMap() then return true end
        local lastError = "RAID_OPEN_FAILED"
        for attempt = 1, Shared.Config.RaidOpenMaxAttempts do
            local ok, result = RemoteService.OpenWisteriaRaid()
            if ok then
                if waitForRaidMap(Shared.Config.RaidMapWaitTimeout) then task.wait(0.5) return true end
                lastError = "RAID_MAP_TIMEOUT"
            else lastError = result end
            task.wait(Shared.Config.RaidOpenBackoff[math.min(attempt, #Shared.Config.RaidOpenBackoff)] or 1)
        end
        return false, lastError
    end

    -- MonsterTracker
    local function scanFarmMonsters()
        local all, byName, uniqueNames, seenNames = {}, {}, {}, {}
        for _, child in ipairs(workspace:GetChildren()) do
            if string.match(child.Name, "^World%d+$") then
                local enemyFolder = child:FindFirstChild("Enemy")
                if enemyFolder then
                    for _, monster in ipairs(enemyFolder:GetChildren()) do
                        if monster:IsA("Model") then
                            all[#all + 1] = monster
                            byName[monster.Name] = byName[monster.Name] or {}
                            table.insert(byName[monster.Name], monster)
                            if not seenNames[monster.Name] then
                                seenNames[monster.Name] = true
                                uniqueNames[#uniqueNames + 1] = monster.Name
                            end
                        end
                    end
                end
            end
        end
        table.sort(uniqueNames)
        Shared.Caches.farm.all = all
        Shared.Caches.farm.byName = byName
        Shared.Caches.farm.uniqueNames = uniqueNames
        Shared.Caches.farm.lastRefresh = now()
    end
    local function scanRaidMonsters()
        local all = {}
        local raid = workspace:FindFirstChild("WisteriaRaid")
        local raid1 = raid and raid:FindFirstChild("Raid1")
        local enemyFolder = raid1 and raid1:FindFirstChild("Enemy")
        if enemyFolder then
            for _, monster in ipairs(enemyFolder:GetChildren()) do
                if monster:IsA("Model") and CombatService.IsAlive(monster) then all[#all + 1] = monster end
            end
        end
        Shared.Caches.raid.all = all
        Shared.Caches.raid.lastRefresh = now()
    end
    function MonsterTracker.SetMode(mode) Shared.Caches.mode = mode == "RAID" and "RAID" or "FARM" end
    function MonsterTracker.RefreshFarmMonsters()
        local ok, err = safePCall("RefreshFarmMonsters", scanFarmMonsters)
        if not ok then ErrorHandler.Record("FARM_SCAN", err) end
        return Shared.Caches.farm.all
    end
    function MonsterTracker.RefreshRaidEnemies()
        local ok, err = safePCall("RefreshRaidEnemies", scanRaidMonsters)
        if not ok then ErrorHandler.Record("RAID_SCAN", err) end
        return Shared.Caches.raid.all
    end
    function MonsterTracker.GetAllMonsters(mode)
        mode = mode == "RAID" and "RAID" or "FARM"
        local source = mode == "RAID" and Shared.Caches.raid.all or Shared.Caches.farm.all
        local result, idx = {}, 0
        for i = 1, #source do
            local monster = source[i]
            if monster and monster.Parent and CombatService.IsAlive(monster) then
                idx += 1 result[idx] = monster
            end
        end
        return result
    end
    function MonsterTracker.GetNearestMonster(mode)
        mode = mode == "RAID" and "RAID" or "FARM"
        local cache = mode == "RAID" and Shared.Caches.raid or Shared.Caches.farm
        local current = now()
        if cache.nearestCache and cache.nearestCache.Parent and (current - cache.lastNearAt) <= Shared.Config.NearCacheLifetime then
            if CombatService.IsAlive(cache.nearestCache) then return cache.nearestCache end
        end
        local root = getRootPart(getCharacter())
        if not root then return nil end
        local myPos = root.Position
        local source = mode == "RAID" and Shared.Caches.raid.all or Shared.Caches.farm.all
        local nearest, bestDist = nil, math.huge
        for i = 1, #source do
            local monster = source[i]
            if monster and monster.Parent and CombatService.IsAlive(monster) then
                local monsterRoot = getMonsterRoot(monster)
                if monsterRoot then
                    local d2 = getDistanceSquared(myPos, monsterRoot.Position)
                    if d2 < bestDist then bestDist = d2 nearest = monster end
                end
            end
        end
        cache.nearestCache = nearest cache.lastNearAt = current
        return nearest
