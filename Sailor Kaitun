                            _G.TargetMob = mobAfterTeleport
                        else
                            -- วาร์ปมาแล้วแต่ไม่เจอ (อาจจะบักหรือคนอื่นฆ่าไปแล้ว) → ข้าม
                            _G.BossNoMobAfterTeleport[activeBoss] = true
                            local selectedList = getSelectedBossList()
                            _G.BossRoundRobinIndex = (_G.BossRoundRobinIndex % #selectedList) + 1
                            _G.CurrentActiveBoss = nil
                        end
                    end

                else
                    local mob = findBossMob(bData.MobName)
                    if mob then
                        _G.TargetMob = mob
                    elseif isBossSpawningSoon(activeBoss) then
                        -- ถ้าใกล้เกิด ให้วาร์ปไปรอ
                        doTeleport(bData.Prefix)
                    end
                end

            -- 🌟 3. ถ้าระบบ Boss/Summon ว่าง ให้มาระบบ Auto Island Farm
            elseif MoMoConfig.AutoIsland and not MoMoConfig.AutoSummon and not MoMoConfig.AutoStrongestBoss and not MoMoConfig.AutoTrueAizen then
                local selectedList = getSelectedIslandList()
                
                if #selectedList > 0 then
                    if _G.IslandRoundRobinIndex > #selectedList then
                        _G.IslandRoundRobinIndex = 1
                    end
                    
                    local currentIsland = selectedList[_G.IslandRoundRobinIndex]
                    local closestTargetMob = getClosestTargetMobForIsland(currentIsland)
                    
                    if closestTargetMob then
                        _G.TargetMob = closestTargetMob
                    else
                        if tick() - _G.LastIslandTeleportTime > 3 then
                            _G.IslandRoundRobinIndex = (_G.IslandRoundRobinIndex % #selectedList) + 1
                            local nextIsland = selectedList[_G.IslandRoundRobinIndex]
                            
                            pcall(function() RS:WaitForChild("Remotes"):WaitForChild("TeleportToPortal"):FireServer(nextIsland) end)
                            pcall(function() Window:Notify({Title = "Auto Island", Desc = "🏝️ Clear! Next: " .. nextIsland, Time = 3}) end)
                            
                            _G.LastIslandTeleportTime = tick()
                            task.wait(0.5) 
                        end
                    end
                end
                
            -- 🌟 3.5 ระบบ Auto Haki Quest (เพิ่มเข้ามาใน ENGINE 1 เพื่อล็อกเป้าหมายให้แม่นยำ)
            elseif _G.KaitunPhase == "doingHakiQuest1" or _G.KaitunPhase == "doingHakiQuest2" or _G.KaitunPhase == "doingHakiQuestFinal" then
                local hakiIslands = {"Starter", "Jungle"}
                if _G.HakiIslandIndex == nil then _G.HakiIslandIndex = 1 end
                
                local currentIsland = hakiIslands[_G.HakiIslandIndex]
                local targetMob = getClosestTargetMobForIsland(currentIsland)
                
                if targetMob then
                    _G.TargetMob = targetMob 
                else
                    if tick() - _G.LastIslandTeleportTime > 3 then
                        _G.HakiIslandIndex = (_G.HakiIslandIndex % #hakiIslands) + 1
                        local nextIsland = hakiIslands[_G.HakiIslandIndex]
                        pcall(function() RS:WaitForChild("Remotes"):WaitForChild("TeleportToPortal"):FireServer(nextIsland) end)
                        pcall(function() Window:Notify({Title = "Haki Quest", Desc = "🏝️ Moving to " .. nextIsland, Time = 3}) end)
                        _G.LastIslandTeleportTime = tick()
                    end
                end

            -- 🌟 4. ระบบ Auto Level Farm ปกติ
            elseif MoMoConfig.AutoFarm then
                local npc, targetType, targetIsland = getFarmInfo()

                -- ✅ [ FORCE ABANDON ] พาสลับ NPC เมื่อไหร่ ให้ล้างเควสเก่าทิ้งทันที
                if npc ~= lastQuestNPC then
                    pcall(function() RS.RemoteEvents.QuestAbandon:FireServer("repeatable") end)
                    
                    -- 🛑 [ KILL SWITCH ] สั่ง ENGINE 2 หยุดคุมตัวละครทันที!
                    _G.IsTeleporting = true
                    _G.LastMobPosition = nil
                    _G.TargetMob = nil
                    _G.TargetPosition = nil
                    
                    -- ลบ BodyVelocity + ปลด Anchored (ENGINE 2 จะไม่สร้างใหม่เพราะ IsTeleporting = true)
                    local myRoot = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
                    if myRoot then
                        myRoot.Anchored = false
                        myRoot.Velocity = Vector3.new(0, 0, 0)
                        for _, bv in pairs(myRoot:GetChildren()) do
                            if bv:IsA("BodyVelocity") then
                                bv:Destroy()
                            end
                        end
                    end
                    task.wait(0.5) -- ให้ physics ตกลงพื้นสักครู่
                    
                    -- 🛑 วาร์ปไป Portal เฉพาะตอนเปลี่ยนเควส
                    if targetIsland then
                        _G.PendingFarmIsland = targetIsland
                        _G.LastFarmTeleportTime = tick()
                        pcall(function() Window:Notify({Title = "Auto Farm", Desc = "✈️ Changing Quest! Teleporting to " .. targetIsland, Time = 3}) end)
                        pcall(function() RS:WaitForChild("Remotes"):WaitForChild("TeleportToPortal"):FireServer(targetIsland) end)
                        task.wait(4) -- รอแมพโหลด (ENGINE 2 ยังหยุดอยู่)
                    end
                    
                    -- ✅ ปลดล็อก ENGINE 2 กลับมาทำงาน!
                    _G.IsTeleporting = false
                    
                    lastQuestNPC = npc
                    lastQuestTime = 0
                    task.wait(0.3)
                end
                
                -- 🛑 [ RETRY ] ถ้าวาร์ปไม่ติด (ยังหามอนไม่เจอ) ให้ลองวาร์ปซ้ำทุก 5 วิ
                if _G.PendingFarmIsland and not _G.TargetMob then
                    local npcsFolder = workspace:FindFirstChild("NPCs")
                    local foundAnyMob = false
                    if npcsFolder and targetType then
                        for _, mob in pairs(npcsFolder:GetChildren()) do
                            if string.find(mob.Name, targetType) and mob:FindFirstChild("Humanoid") and mob.Humanoid.Health > 0 then
                                foundAnyMob = true
                                break
                            end
                        end
                    end
                    
                    if foundAnyMob then
                        _G.PendingFarmIsland = nil
                    elseif tick() - (_G.LastFarmTeleportTime or 0) > 5 then
                        -- ใช้ KILL SWITCH อีกครั้งตอน Retry
                        _G.IsTeleporting = true
                        local myRoot = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
                        if myRoot then
                            myRoot.Anchored = false
                            for _, bv in pairs(myRoot:GetChildren()) do
                                if bv:IsA("BodyVelocity") then bv:Destroy() end
                            end
                        end
                        task.wait(0.3)
                        
                        pcall(function() Window:Notify({Title = "Auto Farm", Desc = "🔄 Retrying teleport to " .. _G.PendingFarmIsland, Time = 2}) end)
                        pcall(function() RS:WaitForChild("Remotes"):WaitForChild("TeleportToPortal"):FireServer(_G.PendingFarmIsland) end)
                        _G.LastFarmTeleportTime = tick()
                        task.wait(4)
                        _G.IsTeleporting = false
                    end
                end
                
                if npc and (tick() - lastQuestTime > 5) then
                    pcall(function() RS.RemoteEvents.QuestAccept:FireServer(npc) end)
                    lastQuestTime = tick()
                end

                if currentLvl < 50 then
                    if not _G.TargetMob then
                        local root = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
                        if root then
                            local bandit = getClosestTargetMobForIsland("StarterIsland") or getClosestTargetMobForIsland("Starter")
                            if bandit then
                                _G.TargetMob = bandit
                                _G.LastTargetFoundTime = tick() -- ✅ รีเซ็ตนาฬิกา
                            else
                                _G.TargetPosition = Vector3.new(18, 5, 1056)
                            end
                        end
                    else
                        _G.LastTargetFoundTime = tick() -- ✅ มีเป้าหมายอยู่ รีเซ็ตนาฬิกา
                    end
                else
                    local npcsFolder = workspace:FindFirstChild("NPCs")
                    if npcsFolder and targetType and not _G.TargetMob then
                        for _, mob in pairs(npcsFolder:GetChildren()) do
                            if string.find(mob.Name, targetType)
                                and mob:FindFirstChild("Humanoid")
                                and mob.Humanoid.Health > 0
                                and mob:FindFirstChild("HumanoidRootPart") then
                                local isCorrectMob = true
                                if not string.find(targetType, "Boss") and string.find(mob.Name, "Boss") then isCorrectMob = false end
                                if not string.find(targetType, "Strong") and string.find(mob.Name, "Strong") then isCorrectMob = false end
                                if isCorrectMob then
                                    _G.TargetMob = mob
                                    _G.LastTargetFoundTime = tick() -- ✅ รีเซ็ตนาฬิกา
                                    break
                                end
                            end
                        end
                    elseif _G.TargetMob then
                        _G.LastTargetFoundTime = tick() -- ✅ มีเป้าหมายอยู่ รีเซ็ตนาฬิกา
                    end
                end
                
                -- 🛑 [ FIX ] ถ้าไม่เจอ Target มอนสเตอร์เกิน 5 วินาที → วาร์ปไปเกาะซ้ำ!
                if not _G.TargetMob and targetIsland then
                    if not _G.LastTargetFoundTime then _G.LastTargetFoundTime = tick() end
                    
                    if tick() - _G.LastTargetFoundTime > 5 then
                        -- 🛑 KILL SWITCH → หยุด ENGINE 2
                        _G.IsTeleporting = true
                        _G.TargetMob = nil
                        _G.TargetPosition = nil
                        _G.LastMobPosition = nil
                        
                        -- ลบ BodyVelocity + ปลด Anchored
                        local myRoot = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
                        if myRoot then
                            myRoot.Anchored = false
                            myRoot.Velocity = Vector3.new(0, 0, 0)
                            for _, bv in pairs(myRoot:GetChildren()) do
                                if bv:IsA("BodyVelocity") then bv:Destroy() end
                            end
                        end
                        task.wait(0.5) -- รอตัวละครตกลงพื้น
                        
                        -- ยิง TeleportToPortal
                        pcall(function() Window:Notify({Title = "Auto Farm", Desc = "⚠️ No target for 5s! Re-teleporting to " .. targetIsland, Time = 3}) end)
                        pcall(function() RS:WaitForChild("Remotes"):WaitForChild("TeleportToPortal"):FireServer(targetIsland) end)
                        task.wait(4) -- รอแมพโหลด
                        
                        -- ปลดล็อก ENGINE 2 กลับมาทำงาน
                        _G.IsTeleporting = false
                        _G.LastTargetFoundTime = tick() -- รีเซ็ตนาฬิกาหลังวาร์ป
                    end
                end
                
                -- 🛑 [ ลบโค้ดวาร์ปรัวๆ ตอนมอนหมดทิ้งไปเรียบร้อยแล้ว! ]
            end

            local selectedWeaponType = MoMoConfig.WeaponType
            if selectedWeaponType ~= "None" then
                local function getToolType(tName) return WeaponDatabase[tName] or "Melee" end
                
                if selectedWeaponType == "Sword" then
                    -- 🛑 [ FIX ] ระงับการบังคับถือดาบหน้าเดียว ถ้ากำลังอยู่ในโหมดคอมโบสลับดาบ!
                    if _G.KaitunPhase == "farmIchigo" or _G.KaitunPhase == "farmPity" then
                        -- ปล่อยให้ลูป Dual-Sword ด้านบนทำหน้าที่สลับดาบไปมาแทน ป้องกันการดึงอาวุธแย่งกันเอง!
                    else
                        -- 🥇 ถ้าฟาร์มปกติ ให้มันหยิบ Soul Reaper มาถือเป็นอันดับแรกสุด!
                        local swordPriority = {"Soul Reaper", "Ichigo", "Excalibur", "Saber", "True Aizen", "Yamato", "Gryphon", "Dark Blade"}
                        local hasEquippedTopTier = false
                        
                        for _, swordName in ipairs(swordPriority) do
                            local inChar = char:FindFirstChild(swordName)
                            local inPack = LP.Backpack:FindFirstChild(swordName)
                            
                            -- ถ้ามีดาบระดับเทพอยู่ในตัว ให้หยิบมาถือทันที แล้วหยุดค้นหา
                            if inChar or inPack then
                                hasEquippedTopTier = true
                                if not inChar and char:FindFirstChild("Humanoid") and inPack then
                                    char.Humanoid:EquipTool(inPack)
                                end
                                break 
                            end
                        end -- ปิด for loop
                        
                        -- ถ้าไม่มีดาบระดับเทพในกระเป๋าเลย ให้หยิบดาบอะไรก็ได้ที่มีออกมาถือ
                        if not hasEquippedTopTier then
                            local isEquipped = false
                            for _, tool in pairs(char:GetChildren()) do
                                if tool:IsA("Tool") and getToolType(tool.Name) == "Sword" then isEquipped = true; break end
                            end
                            if not isEquipped then
                                for _, tool in pairs(LP.Backpack:GetChildren()) do
                                    if tool:IsA("Tool") and getToolType(tool.Name) == "Sword" then
                                        if char:FindFirstChild("Humanoid") then char.Humanoid:EquipTool(tool) end
                                        break
                                    end
                                end
                            end
                        end
                    end -- ปิด else ของการเช็คโหมดคอมโบ
                    
                -- ==========================================
                -- 🥊 [ ระบบสวมใส่หมัด (Melee) ]
                -- ==========================================
                elseif selectedWeaponType == "Melee" then
                    local isEquipped = false
                    for _, tool in pairs(char:GetChildren()) do
                        if tool:IsA("Tool") and getToolType(tool.Name) == "Melee" then isEquipped = true; break end
                    end
                    if not isEquipped then
                        for _, tool in pairs(LP.Backpack:GetChildren()) do
                            if tool:IsA("Tool") and getToolType(tool.Name) == "Melee" then
                                if char:FindFirstChild("Humanoid") then char.Humanoid:EquipTool(tool) end
                                break
                            end
                        end
                    end
                end
            end

        else
            _G.TargetMob = nil
            _G.TargetPosition = nil
        end
        end -- ปิดเงื่อนไข if isNavigating then
    end
end)

-- ==========================================
-- 🚀 [ ENGINE 2: Movement Execution ]
-- ==========================================
task.spawn(function()
    -- 🛑 [ REMOVED ] local oldTarget = nil (เปลี่ยนไปใช้ _G.LastMobPosition แทนเพื่อให้ ENGINE 1 ล้างค่าข้ามสคริปต์ได้)
    while true do
        task.wait() 
        
        -- 🛑 [ FIX ] ถ้ากำลังวาร์ป ห้าม ENGINE 2 ทำอะไรเด็ดขาด! ปล่อยให้ Teleport ทำงาน!
        if _G.IsTeleporting then continue end
        
        local farmActive = (MoMoConfig.AutoFarm or MoMoConfig.AutoBoss or MoMoConfig.AutoIsland or MoMoConfig.AutoSummon or MoMoConfig.AutoDungeon or MoMoConfig.AutoStrongestBoss or MoMoConfig.AutoTrueAizen or MoMoConfig.AutoHogyokuQuest or string.find(_G.KaitunPhase, "Haki") or string.find(_G.KaitunPhase, "buy"))
        local char = LP.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChild("Humanoid")

        if farmActive and root and hum then
            
            local bv = root:FindFirstChild("MomoFloatBV")
            if not bv then
                bv = Instance.new("BodyVelocity")
                bv.Name = "MomoFloatBV"
                bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
                bv.Velocity = Vector3.new(0, 0, 0)
                bv.Parent = root
            end

            local hasTarget = (_G.TargetMob ~= nil) or (_G.TargetPosition ~= nil)
            
            if hasTarget and (
                (_G.TargetMob and _G.TargetMob:FindFirstChild("HumanoidRootPart") and _G.TargetMob.Humanoid.Health > 0) or
                (_G.TargetPosition ~= nil)
            ) then
                
                root.Anchored = false 
                if hum then hum.PlatformStand = false end
                
                local targetPos = nil
                local lookAtTarget = nil
                
                local mobRoot = _G.TargetMob and (_G.TargetMob:FindFirstChild("HumanoidRootPart") or _G.TargetMob:FindFirstChild("Torso") or _G.TargetMob.PrimaryPart)
                if mobRoot and _G.TargetMob:FindFirstChild("Humanoid") and _G.TargetMob.Humanoid.Health > 0 then
                    targetPos = mobRoot.Position + Vector3.new(0, MoMoConfig.FarmHeight, 0)
                    lookAtTarget = mobRoot.Position
                elseif _G.TargetPosition then
                    targetPos = _G.TargetPosition
                end
                
                if targetPos then
                    lookAtTarget = lookAtTarget or targetPos
                    SafeBypassWarp(targetPos, lookAtTarget)
                    _G.LastMobPosition = targetPos -- 🛑 [ FIX ] เปลี่ยนมาใช้ตัวแปร Global เพื่อให้ล้างค่าข้าม ENGINE ได้
                end
            else
                -- 🛑 [ จุดที่แก้ไข ] สั่งปลด Anchored ถ้ากำลังทำเควสฮาคิ หรือซื้อของ แต่ "ห้ามแช่แข็ง" ถ้ากำลังฟาร์มเลเวลปกติ
                if string.find(_G.KaitunPhase, "Haki") or string.find(_G.KaitunPhase, "buy") then
                    root.Anchored = false
                    if hum then hum.PlatformStand = false end
                elseif _G.KaitunPhase == "farmLevel" then
                    -- สำหรับ FarmLevel ถ้าไม่มีเป้าหมาย ให้เดินกลับจุดเก่าแทนที่จะยืนนิ่ง
                    if _G.LastMobPosition and typeof(_G.LastMobPosition) == "Vector3" then
                        SafeBypassWarp(_G.LastMobPosition + Vector3.new(0, MoMoConfig.FarmHeight, 0))
                    else
                        -- ยืนนิ่งๆ แต่ห้ามแช่แข็ง เพื่อให้โดนมอนตบตายและเกิดใหม่ (Bypass TP จะทำให้มอนตีไม่โดน)
                        root.Anchored = false
                    end
                else
                    root.Anchored = true
                    root.Velocity = Vector3.new(0,0,0)
                end
            
                -- เคลียร์เป้าหมายที่ตายแล้ว
                _G.TargetMob = nil
                _G.TargetPosition = nil
            end
        else
            if root then
                for _, oldBv in pairs(root:GetChildren()) do
                    if oldBv:IsA("BodyVelocity") and string.find(oldBv.Name, "Momo") then
                        oldBv:Destroy()
                    end
                end
                root.Anchored = false
                if hum then 
                    hum.PlatformStand = false
                    hum:ChangeState(8)
                end
            end
        end
    end
end)
