-- Delete / Refresh Buttons Group
local cfgManageGroup = cfgSection:Group({})

cfgManageGroup:Button({
    Title = "🗑️ Delete Config",
    Icon  = "trash-2",
    Color = Red,
    Justify = "Center",
    Callback = function()
        if cfgName == "" or cfgName == "Default" then return end
        local cfg = cfgMgr:Config(cfgName)
        if cfg:Delete() then
            pcall(function()
                WindUI:Notify({ Title = "🗑️ Deleted", Content = "Deleted [" .. cfgName .. "] successfully", Duration = 3 })
            end)
            
            -- ปิด Auto Load ให้ด้วยถ้า Config ที่เลือกลบหายไปแล้ว
            if writefile then pcall(function() writefile("MoMoHub_AutoLoad.txt", "") end) end 
            
            cfgName = "Default"
            cfgInput:Set("Default")
            cfgList:Refresh(cfgMgr:AllConfigs())
        end
    end,
})

cfgManageGroup:Space()

cfgManageGroup:Button({
    Title = "🔄 Refresh List",
    Icon  = "refresh-cw",
    Color = Yellow,
    Justify = "Center",
    Callback = function()
        local configs = cfgMgr:AllConfigs()
        cfgList:Refresh(configs)
        pcall(function() WindUI:Notify({ Title = "🔄 Refreshed!", Content = "Found " .. #configs .. " configs", Duration = 3 }) end)
    end,
})

