    local recentFailedSpots = {}

    local lastAutoActionAt = 0
    local lastPlaceAttemptAt = 0
    local lastFarmAttemptAt = 0
    local lastUpgradeBurstAt = 0
    local placementFailStreak = 0
    local lastJoinAttempt = 0

    local AUTO_LOOP_INTERVAL = 0.6
    local GLOBAL_ACTION_COOLDOWN = 0.25
    local PLACE_COOLDOWN = 0.75
    local FARM_COOLDOWN = 0.75
    local UPGRADE_BURST_COOLDOWN = 0.4
    local FAIL_BACKOFF_BASE = 0.5
    local FAIL_BACKOFF_MAX = 2.0

    local function getFailBackoff()
        return math.min(FAIL_BACKOFF_BASE + (placementFailStreak * 0.25), FAIL_BACKOFF_MAX)
    end

    local function canDoGlobalAction()
        return (tick() - lastAutoActionAt) >= GLOBAL_ACTION_COOLDOWN
    end

    local function markGlobalAction()
        lastAutoActionAt = tick()
    end

    local function canAttemptFarm()
        return (tick() - lastFarmAttemptAt) >= FARM_COOLDOWN and canDoGlobalAction()
    end

    local function canAttemptPlacement()
        return (tick() - lastPlaceAttemptAt) >= (PLACE_COOLDOWN + getFailBackoff()) and canDoGlobalAction()
    end

    local function canBurstUpgrade()
        return (tick() - lastUpgradeBurstAt) >= UPGRADE_BURST_COOLDOWN and canDoGlobalAction()
    end

    local function markFarmAttempt(success)
        lastFarmAttemptAt = tick()
        markGlobalAction()
        if success then
            placementFailStreak = 0
        else
            placementFailStreak += 1
        end
    end

    local function markPlacementAttempt(success)
        lastPlaceAttemptAt = tick()
        markGlobalAction()
        if success then
            placementFailStreak = 0
        else
            placementFailStreak += 1
        end
    end

    local function markUpgradeBurst()
        lastUpgradeBurstAt = tick()
        markGlobalAction()
    end

    local function trimFailedSpots()
        local now = tick()
        local kept = {}
        for _, item in ipairs(recentFailedSpots) do
            if now - item.t < 8 then
                table.insert(kept, item)
            end
        end
        recentFailedSpots = kept
    end

    local function markFailedSpot(pos)
        if pos then
            table.insert(recentFailedSpots, {pos = pos, t = tick()})
        end
    end

    local function isNearFailedSpot(pos, radius)
        radius = radius or 4
        trimFailedSpots()
        for _, item in ipairs(recentFailedSpots) do
            if (item.pos - pos).Magnitude <= radius then
                return true
            end
        end
        return false
    end

    local function softResync()
        local placedFolder = workspace:FindFirstChild("placedTowers")
        local liveCount = placedFolder and #placedFolder:GetChildren() or 0
        local tracked = 0

        for i = 1, 6 do
            tracked += (placedTracking[i] or 0)
        end

        if liveCount == 0 then
            placedTracking = {0, 0, 0, 0, 0, 0}
            farmPositions = {}
            recentFailedSpots = {}
            placementFailStreak = 0
            lastAutoActionAt = 0
            lastPlaceAttemptAt = 0
            lastFarmAttemptAt = 0
            lastUpgradeBurstAt = 0
            return
        end

        if tracked > liveCount + 2 then
            placedTracking = {0, 0, 0, 0, 0, 0}
            farmPositions = {}
            recentFailedSpots = {}
            placementFailStreak = 0
            print("♻️ [ResetAI] Tracking desync detected, reset local counters.")
        end
    end

    local function getDeckCardBySlot(deck, slot)
        for _, card in ipairs(deck) do
            if card.Slot == slot then
                return card
            end
        end
        return nil
    end

    local function getOrderedPriorityCards(deck, farmSlot)
        local result = {}

        for _, slotNum in ipairs(MoMoConfig.UnitPriority) do
            if slotNum ~= farmSlot then
                local card = getDeckCardBySlot(deck, slotNum)
                if card then
                    table.insert(result, card)
                end
            end
        end

        for _, card in ipairs(deck) do
            local exists = false
            for _, picked in ipairs(result) do
                if picked.Slot == card.Slot then
                    exists = true
                    break
                end
            end
            if not exists and card.Slot ~= farmSlot then
                table.insert(result, card)
            end
        end

        return result
    end

    local function classifyPlacedTowers()
        local attackTowers = {}
        local farmTowers = {}
        local placedFolder = workspace:FindFirstChild("placedTowers")

        if placedFolder then
            for _, obj in pairs(placedFolder:GetChildren()) do
                if obj:IsA("Model") and obj.Name:match("^tower%-") then
                    local pos = obj:GetPivot().Position
                    local isFarm = false

                    for _, fPos in ipairs(farmPositions) do
                        if (pos - fPos).Magnitude < 3 then
                            isFarm = true
                            break
                        end
                    end

                    if isFarm then
                        table.insert(farmTowers, obj)
                    else
                        table.insert(attackTowers, obj)
                    end
                end
            end
        end

        return attackTowers, farmTowers, placedFolder
    end

    local function getLatestEnemyAnchor()
        local enemies = workspace:FindFirstChild("enemiesModels")
        if not enemies then
            return nil, nil
        end

        local bestEnemy = nil
        local bestPos = nil
        local bestScore = -math.huge

        for _, enemy in ipairs(enemies:GetChildren()) do
            local hrp = enemy:FindFirstChild("HumanoidRootPart")
            if hrp then
                local pos = hrp.Position

                -- heuristic ง่าย ๆ: ใช้แกน Z เป็นตัวประมาณ "ตัวที่อยู่หน้าสุด"
                -- ถ้าแมพไหนทิศทางเดินไม่ใช่ Z ค่อยเปลี่ยน logic นี้ทีหลัง
                if pos.Z > bestScore then
                    bestScore = pos.Z
                    bestEnemy = enemy
                    bestPos = pos
                end
            end
        end

        return bestEnemy, bestPos
    end

    local function findSpotNearLatestEnemy(minDist, maxDist, tries)
        minDist = minDist or 5
        maxDist = maxDist or 18
        tries = tries or 10

        local _, enemyPos = getLatestEnemyAnchor()
        if not enemyPos then
            return findSpot()
        end

        local bestSpot = nil
        local bestScore = math.huge

        for _ = 1, tries do
            local spot = findSpot()
            if spot and spot.Position and not isNearFailedSpot(spot.Position, 4) then
                local dist = (spot.Position - enemyPos).Magnitude

                if dist >= minDist and dist <= maxDist then
                    local targetDist = (minDist + maxDist) / 2
                    local score = math.abs(dist - targetDist)

                    if score < bestScore then
                        bestScore = score
                        bestSpot = spot
                    end
                end
            end
        end

        -- fallback: ถ้าไม่มีจุดในช่วงที่ต้องการจริง ๆ ค่อยยอมใช้ spot ที่ใกล้สุด
        if not bestSpot then
            local fallbackScore = math.huge

            for _ = 1, math.max(tries // 2, 4) do
                local spot = findSpot()
                if spot and spot.Position and not isNearFailedSpot(spot.Position, 4) then
                    local dist = (spot.Position - enemyPos).Magnitude
                    local score = math.abs(dist - maxDist)

                    if score < fallbackScore then
                        fallbackScore = score
                        bestSpot = spot
                    end
                end
            end
        end

        return bestSpot
    end

    local function tryPlaceFarm(sync, farmCard, placedFolder, farmLimit)
        if not sync or not farmCard then return false end

        local placedFarm = placedTracking[farmCard.Slot] or 0
        if placedFarm >= farmLimit then return false end
        if not canAttemptFarm() then return false end
        if getRealMoney() < farmCard.Cost then return false end

        local success = false

        for _ = 1, 6 do
            local spot = findFarmSpot()
            if spot and not isNearFailedSpot(spot.Position, 5) then
                local countBefore = placedFolder and #placedFolder:GetChildren() or 0
                local ok = pcall(function()
                    sync.clientTowerPlacement.call(farmCard.UUID, spot)
                end)

                if ok then
                    task.wait(0.7)
                    local countAfter = placedFolder and #placedFolder:GetChildren() or 0
                    if countAfter > countBefore then
                        placedTracking[farmCard.Slot] = (placedTracking[farmCard.Slot] or 0) + 1
                        table.insert(farmPositions, spot.Position)
                        success = true
                        print("🤑 [FarmFirst] วางตัวฟาร์มสำเร็จ (" .. placedTracking[farmCard.Slot] .. "/" .. farmLimit .. ")")
                        break
                    else
                        markFailedSpot(spot.Position)
                    end
                else
                    markFailedSpot(spot.Position)
                end
            end
        end

        markFarmAttempt(success)
        return success
    end

    local function tryPlacePriorityAttack(sync, deck, farmSlot, placedFolder)
        if not sync or #deck == 0 then return false end
        if not canAttemptPlacement() then return false end

        local money = getRealMoney()
        local priorityCards = getOrderedPriorityCards(deck, farmSlot)
        local success = false

        for _, card in ipairs(priorityCards) do
            local limit = MoMoConfig.UnitLimits[card.Slot] or 0
            local placed = placedTracking[card.Slot] or 0

            if placed < limit and money >= card.Cost then
                for _ = 1, 6 do
                    local spot = findSpotNearLatestEnemy(4, 14, 8)
                    if spot and spot.Position and not isNearFailedSpot(spot.Position, 4) then
                        local countBefore = placedFolder and #placedFolder:GetChildren() or 0
                        local ok = pcall(function()
                            sync.clientTowerPlacement.call(card.UUID, spot)
                        end)

                        if ok then
                            task.wait(0.7)
                            local countAfter = placedFolder and #placedFolder:GetChildren() or 0
                            if countAfter > countBefore then
                                placedTracking[card.Slot] = (placedTracking[card.Slot] or 0) + 1
                                success = true
                                print("✅ [Priority] วาง Unit Slot " .. card.Slot .. " สำเร็จ (" .. placedTracking[card.Slot] .. "/" .. limit .. ")")
                                break
                            else
                                markFailedSpot(spot.Position)
                            end
                        else
                            markFailedSpot(spot.Position)
                        end
                    end
                end
            end

            if success then
                break
            end
        end

        markPlacementAttempt(success)
        return success
    end

    local function tryUpgradeObject(obj)
        local ok = pcall(function()
            ReplicatedStorage.towers.towers_RELIABLE:FireServer(
                buffer.fromstring("\001\031+\000" .. obj.Name),
                {}
            )
        end)
        return ok
    end

    local function tryUpgradeFarmFirst(attackTowers, farmTowers, deck, farmSlot)
        if not canBurstUpgrade() then return false end

        local acted = false

        -- 1) อัปฟาร์มก่อนเสมอ
        for _, obj in ipairs(farmTowers) do
            if tryUpgradeObject(obj) then
                acted = true
            end
        end

        -- 2) แล้วค่อยอัปตาม Priority ของผู้เล่น
        local orderedPrioritySlots = {}
        for _, slotNum in ipairs(MoMoConfig.UnitPriority) do
            if slotNum ~= farmSlot then
                table.insert(orderedPrioritySlots, slotNum)
            end
        end

        for _, slotNum in ipairs(orderedPrioritySlots) do
            for _, obj in ipairs(attackTowers) do
                -- ใช้ heuristic ว่า slot tracking นี้มีของอยู่ก็ยิง upgrade ทุกตัวในสนามก่อน
                if (placedTracking[slotNum] or 0) > 0 then
                    if tryUpgradeObject(obj) then
                        acted = true
                    end
                end
            end
        end

        markUpgradeBurst()
        return acted
    end

