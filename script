local _FPSBoostApplied = false
local function ApplyFpsBoost()
    if _FPSBoostApplied then return end 
    _FPSBoostApplied = true
    task.spawn(function()
        local Lighting = game:GetService("Lighting")
        local Terrain = workspace:FindFirstChildOfClass("Terrain")
        Lighting.GlobalShadows = false
        Lighting.FogEnd = 9e9
        if Terrain then
            Terrain.WaterWaveSize = 0; Terrain.WaterWaveSpeed = 0
            Terrain.WaterReflectance = 0; Terrain.WaterTransparency = 0
            pcall(function() Terrain:Clear() end) 
        end
        local function CleanPart(v)
            pcall(function()
                if v:IsA("BasePart") or v:IsA("MeshPart") then
                    v.Material = Enum.Material.SmoothPlastic; v.Reflectance = 0; v.CastShadow = false
                elseif v:IsA("Decal") or v:IsA("Texture") then v.Transparency = 1
                elseif v:IsA("ParticleEmitter") or v:IsA("Trail") then v.Lifetime = NumberRange.new(0)
                elseif v:IsA("Fire") or v:IsA("SpotLight") or v:IsA("Smoke") or v:IsA("Sparkles") then v.Enabled = false
                end
            end)
        end
        for _, v in pairs(Lighting:GetDescendants()) do
            if v:IsA("PostEffect") or v:IsA("Atmosphere") or v:IsA("Sky") or v:IsA("ColorCorrectionEffect") or v:IsA("BloomEffect") or v:IsA("BlurEffect") or v:IsA("DepthOfFieldEffect") or v:IsA("SunRaysEffect") then v:Destroy() end
        end
        for _, v in pairs(workspace:GetDescendants()) do CleanPart(v) end
        workspace.DescendantAdded:Connect(function(v) if MoMoConfig.AutoFpsBoost then CleanPart(v) end end)
    end)
end

--// Ultra Aggressive Map Cache
--// Hide almost everything in workspace, but keep Character / Camera / Terrain safe.
--// Uses Parent = nil, not Destroy(), so it can be restored later.

_G.UltraMapCache = _G.UltraMapCache or {}
local MapCache = _G.UltraMapCache

MapCache.Enabled = MapCache.Enabled or false
MapCache.Objects = MapCache.Objects or {}      -- [instance] = originalParent
MapCache.Observer = MapCache.Observer or nil
MapCache.BatchSize = MapCache.BatchSize or 800
MapCache.JobId = MapCache.JobId or 0

local function notifyMsg(txt)
    if typeof(MoMoNotify) == "function" then
        MoMoNotify({
            Title = "Ultra Map Cache",
            Desc = txt,
            Time = 3
        })
    else
        warn("[Ultra Map Cache] " .. tostring(txt))
    end
end

local function isProtected(instance)
    if not instance then return true end
    if instance == workspace then return true end
    if instance == workspace.CurrentCamera then return true end
    if instance == workspace.Terrain then return true end

    -- 喔佮副喔� Character 喔傕腑喔囙笢喔灌箟喙€喔ム箞喔�
    local char = LP and LP.Character
    if char and (instance == char or instance:IsDescendantOf(char)) then
        return true
    end

    -- 鉁� 喔佮副喔� NPCs, Bosses, 喙佮弗喔� Model 喔椸傅喙堗浮喔� Humanoid 喔椸副喙夃竾喔�浮喔�
    local keepFolders = {
        workspace:FindFirstChild("NPCs"),
        workspace:FindFirstChild("Bosses"),
        workspace:FindFirstChild("Enemies"),
        workspace:FindFirstChild("Monsters"),
        workspace:FindFirstChild("Mobs"),
    }

    for _, folder in ipairs(keepFolders) do
        if folder and (instance == folder or instance:IsDescendantOf(folder)) then
            return true
        end
    end

    -- 喔佮副喔� Model 喔椸傅喙堗浮喔� Humanoid 喙冟笝喔曕副喔� (喔∴腑喔權笚喔掂箞喙勦浮喙堗箘喔斷箟喔�涪喔灌箞喙冟笝喙傕笩喔ム箑喔斷腑喔｀箤喔∴覆喔曕福喔愢覆喔�)
    local model = instance:IsA("Model") and instance
        or instance:FindFirstAncestorOfClass("Model")
    if model and model:FindFirstChildOfClass("Humanoid") then
        return true
    end

    return false
end

local function ultraHasCachedAncestor(instance)
    local current = instance and instance.Parent
    while current do
        if MapCache.Objects[current] ~= nil then
            return true
        end
        current = current.Parent
    end
    return false
end

local function canHide(instance)
    if not instance then
        return false
    end

    if MapCache.Objects[instance] ~= nil then
        return false
    end

    if not instance.Parent then
        return false
    end

    if isProtected(instance) then
        return false
    end

    return true
end

local function hideInstance(instance)
    if not canHide(instance) then
        return false
    end

    local ok, err = pcall(function()
        MapCache.Objects[instance] = instance.Parent
        instance.Parent = nil
    end)

    if not ok then
        MapCache.Objects[instance] = nil
        warn("Hide failed:", err)
        return false
    end

    return true
end

local function ultraRestoreInstance(instance, originalParent)
    if not instance then
        return
    end

    pcall(function()
        if originalParent and (originalParent == workspace or originalParent.Parent ~= nil) then
            instance.Parent = originalParent
        else
            instance.Parent = workspace
        end
    end)
end

local function disconnectUltraObserver()
    if MapCache.Observer then
        MapCache.Observer:Disconnect()
        MapCache.Observer = nil
    end
end

local function connectUltraObserver(jobId)
    disconnectUltraObserver()

    -- DescendantAdded fires when new objects enter the tree.
    MapCache.Observer = workspace.DescendantAdded:Connect(function(instance)
        if not MapCache.Enabled then
            return
        end

        task.defer(function()
            if not MapCache.Enabled then
                return
            end

            if jobId ~= MapCache.JobId then
                return
            end

            if not instance or not instance.Parent then
                return
            end

            if isProtected(instance) then
                return
            end

            if ultraHasCachedAncestor(instance) then
                return
            end

            hideInstance(instance)
        end)
    end)
end

local function hideAll(jobId)
    local list = workspace:GetDescendants()
    local processed = 0
    local hidden = 0

    for _, obj in ipairs(list) do
        if not MapCache.Enabled then
            return
        end

        if jobId ~= MapCache.JobId then
            return
        end

        if not ultraHasCachedAncestor(obj) then
            if hideInstance(obj) then
                hidden += 1
            end
        end

        processed += 1
        if processed % MapCache.BatchSize == 0 then
            RunService.Heartbeat:Wait()
        end
    end

    notifyMsg("Hidden: " .. tostring(hidden))
end

local function restoreAll(jobId)
    local restoreList = {}
    local processed = 0
    local restored = 0

    for instance, originalParent in pairs(MapCache.Objects) do
        restoreList[#restoreList + 1] = {
            Instance = instance,
            Parent = originalParent
        }
    end

    for _, item in ipairs(restoreList) do
        if jobId ~= MapCache.JobId then
            return
        end

        ultraRestoreInstance(item.Instance, item.Parent)
        MapCache.Objects[item.Instance] = nil

        restored += 1
        processed += 1

        if processed % MapCache.BatchSize == 0 then
            RunService.Heartbeat:Wait()
        end
    end

    notifyMsg("Restored: " .. tostring(restored))
end

function ToggleUltraMap(state)
    state = state == true

    if state == MapCache.Enabled then
        return
    end

    MapCache.JobId += 1
    local jobId = MapCache.JobId

    if state then
        MapCache.Enabled = true
        connectUltraObserver(jobId)

        task.spawn(function()
            hideAll(jobId)
        end)
    else
        MapCache.Enabled = false
        disconnectUltraObserver()

        task.spawn(function()
            restoreAll(jobId)
        end)
    end
end

