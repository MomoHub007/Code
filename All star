local function StartLobbyMaster()
    local hud = LocalPlayer.PlayerGui:WaitForChild("HUD")
    local Tutorial = {}

    function Tutorial.SkipDialogueAndSummon()
        pcall(function()
            local tutV2 = hud:FindFirstChild("TutorialV2")
            if tutV2 and tutV2:FindFirstChild("TutorialDialogue") and tutV2.TutorialDialogue.Visible then
                inputRemote:FireServer("AdvanceTutorialStep")
            end
            local isSummoning = false
            for _, v in pairs(hud:GetChildren()) do
                if v:IsA("GuiObject") and v.Visible and (v.Name:find("Summon") or v.Name:find("Animation")) and v.Name ~= "SummonBanners" then
                    isSummoning = true; break
                end
            end
            if isSummoning then
                local vS = workspace.CurrentCamera.ViewportSize
                VirtualUser:Button1Down(Vector2.new(vS.X/2, vS.Y/2))
                task.wait(0.05)
                VirtualUser:Button1Up(Vector2.new(vS.X/2, vS.Y/2))
            end
        end)
    end

    function Tutorial.ForceLoadInventoryUI()
        local VIM = game:GetService("VirtualInputManager")
        local invV2 = hud:FindFirstChild("InventoryV2")
        if not invV2 or not invV2.Visible then
            local invB = hud:FindFirstChild("LeftButton") and hud.LeftButton:FindFirstChild("InventoryButton")
            if invB and invB.Visible then
                local aP, aS = invB.AbsolutePosition, invB.AbsoluteSize
                pcall(function()
                    VIM:SendMouseButtonEvent(aP.X + aS.X/2, aP.Y + aS.Y/2 + 36, 0, true, game, 1)
                    task.wait(0.05)
                    VIM:SendMouseButtonEvent(aP.X + aS.X/2, aP.Y + aS.Y/2 + 36, 0, false, game, 1)
                end)
            end
        end
    end

    function Tutorial.SmartEquip()
        print("🔍 [SmartEquip V8.1] เริ่มสแกนแบบ Deep Memory...")
        _G.MoMoStatus("เริ่มสแกนกระเป๋าแบบ Deep Memory...")
        Tutorial.ForceLoadInventoryUI()
        task.wait(3)
        
        -- 🎯 1. สแกน UI (ดึงชื่อยูนิตและดาว)
        _G.MoMoStatus("กำลังค้นหายูนิตจากหน้าจอ...")
        local unitUIList = {} 
        local highStarCount = 0
        local invV2 = hud:FindFirstChild("InventoryV2")
        local scroll = invV2 and invV2:FindFirstChildWhichIsA("ScrollingFrame", true)

        if not scroll then
            warn("❌ [UI] หา Scroll ไม่เจอ!")
            return false
        end
        
        for _, uiObj in pairs(scroll:GetChildren()) do
            if uiObj:IsA("GuiObject") then
                local stars = 0
                local starLabel = uiObj:FindFirstChild("StarFrame", true) and uiObj:FindFirstChild("StarFrame", true):FindFirstChildWhichIsA("TextLabel")
                
                -- งัดหาดาวจากลูกหลาน ถ้าหา StarFrame ไม่เจอ
                if not starLabel then
                    for _, desc in pairs(uiObj:GetDescendants()) do
                        if desc:IsA("TextLabel") and (desc.Name:lower():find("star") or (desc.Parent and desc.Parent.Name:lower():find("star"))) then
                            starLabel = desc; break
                        end
                    end
                end
                
                if starLabel and tonumber(starLabel.Text) then
                    stars = tonumber(starLabel.Text)
                end
                
                if stars > 0 then
                    if stars >= 4 then highStarCount = highStarCount + 1 end
                    
                    local realName = uiObj.Name
                    local nameLabel = uiObj:FindFirstChild("UnitName", true) or uiObj:FindFirstChild("MainName", true)
                    if nameLabel and nameLabel:IsA("TextLabel") and nameLabel.Text ~= "" then 
                        realName = nameLabel.Text 
                    end
                    
                    -- งัดหา ID จาก UI (เผื่อเกมแนบมากับ Attribute)
                    local uiID = nil
                    pcall(function()
                        uiID = uiObj:GetAttribute("uid") or uiObj:GetAttribute("uuid") or uiObj:GetAttribute("ID") or uiObj:GetAttribute("UUID")
                    end)
                    if not uiID then
                        for _, child in pairs(uiObj:GetDescendants()) do
                            local cn = child.Name:lower()
                            if cn == "uid" or cn == "uuid" or cn == "id" then
                                if child:IsA("IntValue") or child:IsA("NumberValue") or child:IsA("StringValue") then
                                    uiID = child.Value; break
                                end
                            end
                        end
                    end
                    
                    table.insert(unitUIList, {
                        Name = realName, Stars = stars, UI = uiObj, 
                        ID = uiID, Level = 1
                    })
                end
            end
        end
        
        -- 🧠 2. ดึง ID จาก Memory แบบดุดันสุดขีด
        local needMemory = false
        for _, u in ipairs(unitUIList) do
            if not u.ID then needMemory = true; break end
        end
        
        if needMemory then
            print("🧠 [Memory] UI ไม่มี ID... กำลังเจาะทะลวง getgc()...")
            _G.MoMoStatus("UI ไม่มี ID... กำลังขุดหาจาก Memory...")
            local memoryData = {}
            local countMem = 0
            
            pcall(function()
                for _, v in pairs(getgc(true)) do
                    if type(v) == "table" then
                        pcall(function()
                            -- สแกนหา Key ทุกรูปแบบที่เกมส่วนใหญ่ใช้ (ขุดลึกทะลุ Metatable)
                            local id = rawget(v, "uid") or rawget(v, "uuid") or rawget(v, "ID") or rawget(v, "UUID") or v.uid or v.uuid or v.ID or v.UUID
                            local name = rawget(v, "unitId") or rawget(v, "Name") or rawget(v, "UnitName") or v.unitId or v.Name or v.UnitName
                            local level = rawget(v, "level") or rawget(v, "Level") or v.level or v.Level or 1
                            
                            if id and type(name) == "string" then
                                memoryData[name] = {ID = id, Level = level}
                                memoryData[name:lower()] = {ID = id, Level = level} -- ดักเผื่อกรณีตัวพิมพ์เล็ก/ใหญ่ไม่ตรงกัน
                                countMem = countMem + 1
                            end
                        end)
                    end
                end
            end)
            
            print("📦 [Memory] ขุดเจอข้อมูล " .. countMem .. " รายการ")
            
            -- จับคู่ข้อมูล Memory เข้ากับตัวละครใน UI
            for _, u in ipairs(unitUIList) do
                if not u.ID then
                    local mem = memoryData[u.Name] or memoryData[u.Name:lower()]
                    if mem then
                        u.ID = mem.ID
                        u.Level = mem.Level
                        print("   🔗 จับคู่สำเร็จ: " .. u.Name .. " -> ID: " .. tostring(u.ID))
                    end
                end
            end
        end
        
        print("📊 [Scan] ตัว 4-5 ดาว: " .. highStarCount .. " | ยูนิตทั้งหมด: " .. #unitUIList)

        -- 🎰 3. สุ่มกาชา (ตัดสินจากดาวเท่านั้น)
        if highStarCount <= 1 then
            print("🎰 [Auto Gacha] ตัวละครระดับสูงน้อยเกินไป... เริ่มสุ่ม 10 โรล!")
            _G.MoMoStatus("ตัวตึงน้อยเกินไป! เริ่มสุ่มกาชา 10 โรล...")
            local killAnim = task.spawn(function()
                while task.wait(0.05) do
                    for _, v in pairs(hud:GetChildren()) do
                        if (v.Name:match("Summon") or v.Name:match("Animation")) and v.Name ~= "SummonBanners" then v:Destroy() end
                    end
                end
            end)
            pcall(function() serverRemote:InvokeServer("BannerSummon", 10, "Rerun101") end)
            task.wait(3.5)
            task.cancel(killAnim)
            Tutorial.Rejoin()
            return false 
        end

        if #unitUIList == 0 then return false end

        table.sort(unitUIList, function(a, b) return a.Stars > b.Stars end)
        
        -- 🔓 4. ถอดตัวละครเดิม
        print("🔓 [Unequip] เคลียร์ทีมเดิม...")
        _G.MoMoStatus("กำลังเคลียร์ทีมเดิม...")
        local bF = hud:FindFirstChild("BottomFrame") or hud:FindFirstChild("Main")
        if bF then
            for _, v in pairs(bF:GetDescendants()) do
                if v:IsA("StringValue") and v.Value ~= "" and v.Value ~= "Empty" then
                    pcall(function() inputRemote:FireServer("Unequip", {Stats = v.Value}) end)
                    task.wait(0.3)
                end
            end
        end
        task.wait(0.5)

        -- ✨ 5. ใส่ตัวละคร (ฉลาดขึ้น: รองรับ UUID แบบอักษร)
        print("🚀 [Auto Equip] สวมใส่ผ่าน Remote...")
        local equipped = 0
        for i = 1, math.min(6, #unitUIList) do
            local u = unitUIList[i]
            if u.ID then
                print("   ➕ กำลังใส่: " .. u.Name .. " ⭐" .. u.Stars)
                pcall(function() 
                    -- ป้องกันบั๊ก JSON: ถ้า ID เป็นข้อความยาวๆ ต้องใส่เครื่องหมายคำพูดครอบด้วย ("uuid")
                    local idStr
                    if type(u.ID) == "string" and not tonumber(u.ID) then
                        idStr = '"' .. u.ID .. '"'
                    else
                        idStr = tostring(u.ID)
                    end
                    
                    local statsJson = string.format('{"ID":%s,"Level":%d,"Name":"%s"}', idStr, u.Level, u.Name)
                    serverRemote:InvokeServer("Equip", { Stats = statsJson }) 
                end)
                task.wait(0.5)
                equipped = equipped + 1
            else
                warn("   ⚠️ ข้าม " .. u.Name .. " เพราะระบบขุดหา ID ไม่เจอ (ข้อมูลขาดหาย)!")
            end
        end
        
        task.wait(1)
        local finalCount = 0
        bF = hud:FindFirstChild("BottomFrame") or hud:FindFirstChild("Main")
        if bF then
            for _, v in pairs(bF:GetDescendants()) do
                if v:IsA("StringValue") and v.Value ~= "" and v.Value ~= "Empty" then finalCount = finalCount + 1 end
            end
        end
        
        print("🏁 [SmartEquip] สั่งใส่ไป " .. equipped .. " ตัว | ในทีมจริง: " .. finalCount .. " ตัว")
        return finalCount > 0
    end

    function Tutorial.Rejoin()
        task.wait(1)
        if #Players:GetPlayers() <= 1 then TeleportService:Teleport(game.PlaceId, LocalPlayer)
        else TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, LocalPlayer) end
    end

    -- 🚀 Tutorial Master Loop V6.6
    task.spawn(function()
        local hasCompleted = LocalPlayer:GetAttribute("TutorialStage") == "Completed" 
                           or (LocalPlayer:FindFirstChild("Stats") and LocalPlayer.Stats:FindFirstChild("Level") and LocalPlayer.Stats.Level.Value > 1)
        if hasCompleted then return end
        
        while task.wait(1.5) do 
            if not _G.LobbyActive then continue end
            local tutV2 = hud:FindFirstChild("TutorialV2")
            local isTut = tutV2 and tutV2.Visible
            
            local equippedCount = 0
            local bF = hud:FindFirstChild("BottomFrame") or hud:FindFirstChild("Main")
            if bF then
                for _, v in pairs(bF:GetDescendants()) do
                    if v:IsA("StringValue") and v.Value ~= "" and v.Value ~= "Empty" then equippedCount = equippedCount + 1 end
                end
            end
            
            if equippedCount >= 3 or (equippedCount > 0 and not isTut) then break end
            
            if equippedCount == 0 or isTut then
                Tutorial.SkipDialogueAndSummon()
                local invB = hud:FindFirstChild("LeftButton") and hud.LeftButton:FindFirstChild("InventoryButton")
                if invB and invB.Visible then
                    Tutorial.ForceLoadInventoryUI()
                    if hud:FindFirstChild("InventoryV2") and hud.InventoryV2.Visible then
                        if Tutorial.SmartEquip() then break end
                    end
                end
            end
        end
    end)

    -- 🚀 Auto Join Loop (V9.1 - Inventory Check & Smart Progression)
    task.spawn(function()
        while task.wait(3) do
            if not _G.LobbyActive then continue end
            
            -- 🛑 1. เช็คความพร้อม: ต้องมีตัวละครใส่อยู่ในทีมถึงจะไปลุยด่านได้
            local eC = 0
            local bF = hud:FindFirstChild("BottomFrame") or hud:FindFirstChild("Main")
            if bF then
                for _, v in pairs(bF:GetDescendants()) do
                    if v:IsA("StringValue") and v.Value ~= "" and v.Value ~= "Empty" then 
                        eC = eC + 1 
                    end
                end
            end
            
            if eC == 0 then continue end
            
            -- 🎒 2. ก่อนไปลุยด่าน ขอเช็คกระเป๋าก่อนว่าเต็มไหม!
            pcall(function()
                if _G.MoMoStatus then _G.MoMoStatus("กำลังเช็คพื้นที่กระเป๋า...") end
                Tutorial.ForceLoadInventoryUI()
                task.wait(1.5)
                
                local invV2 = hud:FindFirstChild("InventoryV2")
                if invV2 then
                    -- เจาะทะลวง Path ตามที่ Tester ระบุ
                    local unitAmountLbl = invV2:FindFirstChild("Page") 
                        and invV2.Page:FindFirstChild("Main") 
                        and invV2.Page.Main:FindFirstChild("Top") 
                        and invV2.Page.Main.Top:FindFirstChild("List") 
                        and invV2.Page.Main.Top.List:FindFirstChild("UnitsBox") 
                        and invV2.Page.Main.Top.List.UnitsBox:FindFirstChild("UnitAmount")
                        
                    if unitAmountLbl and unitAmountLbl:IsA("TextLabel") then
                        -- แยกตัวเลข ปัจจุบัน/สูงสุด (เช่น "16/15" -> จะดึง 16 กับ 15 ออกมา)
                        local current, max = unitAmountLbl.Text:match("(%d+)%s*/%s*(%d+)")
                        if current and max then
                            if tonumber(current) >= tonumber(max) then
                                print("🎒 [System] กระเป๋าเต็ม (" .. current .. "/" .. max .. ")! สั่งซื้อช่องเพิ่ม...")
                                if _G.MoMoStatus then _G.MoMoStatus("กระเป๋าเต็ม! กำลังขยายช่อง...") end
                                
                                -- 💰 ยิง Remote สั่งซื้อช่องกระเป๋า
                                serverRemote:InvokeServer("UpgradeInventory")
                                task.wait(1.5) -- รอให้ระบบตัดเงินและอัปเดต UI
                            end
                        end
                    end
                end
                
                -- ปิดกระเป๋าทิ้งเพื่อเตรียมวาร์ปไม่ให้ UI บังหน้าจอ
                local invB = hud:FindFirstChild("LeftButton") and hud.LeftButton:FindFirstChild("InventoryButton")
                if invB and invB.Visible and invV2 and invV2.Visible then
                    local VIM = game:GetService("VirtualInputManager")
                    local aP, aS = invB.AbsolutePosition, invB.AbsoluteSize
                    VIM:SendMouseButtonEvent(aP.X + aS.X/2, aP.Y + aS.Y/2 + 36, 0, true, game, 1)
                    task.wait(0.05)
                    VIM:SendMouseButtonEvent(aP.X + aS.X/2, aP.Y + aS.Y/2 + 36, 0, false, game, 1)
                    task.wait(0.5)
                end
            end)

            -- 🟢 3. ทีมพร้อม กระเป๋าไม่เต็ม พุ่งเข้าตู้หมายเลข 37!
            pcall(function()
                local char = LocalPlayer.Character
                local storyQ = workspace:FindFirstChild("Queue") and workspace.Queue:FindFirstChild("Story")
                
                if storyQ and char and char:FindFirstChild("HumanoidRootPart") then
                    local q = storyQ:GetChildren()
                    if #q >= 37 then
                        local cap = q[37]
                        
                        local tCF = nil
                        if cap:IsA("BasePart") then
                            tCF = cap.CFrame
                        elseif cap:IsA("Model") then
                            tCF = cap.PrimaryPart and cap.PrimaryPart.CFrame or (cap:FindFirstChildWhichIsA("BasePart", true) and cap:FindFirstChildWhichIsA("BasePart", true).CFrame)
                        end
                        
                        if tCF then
                            print("🏃 [Auto Join] วาร์ปเข้าตู้ 37 เพื่อเปิดหน้าต่างเลือกด่าน...")
                            if _G.MoMoStatus then _G.MoMoStatus("วาร์ปเข้าตู้รอสแกนด่าน...") end
                            char.HumanoidRootPart.CFrame = tCF + Vector3.new(0, 3, 0)
                            
                            task.wait(5) 
                            
                            -- 🔍 4. สแกนหาด่านล่าสุด
                            if _G.MoMoStatus then _G.MoMoStatus("กำลังสแกนหาด่านล่าสุด...") end
                            local highestStage = 1
                            local isYellowFound = false
                            local playerGui = LocalPlayer:WaitForChild("PlayerGui")
                            
                            for _, v in pairs(playerGui:GetDescendants()) do
                                if v:IsA("TextLabel") or v:IsA("TextButton") then
                                    local txt = tonumber(v.Text)
                                    if txt then
                                        local r = math.floor(v.TextColor3.R * 255 + 0.5)
                                        local g = math.floor(v.TextColor3.G * 255 + 0.5)
                                        local b = math.floor(v.TextColor3.B * 255 + 0.5)
                                        
                                        if r >= 250 and g >= 250 and b <= 10 then
                                            highestStage = txt
                                            isYellowFound = true
                                        elseif r >= 250 and g >= 250 and b >= 250 and not isYellowFound then
                                            if txt > highestStage then highestStage = txt end
                                        end
                                    end
                                end
                            end
                            
                            print("🎯 [Spy] สแกนเจอด่านที่ต้องเล่นคือด่าน: " .. highestStage)
                            if _G.MoMoStatus then _G.MoMoStatus("ลุย! กำลังเข้าเล่นด่าน " .. highestStage) end
                            
                            inputRemote:FireServer("Script395Level", tostring(highestStage), false)
                            task.wait(2)
                            
                            print("🚀 [Auto Join] ส่งคำสั่ง Start เข้าด่าน!")
                            inputRemote:FireServer("Script395Start")
                        end
                    end
                end
            end)
        end
    end)
end

