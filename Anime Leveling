    local function log(level, message, ...)
        if level == "DEBUG" and not Shared.Config.Debug then return end
        local prefix = string.format("[AnimeLeveling][%s] %s", tostring(level), tostring(message))
        if select("#", ...) > 0 then warn(prefix, ...) else warn(prefix) end
    end

    local function now() return os.clock() end
    local function nowMs() return math.floor(os.clock() * 1000) end
    local function clearArray(arr) if type(arr) == "table" then table.clear(arr) end end
    local function clamp(value, minValue, maxValue)
        value = tonumber(value) or minValue
        return math.min(math.max(value, minValue), maxValue)
    end
    local function safePCall(context, fn, ...)
        local ok, a, b, c, d = pcall(fn, ...)
        if not ok then log("WARN", context .. " failed", a) return false, a end
        return true, a, b, c, d
    end
    local function setComponentLabel(component, text)
        if not component then return false end
        local methods = { "SetTitle", "SetName", "Update", "SetText" }
        for i = 1, #methods do
            local method = component[methods[i]]
            if type(method) == "function" then
                local ok = pcall(function() method(component, text) end)
                if ok then return true end
                ok = pcall(function() method(text) end)
                if ok then return true end
            end
        end
        return pcall(function() component.Name = text end)
    end
    local function setToggleValue(toggle, value)
        if not toggle then return false end
        local methods = { "SetValue", "Update", "SetActive" }
        for i = 1, #methods do
            local method = toggle[methods[i]]
            if type(method) == "function" then
                local ok = pcall(function() method(toggle, value) end)
                if ok then return true end
                ok = pcall(function() method(value) end)
                if ok then return true end
            end
        end
        return false
    end
    local function getCharacter()
        local character = LocalPlayer and LocalPlayer.Character
        if character and character.Parent then return character end
        return nil
    end
    local function getHumanoid(character)
        if not character then return nil end
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if humanoid and humanoid.Parent then return humanoid end
        return nil
    end
    local function getRootPart(character)
        if not character then return nil end
        local root = character:FindFirstChild("HumanoidRootPart")
        if root and root:IsA("BasePart") then return root end
        return nil
    end
    local function getMonsterRoot(monster)
        if not (monster and monster.Parent) then return nil end
        local root = monster:FindFirstChild("HumanoidRootPart") or monster.PrimaryPart or monster:FindFirstChildWhichIsA("BasePart")
        if root and root:IsA("BasePart") then return root end
        return nil
    end
    local function getDistanceSquared(a, b)
        local delta = a - b
        return delta.X * delta.X + delta.Y * delta.Y + delta.Z * delta.Z
    end
    local function notify(title, desc, timeValue)
