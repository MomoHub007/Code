                        local targetY = aP.Y + (aS.Y / 2) + inset.Y
                        for i = 1, 2 do
                            VIM:SendMouseButtonEvent(targetX, targetY, 0, true, game, 1)
                            task.wait(0.1)
                            VIM:SendMouseButtonEvent(targetX, targetY, 0, false, game, 1)
                            task.wait(0.2)
                        end
                        task.wait(8)
                    end
                    return
                end
                
                -- 2. ตัดสินใจเลือกปุ่มตาม Stage
                local targetButton = nil
                local actionName = ""
                
                if currentStage <= 5 then
                    -- Stage 1-5: กด Next (ไปด่านถัดไป)
                    targetButton = findButtonByKeyword({"play next", "playnext", "next stage", "next"})
                    actionName = "Play Next"
                else
