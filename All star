-- 🔴 [MODULE 2]: Auto Play
-- ========================================================================= --
local function StartAutoPlay()
    -- ⚡ [SUB-MODULE]: Auto Game State (ควบคุมความเร็วด่าน & ข้ามเวฟ)
    task.spawn(function()
        local hasSpedUp = false 
        while task.wait(0.5) do
            if not _G.AutoPlayActive then hasSpedUp = false; continue end
            local enemiesFolder = workspace:FindFirstChild("Enemies")
            local hasEnemies = enemiesFolder and #enemiesFolder:GetChildren() > 0
            pcall(function()
                if not hasEnemies then
                    inputRemote:FireServer("VoteGameMode", "Normal")
                else
                    if not hasSpedUp then
                        print("⏩ [Auto Play] ศัตรูเวฟแรกโผล่แล้ว! สั่งเปิด Speed x2/x3!")
                        inputRemote:FireServer("SpeedChange", true)
                        hasSpedUp = true 
                    end
                end
            end)
        end
    end)

    task.spawn(function()
        while task.wait(0.5) do
            if not _G.AutoPlayActive then continue end
            pcall(function() inputRemote:FireServer("VoteWaveConfirm") end)
        end
    end)

    local pathPartsCache = {}
    local function loadPaths()
        local fN = {"Paths", "2Paths", "3Paths", "4Paths"}
        for _, n in ipairs(fN) do
            local f = workspace:FindFirstChild(n)
            if f then
                local p = {}
                for _, part in pairs(f:GetDescendants()) do if part:IsA("BasePart") then table.insert(p, part) end end
                table.sort(p, function(a, b) return (tonumber(a.Name) or 0) < (tonumber(b.Name) or 0) end)
                for _, v in ipairs(p) do table.insert(pathPartsCache, v) end
            end
        end
    end
    loadPaths()

    local function getBasePos()
        local b = workspace:FindFirstChild("Base")
        return (b and b:IsA("BasePart")) and b.Position or (#pathPartsCache > 0 and pathPartsCache[#pathPartsCache].Position or Vector3.new(0,0,0))
    end

    local function CheckDefense()
        local uF = workspace:FindFirstChild("Unit")
        local eF = workspace:FindFirstChild("Enemies")
        local bP = getBasePos()
        local myU = {}
        if uF then for _, u in pairs(uF:GetChildren()) do if u:FindFirstChild("Owner") and u.Owner.Value == LocalPlayer then table.insert(myU, u) end end end
        if #myU == 0 then return true end
        if not eF or #eF:GetChildren() == 0 then return false end
        local mED = math.huge
        for _, e in pairs(eF:GetChildren()) do if e:FindFirstChild("HumanoidRootPart") then local d = (e.HumanoidRootPart.Position - bP).Magnitude; if d < mED then mED = d end end end
        local mUD = math.huge
        for _, u in ipairs(myU) do local d = (u:GetPivot().Position - bP).Magnitude; if d < mUD then mUD = d end end
        return mED < mUD
    end

    local function findSpot(pT)
        local pF = workspace:WaitForChild("Placeable"):FindFirstChild(pT or "Base")
        if not pF then return nil end
        local tP = Vector3.new(0,0,0)
        local eF = workspace:FindFirstChild("Enemies")
        local bP = getBasePos()
        local leading = nil
        local mBD = math.huge
        if eF then for _, e in pairs(eF:GetChildren()) do if e:FindFirstChild("HumanoidRootPart") then local d = (e.HumanoidRootPart.Position-bP).Magnitude; if d < mBD then mBD = d; leading = e end end end end
        tP = leading and leading.HumanoidRootPart.Position or (#pathPartsCache > 0 and pathPartsCache[1].Position or tP)
        local rP = RaycastParams.new()
        rP.FilterType = Enum.RaycastFilterType.Include
        rP.FilterDescendantsInstances = {pF}
        for r = 5, 40, 5 do for a = 0, 360, 45 do
            local rad = math.rad(a)
            local rO = Vector3.new(tP.X + math.cos(rad)*r, tP.Y + 50, tP.Z + math.sin(rad)*r)
            local res = workspace:Raycast(rO, Vector3.new(0,-100,0), rP)
            if res then
                local tCF = CFrame.new(res.Position)
                local oP = OverlapParams.new()
                oP.FilterType = Enum.RaycastFilterType.Include
                if workspace:FindFirstChild("Unit") then oP.FilterDescendantsInstances = {workspace.Unit} end
                if #workspace:GetPartBoundsInBox(tCF, Vector3.new(4,4,4), oP) == 0 then return tCF end
            end
        end end
        return nil
    end

    local function getDeck()
        local h = LocalPlayer.PlayerGui:WaitForChild("HUD")
        local uF = h:WaitForChild("BottomFrame"):WaitForChild("Unit")
        local d = {}
        for _, sN in ipairs({"One","Two","Three","Four","Five","Six"}) do
            local s = uF:FindFirstChild(sN)
            if s and s:FindFirstChild("Unit") and s.Unit.Value ~= "" then
                local c = 9999
                for _, t in pairs(s:GetDescendants()) do if (t:IsA("TextLabel") or t:IsA("TextButton")) and t.Text:match("%d+") then c = tonumber(t.Text:match("%d+")); break end end
                table.insert(d, {Name = s.Unit.Value, Cost = c})
            end
        end
        return d
    end

    local Money = LocalPlayer:WaitForChild("Money")
    task.spawn(function()
        while task.wait(1) do
            if not _G.AutoPlayEnabled or not _G.AutoPlayActive then continue end
            local uF = workspace:FindFirstChild("Unit")
            if uF then
                for _, u in pairs(uF:GetChildren()) do
                    if u:FindFirstChild("Owner") and u.Owner.Value == LocalPlayer then
                        local cost = u:GetAttribute("UpgradeCost") or u:GetAttribute("NextUpgradeCost") or 150
                        if Money.Value >= tonumber(cost) then serverRemote:InvokeServer("Upgrade", u) end
                    end
                end
            end
            if CheckDefense() then
                local deck = getDeck()
                for _, card in ipairs(deck) do
                    local count = 0
                    if uF then for _, u in pairs(uF:GetChildren()) do if u:FindFirstChild("Owner") and u.Owner.Value == LocalPlayer and u.Name == card.Name then count = count + 1 end end end
                    if not (knownLimits[card.Name] and count >= knownLimits[card.Name]) then
                        if Money.Value >= card.Cost then
                            local pT = learnedPlacements[card.Name] or "Base"
                            local spot = findSpot(pT)
                            if spot then
                                inputRemote:FireServer("Summon", {Rotation = 0, cframe = spot, Unit = card.Name})
                                task.wait(0.5)
                                local nC = 0
                                if uF then for _, u in pairs(uF:GetChildren()) do if u:FindFirstChild("Owner") and u.Owner.Value == LocalPlayer and u.Name == card.Name then nC = nC + 1 end end end
                                if nC > count then if not learnedPlacements[card.Name] then learnedPlacements[card.Name] = pT end; break
                                else if not learnedPlacements[card.Name] then learnedPlacements[card.Name] = (pT == "Base") and "Hill" or "Base" else knownLimits[card.Name] = count end end
                            end
                        end
                    end
                end
            end
        end
    end)

    -- ⏭️ [SUB-MODULE]: Auto Play Next (ข้ามด่านต่อไปเมื่อจบเกม V9.5)
    task.spawn(function()
        local VIM = game:GetService("VirtualInputManager")
        local playerGui = LocalPlayer:WaitForChild("PlayerGui")
        local guiService = game:GetService("GuiService")
        
        while task.wait(2) do
            if not _G.AutoPlayActive then continue end
            pcall(function()
                local playNextBtn = nil
                
                -- 🔍 สแกนหาปุ่มแบบเจาะลึก (ไม่สนตัวพิมพ์เล็ก/ใหญ่ และค้นหาในลูกหลาน)
                for _, gui in pairs(playerGui:GetDescendants()) do
                    if (gui:IsA("TextButton") or gui:IsA("ImageButton")) and gui.Visible and gui.AbsolutePosition.X > 0 then
                        
                        -- ดึงข้อความจากตัวเองและ TextLabel ที่อยู่ข้างใน
                        local text = gui:IsA("TextButton") and gui.Text or ""
                        for _, child in pairs(gui:GetChildren()) do
                            if child:IsA("TextLabel") then
                                text = text .. " " .. child.Text
                            end
                        end
                        
                        -- แปลงเป็นตัวพิมพ์เล็กให้หมด เพื่อให้หาง่ายขึ้น
                        text = text:lower()
                        local name = gui.Name:lower()
                        
                        -- เช็คคำว่า play next (เผื่อเกมเว้นวรรคหรือไม่เว้นวรรค)
                        if text:find("play next") or name:find("playnext") then
                            
                            -- เช็คซ้ำอีกรอบว่าปุ่มไม่ได้โดนซ่อนอยู่ใน Frame ที่ปิดอยู่
                            local isReallyVisible = true
                            local curr = gui
                            while curr and curr ~= playerGui do
                                if curr:IsA("GuiObject") and not curr.Visible then
                                    isReallyVisible = false
                                    break
                                end
                                curr = curr.Parent
                            end
                            
                            if isReallyVisible then
                                playNextBtn = gui
                                break
                            end
                        end
                    end
                end
                
                -- 🎯 ถ้าเจอปุ่มแล้ว ทำการเล็งเป้าแล้วยิง!
                if playNextBtn then
                    print("⏭️ [Auto Play] เจอหน้าต่างจบเกม! กำลังพุ่งเมาส์ไปกด 'Play Next'...")
                    _G.MoMoStatus("จบเกม! กำลังกด Play Next เพื่อไปต่อ...")
                    local aP, aS = playNextBtn.AbsolutePosition, playNextBtn.AbsoluteSize
                    
                    -- คำนวณระยะขอบจอ (Topbar) อัตโนมัติ แทนการเดาเลข 36
                    local inset = guiService:GetGuiInset()
                    local targetX = aP.X + (aS.X / 2)
                    local targetY = aP.Y + (aS.Y / 2) + inset.Y
                    
                    -- กดย้ำ 2 รอบแบบเน้นๆ เพื่อให้ชัวร์ว่าติดแน่นอน!
                    for i = 1, 2 do
                        VIM:SendMouseButtonEvent(targetX, targetY, 0, true, game, 1)
                        task.wait(0.1)
                        VIM:SendMouseButtonEvent(targetX, targetY, 0, false, game, 1)
                        task.wait(0.2)
                    end
                    
                    print("✅ กด Play Next สำเร็จ! รอระบบโหลดเข้าด่านใหม่...")
                    task.wait(8) -- หน่วงเวลาเพิ่มนิดหน่อย ให้เกมโหลดวาร์ปทัน
                end
            end)
        end
    end)
end

