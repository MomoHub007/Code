local function getCheapestAttackCost(deck, farmSlot)
    local cheapest = math.huge
    for _, card in ipairs(deck) do
        if card.Slot ~= farmSlot then
            local limit = MoMoConfig.UnitLimits[card.Slot] or 0
            local placed = placedTracking[card.Slot] or 0
            if placed < limit and card.Cost > 0 and card.Cost < cheapest then
                cheapest = card.Cost
            end
        end
    end
    return cheapest == math.huge and 0 or cheapest
end

local function getFrontStats()
    local pathFolder = getPathFolder()
    local placedFolder = workspace:FindFirstChild("placedTowers")
    local enemies = workspace:FindFirstChild("enemiesModels")

    local data = {
        towerCount = placedFolder and #placedFolder:GetChildren() or 0,
        enemyCount = enemies and #enemies:GetChildren() or 0,
        maxTowerProgress = -1,
        maxEnemyProgress = -1,
        frontTowerPos = nil,
        frontEnemyPos = nil,
        closeThreats = 0,
        pathMissing = pathFolder == nil
    }

    if pathFolder and placedFolder then
        for _, obj in pairs(placedFolder:GetChildren()) do
            if obj:IsA("Model") and obj.Name:match("^tower%-") then
                local pos = obj:GetPivot().Position
                local prog = getProgressScore(pos, pathFolder)
                if prog > data.maxTowerProgress then
                    data.maxTowerProgress = prog
                    data.frontTowerPos = pos
                end
            end
        end
    end

    if pathFolder and enemies then
        for _, e in pairs(enemies:GetChildren()) do
            local hrp = e:FindFirstChild("HumanoidRootPart")
            if hrp then
                local prog = getProgressScore(hrp.Position, pathFolder)
                if prog > data.maxEnemyProgress then
                    data.maxEnemyProgress = prog
                    data.frontEnemyPos = hrp.Position
                end
                if data.maxTowerProgress >= 0 and prog >= data.maxTowerProgress then
                    data.closeThreats += 1
                end
            end
        end
    end

    return data
end

local function getDangerState(deck, farmSlot)
    local stats = getFrontStats()
    if stats.pathMissing then
        return "EMERGENCY", 100, stats
    end

    if stats.towerCount == 0 then
        return "EMERGENCY", 100, stats
    end

    local score = 0
    local isLeaking = isDefenseBreached()

    if isLeaking then
        score += 50
    end

    if stats.maxEnemyProgress > stats.maxTowerProgress then
        score += 30
    end

    if stats.frontEnemyPos and stats.frontTowerPos and stats.maxEnemyProgress == stats.maxTowerProgress then
        local dist = (stats.frontEnemyPos - stats.frontTowerPos).Magnitude
        if dist > 15 then
            score += 20
        elseif dist > 10 then
            score += 10
        end
    end

    score += math.min(stats.closeThreats * 8, 24)

    if stats.towerCount <= 1 then
        score += 25
    elseif stats.towerCount <= 3 then
        score += 10
    end

    local cheapestAttack = getCheapestAttackCost(deck, farmSlot)
    local money = getRealMoney()
    if isLeaking and cheapestAttack > 0 and money < cheapestAttack then
        score += 10
    end

    if score >= 70 then
        return "EMERGENCY", score, stats
    elseif score >= 30 then
        return "PRESSURE", score, stats
    else
        return "SAFE", score, stats
    end
end

local function classifyPlacedTowers()
    local attackTowers = {}
    local farmTowers = {}
    local placedFolder = workspace:FindFirstChild("placedTowers")

    if placedFolder then
        for _, obj in pairs(placedFolder:GetChildren()) do
            if obj:IsA("Model") and obj.Name:match("^tower%-") then
                local pos = obj:GetPivot().Position
                local isFarm = false
                for _, fPos in ipairs(farmPositions) do
                    if (pos - fPos).Magnitude < 3 then
                        isFarm = true
                        break
                    end
                end
                if isFarm then
                    table.insert(farmTowers, obj)
                else
                    table.insert(attackTowers, obj)
                end
            end
        end
    end

    return attackTowers, farmTowers, placedFolder
end

local function softResync()
    local placedFolder = workspace:FindFirstChild("placedTowers")
    local liveCount = placedFolder and #placedFolder:GetChildren() or 0
    local tracked = 0

    for i = 1, 6 do
        tracked += (placedTracking[i] or 0)
    end

    if liveCount == 0 then
        placedTracking = {0, 0, 0, 0, 0, 0}
        farmPositions = {}
        recentFailedSpots = {}
        placementFailStreak = 0
        lastAutoActionAt = 0
        lastPlaceAttemptAt = 0
        lastFarmAttemptAt = 0
        lastUpgradeBurstAt = 0
        return
    end

    if tracked > liveCount + 2 then
        placedTracking = {0, 0, 0, 0, 0, 0}
        farmPositions = {}
        recentFailedSpots = {}
        placementFailStreak = 0
        print("♻️ [SmartAI] Tracking desync detected, reset local counters.")
    end
end

local lastTowerUpgradeAt = {}

local function getTowerProgress(obj)
    local pathFolder = getPathFolder()
    if not pathFolder or not obj or not obj:IsA("Model") then
        return -1
    end
    return getProgressScore(obj:GetPivot().Position, pathFolder)
end

local function isFarmTower(obj)
    if not obj or not obj:IsA("Model") then
        return false
    end

    local pos = obj:GetPivot().Position
    for _, fPos in ipairs(farmPositions) do
        if (pos - fPos).Magnitude < 3 then
            return true
        end
    end
    return false
end

local function scoreUpgradeTarget(obj, dangerState, deck, farmSlot)
    if not obj or not obj:IsA("Model") then
        return -999999
    end

    local score = 0
    local progress = getTowerProgress(obj)
    local farm = isFarmTower(obj)
    local now = tick()
    local lastUp = lastTowerUpgradeAt[obj.Name] or 0
    local cheapestAttack = getCheapestAttackCost(deck, farmSlot)
    local money = getRealMoney()

    if farm then
        if dangerState == "SAFE" then
            score += 80
        elseif dangerState == "PRESSURE" then
            score -= 25
        else
            score -= 120
        end
    else
        if dangerState == "SAFE" then
            score += 25
            score += math.max(progress, 0) * 2
        elseif dangerState == "PRESSURE" then
            score += 70
            score += math.max(progress, 0) * 7
        else
            score += 110
            score += math.max(progress, 0) * 10
        end
    end

    if cheapestAttack > 0 and money < cheapestAttack and not farm then
        score -= 20
    end

    if cheapestAttack > 0 and money < cheapestAttack and farm then
        score -= 60
    end

    local sinceLastUpgrade = now - lastUp
    if sinceLastUpgrade < 4 then
        score -= 90
    elseif sinceLastUpgrade < 8 then
        score -= 35
    end

    return score
end

local function getSortedUpgradeTargets(dangerState, attackTowers, farmTowers, deck, farmSlot)
    local all = {}

    if dangerState == "SAFE" then
        for _, obj in ipairs(farmTowers) do
            table.insert(all, obj)
        end
        for _, obj in ipairs(attackTowers) do
            table.insert(all, obj)
        end
    else
        for _, obj in ipairs(attackTowers) do
            table.insert(all, obj)
        end
        if dangerState == "PRESSURE" then
            for _, obj in ipairs(farmTowers) do
                table.insert(all, obj)
            end
        end
    end

    table.sort(all, function(a, b)
        return scoreUpgradeTarget(a, dangerState, deck, farmSlot) > scoreUpgradeTarget(b, dangerState, deck, farmSlot)
    end)

    return all
end

local function trySmartUpgrade(dangerState, attackTowers, farmTowers, deck, farmSlot)
    local targets = getSortedUpgradeTargets(dangerState, attackTowers, farmTowers, deck, farmSlot)
    if #targets == 0 then
        return false
    end

    local upgraded = false
    local attempts = 0
    local maxAttempts = (dangerState == "EMERGENCY") and 1 or 2

    for _, obj in ipairs(targets) do
        if attempts >= maxAttempts then
            break
        end

        local ok = pcall(function()
            ReplicatedStorage.towers.towers_RELIABLE:FireServer(
                buffer.fromstring("\001\031+\000" .. obj.Name),
                {}
            )
        end)

        attempts += 1

        if ok then
            upgraded = true
            lastTowerUpgradeAt[obj.Name] = tick()
            print("⬆️ [SmartUpgrade] อัปเกรด " .. obj.Name .. " | state = " .. dangerState)
            task.wait(0.15)
        end
    end

    return upgraded
end

local function tryPlaceFarm(sync, farmCard, placedFolder, farmLimit, dangerState, deck)
    if not sync or not farmCard then return false end

    local placedFarm = placedTracking[farmCard.Slot] or 0
    if placedFarm >= farmLimit then return false end
    if not canAttemptFarm() then return false end

    local money = getRealMoney()
    local cheapestAttack = getCheapestAttackCost(deck, farmCard.Slot)

    if dangerState == "EMERGENCY" then
        return false
    end

    if dangerState == "PRESSURE" and cheapestAttack > 0 then
        local reserve = cheapestAttack
        if money < (farmCard.Cost + reserve) then
            return false
        end
    end

    if money < farmCard.Cost then
        return false
    end

    local success = false

    for _ = 1, 4 do
        local spot = findFarmSpot()
        if spot and not isNearFailedSpot(spot.Position, 5) then
            local countBefore = placedFolder and #placedFolder:GetChildren() or 0
            local ok = pcall(function()
                sync.clientTowerPlacement.call(farmCard.UUID, spot)
            end)

            if ok then
                task.wait(0.9)
                local countAfter = placedFolder and #placedFolder:GetChildren() or 0
                if countAfter > countBefore then
                    placedTracking[farmCard.Slot] = (placedTracking[farmCard.Slot] or 0) + 1
                    table.insert(farmPositions, spot.Position)
                    success = true
                    print("🤑 [SmartEco] วางฟาร์มสำเร็จ (" .. placedTracking[farmCard.Slot] .. "/" .. farmLimit .. ")")
                    break
                else
                    markFailedSpot(spot.Position)
                end
            else
                markFailedSpot(spot.Position)
            end
        end
    end

    markFarmAttempt(success)
    return success
end

local function scoreCard(card, dangerState, farmSlot)
    local limit = MoMoConfig.UnitLimits[card.Slot] or 0
    local placed = placedTracking[card.Slot] or 0
    if placed >= limit then
        return -999999
    end

    if card.Slot == farmSlot then
        return -999999
    end

    local score = 0
    local customPriority = false
    for i = 1, 6 do
        if MoMoConfig.UnitPriority[i] ~= i then
            customPriority = true
            break
        end
    end

    if customPriority then
        for level, slotNum in ipairs(MoMoConfig.UnitPriority) do
            if slotNum == card.Slot then
                score += (100 - level * 10)
                break
            end
        end
    end

    if dangerState == "EMERGENCY" then
        score -= card.Cost
    elseif dangerState == "PRESSURE" then
        score -= (card.Cost * 0.35)
    else
        score += (limit - placed) * 4
        score += (card.Cost * 0.05)
    end

    if placed == 0 then
        score += 6
    end

    return score
end

local function getSortedAttackDeck(deck, dangerState, farmSlot)
    local result = {}
    for _, card in ipairs(deck) do
        table.insert(result, card)
    end

    table.sort(result, function(a, b)
        local sa = scoreCard(a, dangerState, farmSlot)
        local sb = scoreCard(b, dangerState, farmSlot)
        if sa == sb then
            return a.Cost < b.Cost
        end
        return sa > sb
    end)

    return result
end

local function tryPlaceAttack(sync, deck, farmSlot, dangerState, placedFolder)
    if not sync or #deck == 0 then return false end
    if not canAttemptPlacement() then return false end

    local money = getRealMoney()
    local sortedDeck = getSortedAttackDeck(deck, dangerState, farmSlot)
    local success = false

    for _, card in ipairs(sortedDeck) do
        local limit = MoMoConfig.UnitLimits[card.Slot] or 0
        local placed = placedTracking[card.Slot] or 0

        if card.Slot ~= farmSlot and placed < limit and money >= card.Cost then
            for _ = 1, 4 do
                local spot = findSpot()
                if spot and spot.Position and not isNearFailedSpot(spot.Position, 4) then
                    local countBefore = placedFolder and #placedFolder:GetChildren() or 0
                    local ok = pcall(function()
                        sync.clientTowerPlacement.call(card.UUID, spot)
                    end)

                    if ok then
                        task.wait(0.9)
                        local countAfter = placedFolder and #placedFolder:GetChildren() or 0
                        if countAfter > countBefore then
                            placedTracking[card.Slot] = (placedTracking[card.Slot] or 0) + 1
                            success = true
                            print("✅ [SmartAI] วาง Unit Slot " .. card.Slot .. " สำเร็จ (" .. placedTracking[card.Slot] .. "/" .. limit .. ")")
                            break
                        else
                            markFailedSpot(spot.Position)
                        end
                    else
                        markFailedSpot(spot.Position)
                    end
                end
            end
        end

        if success then
            break
        end
    end

    markPlacementAttempt(success)
    return success
end

