    LeakPlacementCooldown = 8,   -- วางตัวสกัดได้ทุก 8 วินาที ไม่รัว
    TotalLeakPlacements = 0,
    MaxLeakPlacements = 3,        -- วางสกัดได้สูงสุด 3 ตัวต่อเกม
}

local function mxLog(...)
