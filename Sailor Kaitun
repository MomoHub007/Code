-- 👁️ [ Background Quest Monitor - Failsafe Edition ]
task.spawn(function()
    while true do
        task.wait(0.5)
        local active = isQuestActive()
        
        local function triggerSwitch(reason)
            -- 🛑 [ FIX ] ห้าม Abandon เควสตอนทำ Haki หรือกำลังไป ซื้อของ (buy) และรีเซ็ตเวลาเพื่อหยุดลูปสแปม
            if string.find(_G.KaitunPhase, "Haki") or string.find(_G.KaitunPhase, "buy") then
                -- รีเซ็ตเวลาเพื่อหยุดสแปม!
                _G.KaitunLastQuestFinishTime = tick() 
                _G.KaitunQuestStartTime = tick()
                return 
            end

            _G.KaitunQuestCount = _G.KaitunQuestCount + 1
            _G.KaitunKillsForCurrentQuest = 0
            _G.KaitunLastQuestFinishTime = tick()
            _G.KaitunQuestStartTime = tick()
            
            pcall(function() RS.RemoteEvents.QuestAbandon:FireServer("repeatable") end)
            pcall(function() 
                Window:Notify({Title = "Auto Kaitun", Desc = "🔄 Switching! Reason: "..reason, Time = 3}) 
                print("[MOMO DEBUG] Switching Target (".._G.KaitunQuestCount..") Reason: "..reason)
            end)
        end

        -- 🕵️ [ CASE 1 ] เควสจบปกติ (UI หาย)
        if _G.LastQuestActiveState == true and active == false then
            -- ⏳ [ DEBOUNCE ] รอ 1.5 วิเพื่อให้แน่ใจว่า UI ไม่ได้แค่กระพริบ
            task.wait(1)
            if isQuestActive() == false then
                triggerSwitch("Quest Finished (UI confirmed)")
            end
        end
        
        -- 🛡️ [ CASE 2 ] ฆ่ามอนครบจำนวน (กัน UI บัค)
        if active and _G.KaitunKillsForCurrentQuest >= 25 then
            triggerSwitch("Kill Threshold (25)")
        end
        
        -- 🛡️ [ CASE 3 ] Idle Timeout (ถ้าไม่มีเควสค้างนานเกิน 30 วิ ให้สลับฝั่งลองดู)
        if not active and (tick() - _G.KaitunLastQuestFinishTime > 30) then
            triggerSwitch("Idle Timeout (30s)")
        end

        -- 🛡️ [ CASE 4 ] Stuck Timeout (ถ้าทำเควสเดิมนานเกิน 5 นาที ให้เปลี่ยน)
        if active and (tick() - _G.KaitunQuestStartTime > 300) then
            triggerSwitch("Stuck Timeout")
        end

        _G.LastQuestActiveState = active
        if active then 
            _G.KaitunLastQuestFinishTime = tick() 
        else
            _G.KaitunQuestStartTime = tick()
        end
        
        -- 🗡️ นับจำนวนมอนที่ฆ่าได้
        if _G.TargetMob and _G.TargetMob:FindFirstChild("Humanoid") then
            local mob = _G.TargetMob
            if mob.Humanoid.Health <= 0 then
                if _G.LastTargetMobUid ~= mob then
                    _G.KaitunKillsForCurrentQuest = _G.KaitunKillsForCurrentQuest + 1
                    _G.LastTargetMobUid = mob
                end
            end
        end
    end
end)

local function getFarmInfo()
    local data = LP:WaitForChild("Data", 10)
    local levelObj = data and data:FindFirstChild("Level", 10)
    if levelObj then
        local currentLvl = levelObj.Value
        local active = isQuestActive()
        
        -- ✅ ถ้ายังมีเควสค้างหน้าจออยู่ ให้ฟาร์มตัวเดิมต่อจนจบ (ตามเงื่อนไข User)
        if active and _G.CurrentKaitunQuest then
            return _G.CurrentKaitunQuest.NPC, _G.CurrentKaitunQuest.Target, _G.CurrentKaitunQuest.Island
        end

        -- ✅ หาเควสที่เลเวลสูงสุดที่ทำได้จากตารางใหม่
        for i, info in ipairs(QuestData) do
            if currentLvl >= info.Level then
                -- บันทึกค่าที่เลือกไว้เพื่อล็อกจนกว่าจะจบเควส
                _G.CurrentKaitunQuest = {NPC = info.NPC, Target = info.Target, Island = info.Island}
                return info.NPC, info.Target, info.Island
            end
        end
    end
    return nil, nil, nil
end

