local function SafeBypassWarp(targetPos, lookTarget, customSpeed)
    if MoMoConfig.OpFarmAllMap then
        -- 鉁� FIX: 喔栢箟喔� WarpBehindAndHit 喔佮赋喔ム副喔� Warp 喔�涪喔灌箞 喙勦浮喙堗笗喙夃腑喔� Warp 喔嬥箟喔�

        local char = LP.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if not char or not root then return end

        if lookTarget and (targetPos - lookTarget).Magnitude > 0.01 then
            char:PivotTo(CFrame.lookAt(targetPos, lookTarget))
        else
            char:PivotTo(CFrame.new(targetPos))
        end

        root.Velocity = Vector3.zero
        root.RotVelocity = Vector3.zero
        return
    end

    local char = LP.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChild("Humanoid")
    if not root or not hum then return end
    
    local dist = (root.Position - targetPos).Magnitude
    
    if dist < 300 then
        if lookTarget and (targetPos - lookTarget).Magnitude > 0.01 then char:PivotTo(CFrame.lookAt(targetPos, lookTarget))
        else char:PivotTo(CFrame.new(targetPos)) end
        if root then root.Velocity = Vector3.new(0, 0, 0); root.RotVelocity = Vector3.new(0, 0, 0) end
        return
    end

    local steps = math.ceil(dist / 15)
    local startPos = root.Position

    for i = 1, steps do
        if not root or not root.Parent then break end
        
        local farmActive = IsAnyFarmActive()
        if not farmActive then break end
        
        local nextPos = startPos:Lerp(targetPos, i / steps)
        
        if lookTarget and (targetPos - lookTarget).Magnitude > 0.01 then char:PivotTo(CFrame.lookAt(nextPos, lookTarget))
        else char:PivotTo(CFrame.new(nextPos)) end
        
        root.Velocity = Vector3.new(0, 0, 0); root.RotVelocity = Vector3.new(0, 0, 0)
        task.wait(0.1)
    end
end

