        local startupCfg = cfgMgr:CreateConfig("Default")
        if startupCfg:Load() and getgenv().MoMoHub.AutoLoad then
            WindUI:Notify({ Title = "⚡ Auto Loaded!", Content = "โหลด Default config สำเร็จ", Duration = 4 })
        end
