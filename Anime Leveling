    -- StateManager
    function StateManager.SetMode(mode)
        if Shared.GlobalState.currentMode ~= mode then
            Shared.GlobalState.lastMode = Shared.GlobalState.currentMode
            Shared.GlobalState.currentMode = mode
        end
    end
    function StateManager.SetPaused(paused, duration)
        Shared.GlobalState.isPaused = paused == true
        Shared.GlobalState.pauseUntil = (paused and duration and duration > 0) and (now() + duration) or 0
    end
    function StateManager.IsPaused()
        if not Shared.GlobalState.isPaused then return false end
        if Shared.GlobalState.pauseUntil > 0 and now() >= Shared.GlobalState.pauseUntil then
            Shared.GlobalState.isPaused = false
            Shared.GlobalState.pauseUntil = 0
            return false
        end
        return Shared.GlobalState.isPaused
    end

    -- ErrorHandler
    local function trimErrorWindow()
        local ts = Shared.Errors.timestamps
        local current = now()
        while #ts > 0 and (current - ts[1]) > Shared.Config.ErrorWindowSeconds do table.remove(ts, 1) end
    end
    function ErrorHandler.Record(op, err)
        Shared.Errors.timestamps[#Shared.Errors.timestamps + 1] = now()
        trimErrorWindow()
        log("WARN", tostring(op) .. " error", err)
    end
    function ErrorHandler.GetRetryDelay(attempt)
        local b = Shared.Config.GenericBackoff
        return b[math.min(attempt, #b)] or 1
    end
    function ErrorHandler.ShouldSoftStop()
        trimErrorWindow()
        return #Shared.Errors.timestamps >= Shared.Config.MaxErrorsBeforeSoftStop
    end
    function ErrorHandler.Handle(op, err, attempt, maxAttempts)
        ErrorHandler.Record(op, err)
        if ErrorHandler.ShouldSoftStop() then return "STOP" end
        if (attempt or 1) < (maxAttempts or 1) then return "RETRY" end
        return "SKIP"
    end

    -- PerformanceMonitor
    function PerformanceMonitor.Init()
        if Shared.Performance._connection then return end
        Shared.Performance._connection = RunService.Heartbeat:Connect(function(dt)
            local perf = Shared.Performance
            perf.frameCounter += 1
            perf.frameAccumulator += dt
            if perf.frameAccumulator >= 1 then
                perf.currentFPS = perf.frameCounter / perf.frameAccumulator
                perf.frameCounter = 0
                perf.frameAccumulator = 0
                perf.lastSampleAt = now()
            end
        end)
    end
    function PerformanceMonitor.GetCurrentFPS() return Shared.Performance.currentFPS end

    -- RemoteService
    local function findRemoteByName(remoteName)
        local cached = Shared.Caches.remotes[remoteName]
        if cached and cached.Parent then return cached end
        local remote = nil
        pcall(function()
            for _, desc in ipairs(ReplicatedStorage:GetDescendants()) do
                if (desc:IsA("RemoteEvent") or desc:IsA("RemoteFunction")) and desc.Name == remoteName then
                    remote = desc break
                end
            end
        end)
        if remote then Shared.Caches.remotes[remoteName] = remote end
        return remote
    end
    local function invokeRemote(remote, ...)
        if not remote then return false, "REMOTE_NIL" end
        if remote:IsA("RemoteFunction") then
            local ok, result = pcall(function(...) return remote:InvokeServer(...) end, ...)
            return ok and true or false, ok and result or result
        end
        if remote:IsA("RemoteEvent") then
            local ok, err = pcall(function(...) remote:FireServer(...) end, ...)
            return ok and true or false, ok and true or err
        end
        return false, "UNSUPPORTED_REMOTE_TYPE"
    end
    function RemoteService.CallWithRetry(remoteName, ...)
        local args = table.pack(...)
        for attempt = 1, 3 do
            local remote = findRemoteByName(remoteName)
            if not remote then
                local action = ErrorHandler.Handle("REMOTE_FIND_"..remoteName, "Remote not found", attempt, 3)
                if action == "STOP" then return false, "SOFT_STOP" end
                task.wait(ErrorHandler.GetRetryDelay(attempt))
            else
                local ok, result = invokeRemote(remote, table.unpack(args, 1, args.n))
                if ok then return true, result end
                local action = ErrorHandler.Handle("REMOTE_CALL_"..remoteName, result, attempt, 3)
                if action == "STOP" then return false, result end
                task.wait(ErrorHandler.GetRetryDelay(attempt))
            end
        end
        return false, "RETRY_EXHAUSTED_"..tostring(remoteName)
    end
    function RemoteService.OpenWisteriaRaid()
        local remotes = ReplicatedStorage:WaitForChild("Remotes")
        local remote = remotes:WaitForChild("OpenWisteriaRaid")
        local ok, err = pcall(function() remote:FireServer() end)
        return ok and true or false, ok and true or err
