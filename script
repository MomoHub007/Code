    -- 🚜 ฟังก์ชันหาพื้นที่ฟาร์ม (หลบฉากอยู่หลังยานอวกาศ ไม่แย่งที่แนวหน้า)
    local function findFarmSpot()
        local map = workspace:FindFirstChild("mapFolder") or workspace:FindFirstChild("Map")
        local areas = map and map:FindFirstChild("PlaceAreas")
        if not areas then return nil end

        local base = workspace:FindFirstChild("Base") or workspace:FindFirstChild("base")
        local basePos = base and base.Position or Vector3.new(0,0,0)

        -- สุ่มระยะให้ไกลจากฐาน (20-40 เมตร) เพื่อหลบเส้นทางมอนสเตอร์
        local checkRadius = math.random(20, 40) 
        local angle = math.random(0, 360)
        local checkPos = basePos + Vector3.new(math.cos(math.rad(angle)) * checkRadius, 0, math.sin(math.rad(angle)) * checkRadius)

        local groundFolder = areas:FindFirstChild("ground")
        if groundFolder then
            local rP = RaycastParams.new()
            rP.FilterType = Enum.RaycastFilterType.Include
            rP.FilterDescendantsInstances = {groundFolder}

            local res = workspace:Raycast(checkPos + Vector3.new(0, 50, 0), Vector3.new(0, -100, 0), rP)
            if res then
                local cf = CFrame.new(res.Position + Vector3.new(0, 1, 0))
                local occupied = false
                for _, p in pairs(workspace:GetPartBoundsInBox(cf, Vector3.new(3.5, 3.5, 3.5))) do
                    if p.Parent and p.Parent.Name:match("^tower%-") then occupied = true break end
                end
                if not occupied then return cf end
            end
        end
        return nil
    end

    -- 5. ตรวจจับมอนหลุดแนว (เปรียบเทียบคะแนน ป้อม VS มอนสเตอร์)
    -- 5. ตรวจจับมอนหลุดแนว (ระบบผสม V.PRO: จุดตรวจ + สายวัดระยะห่างฟิสิกส์)
    local function isDefenseBreached()
        local pathFolder = getPathFolder()
        if not pathFolder then return true end 

        local placedFolder = workspace:FindFirstChild("placedTowers")
        if not placedFolder or #placedFolder:GetChildren() == 0 then 
            return true 
        end

        -- 🌟 หาคะแนนป้อมที่ด่านหน้าสุด พร้อม "จำพิกัด" เอาไว้
        local maxTowerProgress = -1
        local frontTowerPos = nil
        for _, obj in pairs(placedFolder:GetChildren()) do
            if obj:IsA("Model") and obj.Name:match("^tower%-") then
                local pos = obj:GetPivot().Position
                local prog = getProgressScore(pos, pathFolder)
                if prog > maxTowerProgress then 
                    maxTowerProgress = prog 
                    frontTowerPos = pos
                end
            end
        end

        -- 🌟 หาคะแนนมอนสเตอร์หัวขบวน พร้อม "จำพิกัด" เอาไว้
        local maxEnemyProgress = -1
        local frontEnemyPos = nil
        local enemies = workspace:FindFirstChild("enemiesModels")
        if enemies then
            for _, e in pairs(enemies:GetChildren()) do
                local hrp = e:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local prog = getProgressScore(hrp.Position, pathFolder)
                    if prog > maxEnemyProgress then 
                        maxEnemyProgress = prog 
                        frontEnemyPos = hrp.Position
                    end
                end
            end
        end

        -- 🚨 การตัดสินใจ (The Hybrid Verdict)
        if maxEnemyProgress > maxTowerProgress then 
            -- กรณี 1: มอนเดินข้ามไปโซนเสาต้นใหม่แล้ว = หลุดแน่นอน วางดักเลย!
            return true 
        elseif maxEnemyProgress == maxTowerProgress and frontTowerPos and frontEnemyPos then
            -- กรณี 2: มอนอยู่โซนเสาเดียวกับป้อม ให้ควัก "ตลับเมตร" ออกมาวัด!
            local dist = (frontEnemyPos - frontTowerPos).Magnitude
            
            -- 📏 จุดปรับแต่งระยะห่าง: ถ้ามอนเดินห่างจากป้อมสุดท้ายเกิน X เมตร ให้วางป้อมใหม่
            if dist > 15 then 
                return true
            end
        end
        
        return false
    end

