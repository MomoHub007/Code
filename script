    local function isRoomUIVisible()
        local found = false
        pcall(function()
            for _, gui in pairs(LocalPlayer.PlayerGui:GetDescendants()) do
                if (gui:IsA("TextLabel") or gui:IsA("TextButton")) and gui.Text:upper() == "CREATE MATCH" then
                    local current = gui
                    local trulyVisible = true
                    while current and current.Parent do
                        if current:IsA("GuiObject") and not current.Visible then
                            trulyVisible = false
                            break
                        elseif current:IsA("ScreenGui") and not current.Enabled then
                            trulyVisible = false
                            break
                        end
                        current = current.Parent
                    end
                    if trulyVisible then found = true break end
                end
            end
        end)
        return found
    end

    local function AutoJoinMatch(targetMode, targetMapName, targetAct, targetDifficulty)
        targetMode = targetMode or "Story"
        targetMapName = targetMapName or "Ninja Leaf"
        targetAct = tonumber(targetAct) or 1
        targetDifficulty = targetDifficulty or "Normal"

        if not mapList[targetMapName] then return end
        if targetMode == "Legend" and targetAct > 3 then targetAct = 3 end

        -- ดึงค่า Remote ตรงนี้แทน เพื่อไม่ให้ Error ถ้าวิ่งอยู่ในด่าน
        local rooms = ReplicatedStorage:FindFirstChild("rooms")
        local roomsReliable = rooms and rooms:FindFirstChild("rooms_RELIABLE")
        if not roomsReliable then warn("❌ [System Error] หา Remote สร้างห้องไม่เจอ!") return end

        if isInLobby() then
            local storyDoors = workspace:FindFirstChild("StoryDoor")
            local enteredRoom = false
            
            if storyDoors then
                for i = 1, 10 do
                    local doorName = string.format("%03d", i)
                    local doorFolder = storyDoors:FindFirstChild(doorName)
                    local doorPart = doorFolder and doorFolder:FindFirstChild("Door")
                    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                    
                    if hrp and doorPart then
                        hrp.CFrame = doorPart.CFrame
                        if firetouchinterest then
                            firetouchinterest(hrp, doorPart, 0)
                            task.wait(0.1)
                            firetouchinterest(hrp, doorPart, 1)
                        end
                        task.wait(1.5) 
                        
                        if isRoomUIVisible() then 
                            enteredRoom = true
                            break 
                        end
                    end
                end
            end
            
            if enteredRoom or isRoomUIVisible() then
                roomsReliable:FireServer(buffer.fromstring("\b\a\001"), {})
                task.wait(2.5)
                
                if targetMode == "Legend" then
                    roomsReliable:FireServer(buffer.fromstring(legendModeString), {})
                else
                    if difficultyList[targetDifficulty] then 
                        roomsReliable:FireServer(buffer.fromstring(difficultyList[targetDifficulty]), {}) 
                    end
                end
                task.wait(1)

                roomsReliable:FireServer(buffer.fromstring(mapList[targetMapName]), {})
                task.wait(1)
                
                requestCounter = (requestCounter + 1) % 256
                local actString = string.char(2, requestCounter, targetAct)
                roomsReliable:FireServer(buffer.fromstring(actString), {})
                task.wait(1)
                
                roomsReliable:FireServer(buffer.fromstring("\001!\001"), {})
                task.wait(2.5) 
                
                roomsReliable:FireServer(buffer.fromstring("\005\004"), {}) 
            end
        end
    end


