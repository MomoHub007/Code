local function getDungeonMob()
    local function isValidDungeonMob(mob)
        if mob:IsA("Model") and mob:FindFirstChild("Humanoid") then
            local part = mob:FindFirstChild("HumanoidRootPart") or mob:FindFirstChild("Torso") or mob.PrimaryPart
            if part and mob.Humanoid.Health > 0 and not Players:GetPlayerFromCharacter(mob) and mob.Name ~= LP.Name then return true end
        end
        return false
    end
    local foldersToCheck = {"NPCs", "Bosses", "Mobs", "Enemies", "DungeonMobs"}
    for _, folderName in pairs(foldersToCheck) do
        local folder = workspace:FindFirstChild(folderName)
        if folder then
            for _, mob in pairs(folder:GetChildren()) do
                if isValidDungeonMob(mob) then return mob end
                for _, subMob in pairs(mob:GetChildren()) do if isValidDungeonMob(subMob) then return subMob end end
            end
        end
    end
    for _, obj in pairs(workspace:GetChildren()) do if obj.Name ~= "ServiceNPCs" and obj.Name ~= "Map" and not obj:IsA("Camera") then if isValidDungeonMob(obj) then return obj end end end
    return nil
end

