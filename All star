				continue
			end

			if EmergencyState.ProtocolEngaged then
				ELog("Standard placement paused by emergency protocol")
				continue
			end

			local ok, err = pcall(function()
				coordinatorRuntime.LastDecisionAt = os.clock()

				local affordable = getAffordableTower()
				if not affordable.Success or not affordable.Card then
					coordinatorRuntime.LastPlacementReason = affordable.Reason or "NoAffordableTower"
					return
				end

				local card = affordable.Card
				local learnedType = learnedPlacements[card.Name] or "Base"

				safeStatus("กำลังคำนวณตำแหน่ง " .. tostring(card.Name) .. "...")

				local calculation = Module3.CalculatePlacementPosition(card.Name, learnedType, 25)
				if not calculation or not calculation.Success or not calculation.BestPosition then
					if learnedPlacements[card.Name] == nil then
						learnedPlacements[card.Name] = (learnedType == "Base") and "Hill" or "Base"
					end
					coordinatorRuntime.LastPlacementReason = calculation and calculation.Reason or "CalculationFailed"
					return
				end

				safeStatus("กำลังวาง " .. tostring(card.Name) .. "...")

				local placement = Module4.RetryPlacementWithFallback(
					card.Index,
					calculation.BestCFrame or calculation.BestPosition,
					buildFallbackPositions(calculation.BestPosition),
					calculation.TowerType or learnedType
				)

				if placement and placement.Success then
					learnedPlacements[card.Name] = calculation.TowerType or learnedType
					coordinatorRuntime.LastPlacementReason = "Placed"
					mxLog("Placed tower:", card.Name, "| slot:", card.Index)
				else
					if learnedPlacements[card.Name] == nil then
						learnedPlacements[card.Name] = (learnedType == "Base") and "Hill" or "Base"
					else
						local placedCount = countOwnedUnitsByName(card.Name)
						knownLimits[card.Name] = placedCount
					end

					coordinatorRuntime.LastPlacementReason = placement and placement.Reason or "PlacementFailed"
				end
			end)

			if not ok then
				coordinatorRuntime.LastPlacementReason = tostring(err)
				mxWarn("MainLogicLoop:", tostring(err))
			end
		end
	end)

	return {
		Success = true,
		Reason = "OK",
		Runtime = coordinatorRuntime,
	}
end

