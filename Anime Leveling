	--==================================================
	-- ErrorHandler
	--==================================================
	local function trimErrorWindow()
		local timestamps = Shared.Errors.timestamps
		local current = now()

		while #timestamps > 0 and (current - timestamps[1]) > Shared.Config.ErrorWindowSeconds do
			table.remove(timestamps, 1)
		end
	end

	function ErrorHandler.Record(operation, err)
		Shared.Errors.timestamps[#Shared.Errors.timestamps + 1] = now()
		trimErrorWindow()
		log("WARN", string.format("%s error", tostring(operation)), err)
	end

	function ErrorHandler.GetRetryDelay(attempt)
		local backoff = Shared.Config.GenericBackoff
		return backoff[math.min(attempt, #backoff)] or 1
	end

	function ErrorHandler.ShouldSoftStop()
		trimErrorWindow()
		return #Shared.Errors.timestamps >= Shared.Config.MaxErrorsBeforeSoftStop
	end

	function ErrorHandler.Handle(operation, err, attempt, maxAttempts)
		ErrorHandler.Record(operation, err)

		if ErrorHandler.ShouldSoftStop() then
			return "STOP"
		end

		if (attempt or 1) < (maxAttempts or 1) then
			return "RETRY"
		end

		return "SKIP"
	end

