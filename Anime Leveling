		Shared.Performance._connection = RunService.Heartbeat:Connect(function(dt)
			local perf = Shared.Performance
			perf.frameCounter += 1
			perf.frameAccumulator += dt

			if perf.frameAccumulator >= 1 then
				perf.currentFPS = perf.frameCounter / perf.frameAccumulator
				perf.frameCounter = 0
				perf.frameAccumulator = 0
				perf.lastSampleAt = now()
			end
		end)
	end

	function PerformanceMonitor.GetCurrentFPS()
		return Shared.Performance.currentFPS
	end

	--==================================================
	-- RemoteService
	--==================================================
	local function findRemoteByName(remoteName)
		local cached = Shared.Caches.remotes[remoteName]
		if cached and cached.Parent then
			return cached
		end

		local remote = nil
		pcall(function()
			for _, desc in ipairs(ReplicatedStorage:GetDescendants()) do
				if (desc:IsA("RemoteEvent") or desc:IsA("RemoteFunction")) and desc.Name == remoteName then
					remote = desc
					break
				end
			end
		end)

		if remote then
			Shared.Caches.remotes[remoteName] = remote
		end
		return remote
	end

	local function invokeRemote(remote, ...)
		if not remote then
			return false, "REMOTE_NIL"
		end

		if remote:IsA("RemoteFunction") then
			local ok, result = pcall(function(...)
				return remote:InvokeServer(...)
			end, ...)
			if ok then
				return true, result
			end
			return false, result
		end

		if remote:IsA("RemoteEvent") then
			local ok, err = pcall(function(...)
				remote:FireServer(...)
			end, ...)
			if ok then
				return true, true
			end
			return false, err
		end

		return false, "UNSUPPORTED_REMOTE_TYPE"
	end

	function RemoteService.CallWithRetry(remoteName, ...)
		local args = table.pack(...)
		local maxAttempts = 3

		for attempt = 1, maxAttempts do
			local remote = findRemoteByName(remoteName)
			if not remote then
				local action = ErrorHandler.Handle("REMOTE_FIND_" .. remoteName, "Remote not found", attempt, maxAttempts)
				if action == "STOP" then
					return false, "SOFT_STOP"
				end
				task.wait(ErrorHandler.GetRetryDelay(attempt))
			else
				local ok, result = invokeRemote(remote, table.unpack(args, 1, args.n))
				if ok then
					return true, result
				end

				local action = ErrorHandler.Handle("REMOTE_CALL_" .. remoteName, result, attempt, maxAttempts)
				if action == "STOP" then
					return false, result
				end
				task.wait(ErrorHandler.GetRetryDelay(attempt))
			end
		end

		return false, "RETRY_EXHAUSTED_" .. tostring(remoteName)
	end

	function RemoteService.OpenWisteriaRaid()
		local remotes = ReplicatedStorage:WaitForChild("Remotes")
		local remote = remotes:WaitForChild("OpenWisteriaRaid")

		local ok, err = pcall(function()
			remote:FireServer()
		end)

		if ok then
			return true, true
