local PlayRoomEvent = ReplicatedStorage:WaitForChild("Remote"):WaitForChild("Server"):WaitForChild("PlayRoom"):WaitForChild("Event")

task.spawn(function()
    while true do
        task.wait(3) -- ตรวจสอบทุก 3 วินาที
        
        if getgenv().MoMoHub.AutoCreateRoom then
            local config = getgenv().MoMoHub.RoomConfig
            
            pcall(function()
                -- ส่งคำสั่งเซ็ตอัพทีละขั้นตอน
                PlayRoomEvent:FireServer("Change-Mode", { ["Mode"] = config.Mode })
                task.wait(0.3)
                
                PlayRoomEvent:FireServer("Change-World", { ["World"] = config.World })
                task.wait(0.3)
                
                PlayRoomEvent:FireServer("Change-Chapter", { ["Chapter"] = config.Chapter })
                task.wait(0.3)
                
                PlayRoomEvent:FireServer("Change-Difficulty", { ["Difficulty"] = config.Difficulty })
                task.wait(0.5)

                -- กด Submit เพื่อจองห้อง
                PlayRoomEvent:FireServer("Submit")
                task.wait(1.5)

                -- ถ้ายังเปิด Toggle อยู่ ให้กดเริ่มเกม
                if getgenv().MoMoHub.AutoCreateRoom then
                    PlayRoomEvent:FireServer("Start")
                    print("🚀 Room Started: " .. config.World .. " | " .. config.Chapter)
                end
            end)
            
            -- รอสักพักเพื่อให้เกมวาร์ปเข้าด่าน (ป้องกันการสร้างซ้ำซ้อน)
            task.wait(10)
        end
    end
end)
