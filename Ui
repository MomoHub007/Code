local cfgSection = SettingsTab:Section({ Title = "💾 Config Manager", Box = true, BoxBorder = true, Opened = true })

local cfgMgr = Window.ConfigManager
local cfgName = "Default"
local isAutoLoadEnabled = false

-- 1. อ่านค่าจากไฟล์ในเครื่องก่อนสร้าง UI เพื่อดูว่าเคยเปิด Auto Load ไว้ไหม
if isfile and readfile and isfile("MoMoHub_AutoLoad.txt") then
    pcall(function() 
        local content = readfile("MoMoHub_AutoLoad.txt")
        if content and content ~= "" then
            isAutoLoadEnabled = true
            cfgName = content -- จำชื่อ Config สุดท้ายที่ใช้
        end
    end)
end

-- Config Name Input
local cfgInput = cfgSection:Input({
    Flag = "CfgName",
    Title = "Config Name",
    Value = cfgName, -- แสดงชื่อ Config ที่จำไว้ทันที
    Placeholder = "Enter config name...",
    Callback = function(n)
        cfgName = (n ~= "" and n or "Default")
        -- อัปเดตความจำทันที ถ้าผู้เล่นเปลี่ยนชื่อ Config ระหว่างที่ Auto Load เปิดอยู่
        if getgenv().MoMoHub.AutoLoad and writefile then
            pcall(function() writefile("MoMoHub_AutoLoad.txt", cfgName) end)
        end
    end,
})

-- Config List Dropdown
local cfgList = cfgSection:Dropdown({
    Flag = "CfgList",
    Title = "📂 Saved Configs",
    Values = cfgMgr:AllConfigs(),
    Value = cfgName,
    Callback = function(n)
        if n then
            cfgName = n
            cfgInput:Set(n)
            -- อัปเดตความจำทันที ถ้าเลือก Config จาก Dropdown 
            if getgenv().MoMoHub.AutoLoad and writefile then
                pcall(function() writefile("MoMoHub_AutoLoad.txt", cfgName) end)
            end
        end
    end,
})

cfgSection:Space()

-- ✅ Auto Load Config Toggle (จำสถานะของตัวเองได้แล้ว!)
cfgSection:Toggle({
    Flag    = "AutoLoadCfg",
    Title   = "⚡ Auto Load Config on Start",
    Desc    = "Automatically load config when script starts",
    Type    = "Checkbox",
    Value   = isAutoLoadEnabled, -- ดึงสถานะที่จำไว้มาเปิด/ปิดให้ทันที
    Callback = function(v)
        getgenv().MoMoHub.AutoLoad = v
        if v then
            -- สร้างไฟล์ฝังเครื่อง
            if writefile then
                pcall(function() writefile("MoMoHub_AutoLoad.txt", cfgName) end)
            end
            pcall(function()
                WindUI:Notify({ Title = "Auto Load ON", Content = "Will auto-load [" .. cfgName .. "]", Duration = 3 })
            end)
        else
            -- ลบข้อมูลถ้าปิด
            if writefile then
                pcall(function() writefile("MoMoHub_AutoLoad.txt", "") end)
            end
            pcall(function()
                WindUI:Notify({ Title = "Auto Load OFF", Content = "Auto-load disabled", Duration = 3 })
            end)
        end
    end,
})

cfgSection:Space()

-- Save / Load Buttons Group
local cfgActionGroup = cfgSection:Group({})

cfgActionGroup:Button({
