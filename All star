local function StartLobbyMaster()
    local hud = LocalPlayer.PlayerGui:WaitForChild("HUD")
    local Tutorial = {}

    local PORTAL_DATABASE = {
        {Index = 37, Prefix = "Script395"},
        {Index = 52, Prefix = "Script523"},
        {Index = 53, Prefix = "Script600"},
        {Index = 33, Prefix = "Script573"},
        {Index = 32, Prefix = "Script958"},
        {Index = 28, Prefix = "Script170"}
    }

    local function GetPortalCFrame(obj)
        if obj:IsA("BasePart") then
            return obj.CFrame
        elseif obj:IsA("Model") then
            local part = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart", true)
            return part and part.CFrame or nil
        end
        return nil
    end

    local function ScanStageFromGui(playerGui)
        local highestStage = 1
        local yellowFound = false
        for _, v in pairs(playerGui:GetDescendants()) do
            if v:IsA("TextLabel") or v:IsA("TextButton") then
                local txt = tonumber(v.Text)
                if txt then
                    local r = math.floor(v.TextColor3.R * 255 + 0.5)
                    local g = math.floor(v.TextColor3.G * 255 + 0.5)
                    local b = math.floor(v.TextColor3.B * 255 + 0.5)
                    if r >= 250 and g >= 250 and b <= 10 then
                        highestStage = txt
                        yellowFound = true
                    elseif r >= 250 and g >= 250 and b >= 250 and not yellowFound then
                        if txt > highestStage then highestStage = txt end
                    end
                end
            end
        end
        return highestStage
    end

    local function AttemptJoinPortals()
        local char = LocalPlayer.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local storyQ = workspace:FindFirstChild("Queue") and workspace.Queue:FindFirstChild("Story")
        local playerGui = LocalPlayer:WaitForChild("PlayerGui")
        if not (char and hrp and storyQ) then return false end
        
        local queueChildren = storyQ:GetChildren()
        for _, portalData in ipairs(PORTAL_DATABASE) do
            if #queueChildren >= portalData.Index then
                local targetPortal = queueChildren[portalData.Index]
                local targetCFrame = GetPortalCFrame(targetPortal)
                if targetCFrame then
                    hrp.CFrame = targetCFrame + Vector3.new(0, 3, 0)
                    task.wait(2.5)
                    local selectFound = false
                    for _, v in pairs(playerGui:GetDescendants()) do
                        if v:IsA("TextLabel") or v:IsA("TextButton") then
                            local t = (v.Text or ""):lower()
                            if t:find("select stage") or t:find("start") then
                                selectFound = true; break
                            end
                        end
                    end
                    if selectFound then
                        local hs = ScanStageFromGui(playerGui)
                        local levelRemoteCmd = portalData.Prefix .. "Level"
                        local startRemoteCmd = portalData.Prefix .. "Start"
                        pcall(function()
                            inputRemote:FireServer(levelRemoteCmd, tostring(hs), false)
                            task.wait(1.5)
                            inputRemote:FireServer(startRemoteCmd)
                        end)
                        return true
                    end
                end
            end
        end
        return false
    end

