    local function getRealMoney()
        local m = 0
        pcall(function()
            -- 1. เจาะเข้าไปที่หน้าต่าง hotbarGui
            local gui = LocalPlayer.PlayerGui:FindFirstChild("hotbarGui")
            
            -- 2. สแกนหา Object ที่ชื่อ "yen" แบบเจาะลึกทุกชั้น (true)
            local yenNode = gui and gui:FindFirstChild("yen", true)
            
            if yenNode then
                -- 3. หา TextLabel ที่ชื่อ "value"
                local label = yenNode:FindFirstChild("value")
                if label and label:IsA("TextLabel") then
                    -- 4. ใช้ %D เพื่อล้าง "ทุกอย่าง" ที่ไม่ใช่ตัวเลข (ลบลูกน้ำ, ช่องว่าง, ตัวอักษร)
                    local cleanNumber = label.Text:gsub("%D", "")
                    m = tonumber(cleanNumber) or 0
                end
            end
        end)
        return m
    end

