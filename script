local function getConfigList()
    local files = {}

    if listfiles and isfolder and isfolder(ConfigFolder) then
        pcall(function()
            for _, file in ipairs(listfiles(ConfigFolder)) do
                if type(file) == "string" and file:match("%.json$") then
                    local name = file:match("([^/\\]+)%.json$")
                    if name then
                        table.insert(files, name)
                    end
                end
            end
        end)
    end

    table.sort(files, function(a, b)
        return tostring(a):lower() < tostring(b):lower()
    end)

    if #files == 0 then
        return {"None"}
    end

    return files
end

local function refreshConfigDeleteDropdown(forceSelection)
    local currentList = getConfigList()

    if forceSelection and forceSelection ~= "" then
        local found = false
        for _, v in ipairs(currentList) do
            if v == forceSelection then
                found = true
                break
            end
        end
        selectedConfigToDelete = found and forceSelection or "None"
    else
        local stillExists = false
        for _, v in ipairs(currentList) do
            if v == selectedConfigToDelete then
                stillExists = true
                break
            end
        end
        if not stillExists then
            selectedConfigToDelete = "None"
        end
    end

    if configDeleteDropdown then
        local refreshed = false

        for funcName, func in pairs(configDeleteDropdown) do
            if type(func) == "function" then
                local lowerName = string.lower(funcName)

                if lowerName:find("option") or lowerName:find("refresh") or lowerName:find("updatelist") or lowerName:find("setlist") or lowerName:find("reload") then
                    local ok = pcall(function()
                        func(configDeleteDropdown, currentList)
                    end)
                    if ok then
                        refreshed = true
                    end
                end
            end
        end

        if selectedConfigToDelete and selectedConfigToDelete ~= "None" then
            pcall(function()
                if configDeleteDropdown.UpdateSelection then
                    configDeleteDropdown:UpdateSelection(selectedConfigToDelete)
                end
            end)
        end

        if not refreshed then
            warn("[ConfigManager] Could not auto-refresh config dropdown methods.")
        end
    end
end

