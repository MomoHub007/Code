    -- AutoEggModule
    function AutoEggModule.Start()
        if Shared.EggState.isRunning then return end
        Shared.EggState.isRunning = true
        Shared.GlobalState.eggRunning = true
        updateEggStatusText("Running")
    end
    function AutoEggModule.Stop()
        Shared.EggState.isRunning = false
        Shared.GlobalState.eggRunning = false
        updateEggStatusText("Stopped")
    end
    function AutoEggModule.Tick()
        if not Shared.EggState.isRunning then return end
        local current = now()
        if (current - Shared.EggState.lastCallAt) < Shared.EggState.intervalSeconds then return end
        local ok, result = RemoteService.Hatch(Shared.EggState.selectedStar, Shared.EggState.eggsPerHatch)
        if ok then
            Shared.EggState.lastCallAt = current
            Shared.EggState.totalCalls += 1
            Shared.EggState.totalEggsOpened += Shared.EggState.eggsPerHatch
            updateEggStatusText("Running")
        else
            ErrorHandler.Record("EGG_HATCH", result)
            updateEggStatusText("Retrying")
        end
    end
    function AutoEggModule.Loop()
        local token = Shared.EggState.loopToken + 1
        Shared.EggState.loopToken = token
        task.spawn(function()
            while Shared.GlobalState.initialized and Shared.EggState.loopToken == token do
                local ok, err = pcall(AutoEggModule.Tick)
                if not ok then ErrorHandler.Record("EGG_LOOP", err) end
                task.wait(Shared.Config.EggLoopInterval)
            end
        end)
    end

    -- AutoFarmModule
    local function farmSetStatus(text, notifyUser)
        updateFarmStatusText(text)
        if notifyUser then notify("Auto Farm", text, 2) end
    end
    local function farmResolveTarget()
        if Shared.FarmState.farmMode == "NEAR" then return MonsterTracker.GetNearestMonster("FARM") end
        local selected = Shared.FarmState.selectedMonsterNames
        local count = #selected
        if count == 0 then return nil end
        for _ = 1, count do
            if Shared.FarmState.currentSelectedIndex > count then Shared.FarmState.currentSelectedIndex = 1 end
            local name = selected[Shared.FarmState.currentSelectedIndex]
            local list = Shared.Caches.farm.byName[name] or {}
            for i = 1, #list do
                local monster = list[i]
                if monster and monster.Parent and CombatService.IsAlive(monster) then return monster end
            end
            Shared.FarmState.currentSelectedIndex = (Shared.FarmState.currentSelectedIndex % count) + 1
        end
        return nil
    end
    local function farmAdvanceIndex()
        local count = #Shared.FarmState.selectedMonsterNames
        if count > 0 then Shared.FarmState.currentSelectedIndex = (Shared.FarmState.currentSelectedIndex % count) + 1 end
    end
    function AutoFarmModule.StartFarming()
        if Shared.FarmState.isRunning then return true end
        if Shared.FarmState.farmMode == "SELECT" and #Shared.FarmState.selectedMonsterNames == 0 then
            notify("Auto Farm", "Please select monsters first", 3)
            farmSetStatus("No monsters selected", true)
            return false
        end
        Shared.FarmState.isRunning = true
        Shared.FarmState.fightState = "IDLE"
        Shared.FarmState.currentTarget = nil
        Shared.FarmState.currentSelectedIndex = 1
        Shared.FarmState.loopToken += 1
        StateManager.SetMode("FARM")
        farmSetStatus("Running", true)
        local myToken = Shared.FarmState.loopToken
        task.spawn(function()
            while Shared.GlobalState.initialized and Shared.FarmState.isRunning and Shared.FarmState.loopToken == myToken do
                local ok, err = pcall(AutoFarmModule._Tick)
                if not ok then Shared.FarmState.errors += 1 ErrorHandler.Record("FARM_TICK", err) end
                task.wait(Shared.Config.FarmLoopInterval)
            end
        end)
        return true
    end
    function AutoFarmModule.StopFarming()
        Shared.FarmState.isRunning = false
        Shared.FarmState.currentTarget = nil
        Shared.FarmState.fightState = "IDLE"
        Shared.FarmState.loopToken += 1
        farmSetStatus("Stopped", true)
    end
    function AutoFarmModule._Tick()
        if not Shared.FarmState.isRunning or Shared.GlobalState.currentMode ~= "FARM" then return end
        if StateManager.IsPaused() then return end
        local fps = PerformanceMonitor.GetCurrentFPS()
        if fps > 0 and fps < Shared.Config.MinAcceptableFPS then
            StateManager.SetPaused(true, Shared.Config.LowFPSPauseSeconds)
            farmSetStatus("Paused: low FPS") return
        end
        local current = now()
        if (current - Shared.FarmState.lastMonsterRefresh) >= Shared.Config.MonsterRefreshFarmInterval then
            MonsterTracker.RefreshFarmMonsters()
            UIModule.RefreshFarmMonsterDropdown()
            Shared.FarmState.lastMonsterRefresh = current
        end
        local state = Shared.FarmState.fightState
        if state == "IDLE" then
            local target = farmResolveTarget()
            if not target then farmSetStatus("Waiting for target") return end
            Shared.FarmState.currentTarget = target
            Shared.FarmState.fightState = "MOVING"
            Shared.FarmState.lastLoopAt = current
        elseif state == "MOVING" then
            local target = Shared.FarmState.currentTarget
            if not target or not target.Parent or not CombatService.IsAlive(target) then
                Shared.FarmState.currentTarget = nil Shared.FarmState.fightState = "IDLE" return
            end
            local ok, err = TeleportationService.TeleportToMonster(target, Shared.Config.TeleportOffsets)
            if ok then
                Shared.FarmState.totalTeleports += 1
                Shared.FarmState.fightState = "FIGHTING"
                Shared.FarmState.lastLoopAt = current
                farmSetStatus("Fighting " .. target.Name)
            elseif err ~= "TELEPORT_COOLDOWN" then
                Shared.FarmState.errors += 1 ErrorHandler.Record("FARM_TELEPORT", err)
            end
        elseif state == "FIGHTING" then
            local target = Shared.FarmState.currentTarget
            if not target or not target.Parent then
                Shared.FarmState.killedCount += 1 Shared.FarmState.currentTarget = nil
                Shared.FarmState.fightState = "IDLE" farmAdvanceIndex()
                farmSetStatus("Killed! Total: " .. Shared.FarmState.killedCount) return
            end
            if not CombatService.IsAlive(target) then
                Shared.FarmState.killedCount += 1 Shared.FarmState.currentTarget = nil
                Shared.FarmState.fightState = "IDLE" farmAdvanceIndex()
                farmSetStatus("Killed " .. target.Name .. "! Total: " .. Shared.FarmState.killedCount) return
            end
            local distance = CombatService.GetDistanceToTarget(LocalPlayer, target)
            if distance > Shared.Config.FarmReTeleportDistance then Shared.FarmState.fightState = "MOVING" return end
            if (current - Shared.FarmState.lastLoopAt) > Shared.Config.FarmFightStateMaxAge then
                Shared.FarmState.currentTarget = nil Shared.FarmState.fightState = "IDLE"
                Shared.FarmState.errors += 1 farmAdvanceIndex()
                ErrorHandler.Record("FARM_FIGHT_TIMEOUT", target.Name) return
            end
            farmSetStatus(string.format("Fighting %s (%.1f)", target.Name, distance))
        else
            Shared.FarmState.fightState = "IDLE" Shared.FarmState.currentTarget = nil
        end
    end

    -- RaidsModule
    local function raidsSetStatus(text)
        UIModule.UpdateRaidsStatus(text, Shared.RaidsState.killsThisRaid, Shared.RaidsState.raidsCompleted)
    end
    local function raidsWaitForPlayerAlive(timeout)
        local deadline = now() + (timeout or 30)
        while now() < deadline do
            local character = getCharacter()
            local humanoid = getHumanoid(character)
            local root = getRootPart(character)
            if humanoid and humanoid.Health > 0 and root then return true end
            task.wait(0.25)
        end
        return false
    end
    function RaidsModule._RefreshEnemies()
        local state = Shared.RaidsState
        local enemies, success = {}, false
        for attempt = 1, Shared.Config.ScanMaxAttempts do
            local ok, result = safePCall("RaidsRefreshEnemies", function()
                MonsterTracker.SetMode("RAID")
                MonsterTracker.RefreshRaidEnemies()
                return MonsterTracker.GetAllMonsters("RAID")
            end)
            if ok and type(result) == "table" then enemies = result success = true break end
            local action = ErrorHandler.Handle("RAID_SCAN", result, attempt, Shared.Config.ScanMaxAttempts)
            if action == "STOP" then break end
            task.wait(ErrorHandler.GetRetryDelay(attempt))
        end
        if success then
            clearArray(state.enemiesList)
            for i = 1, #enemies do state.enemiesList[i] = enemies[i] end
            state.lastRefreshTime = now()
            if #state.enemiesList > 0 then state.emptySince = 0 end
        end
        return state.enemiesList
    end
    function RaidsModule._OpenRaidWithRetry()
        local state = Shared.RaidsState
        if TeleportationService.IsInRaidMap() then
            state.raidOpened = true state.lastOpenAt = now()
            raidsSetStatus("Raid detected") return true
        end
        for attempt = 1, Shared.Config.RaidOpenMaxAttempts do
            raidsSetStatus("Teleporting to raid")
            local ok, result = TeleportationService.TeleportToRaid()
            if ok then
                state.raidOpened = true state.lastOpenAt = now()
                state.emptySince = 0 state.lastRefreshTime = 0
                raidsSetStatus("Raid opened") return true
            end
            local action = ErrorHandler.Handle("RAID_OPEN", result, attempt, Shared.Config.RaidOpenMaxAttempts)
            if action == "STOP" then return false end
            task.wait(Shared.Config.RaidOpenBackoff[math.min(attempt, #Shared.Config.RaidOpenBackoff)] or 1)
        end
        state.raidOpened = false return false
    end
    function RaidsModule._ProcessEnemy(enemy)
        if not enemy or not enemy.Parent or not CombatService.IsAlive(enemy) then return false end
        Shared.RaidsState.currentTarget = enemy
        if not TeleportationService.IsInRaidMap() then
            local entered, enterErr = TeleportationService.TeleportToRaid()
            if not entered then ErrorHandler.Record("RAID_ENTER", enterErr) return false end
        end
        local teleported = false
        for attempt = 1, Shared.Config.TeleportMaxAttempts do
            if not raidsWaitForPlayerAlive(30) then
                ErrorHandler.Record("RAID_PLAYER_DEAD", "RESPAWN_TIMEOUT")
            else
                local ok, err = TeleportationService.TeleportToMonster(enemy, Shared.Config.TeleportOffsets)
                if ok then
                    teleported = true Shared.RaidsState.lastTeleportTime = now() break
                end
                if err ~= "TELEPORT_COOLDOWN" then
                    local action = ErrorHandler.Handle("RAID_TELEPORT", err, attempt, Shared.Config.TeleportMaxAttempts)
                    if action == "STOP" then return false end
                end
            end
            task.wait(ErrorHandler.GetRetryDelay(attempt))
        end
        if not teleported then return false end
        raidsSetStatus("Fighting " .. tostring(enemy.Name))
        local defeated = false
        local deadline = now() + Shared.Config.TargetDeadTimeout
        while now() < deadline do
            if not enemy or not enemy.Parent or not CombatService.IsAlive(enemy) then defeated = true break end
            if not raidsWaitForPlayerAlive(1) then task.wait(0.5) else task.wait(Shared.Config.WaitDeadPollInterval) end
        end
        if not defeated then ErrorHandler.Record("RAID_WAIT_DEAD", "TIMEOUT") defeated = true end
        if defeated then
            Shared.RaidsState.killsThisRaid += 1
            Shared.RaidsState.currentTarget = nil
            Shared.RaidsState.lastRefreshTime = 0
            raidsSetStatus("Kills: " .. Shared.RaidsState.killsThisRaid)
            return true
        end
        Shared.RaidsState.currentTarget = nil
        return false
    end
    local function getCurrentRaidWave()
        local ok, waveText = pcall(function()
            local gui = LocalPlayer:WaitForChild("PlayerGui")
            local label = gui:WaitForChild("Main"):WaitForChild("HUD"):WaitForChild("Dungeon"):WaitForChild("RaidsInfo"):WaitForChild("WavesFrame"):WaitForChild("Wave")
            return label.Text or label.ContentText
        end)
        if not ok or type(waveText) ~= "string" then return nil end
        local currentWave = string.match(waveText, "(%d+)%s*/%s*%d+")
        return currentWave and tonumber(currentWave) or nil
    end
    function RaidsModule._RestartRaid()
        clearArray(Shared.RaidsState.enemiesList)
        Shared.RaidsState.currentTarget = nil Shared.RaidsState.killsThisRaid = 0
        Shared.RaidsState.raidOpened = false Shared.RaidsState.emptySince = 0
        local leaveOk, leaveErr = RemoteService.LeaveRaid()
        if not leaveOk then ErrorHandler.Record("RAID_LEAVE", leaveErr) return false end
        task.wait(1.5)
        return RaidsModule._OpenRaidWithRetry()
    end
    function RaidsModule._CompleteRaid()
        Shared.RaidsState.raidsCompleted += 1
        Shared.RaidsState.currentTarget = nil Shared.RaidsState.raidOpened = false Shared.RaidsState.emptySince = 0
        raidsSetStatus("Completed")
        if Shared.RaidsState.autoRestart and (Shared.RaidsState.maxRaids == 0 or Shared.RaidsState.raidsCompleted < Shared.RaidsState.maxRaids) then
            return RaidsModule._RestartRaid()
        end
        RaidsModule.StopRaiding(true) return true
    end
    function RaidsModule._Tick()
        if not Shared.RaidsState.isRaiding or Shared.GlobalState.currentMode ~= "RAIDS" then return end
        if StateManager.IsPaused() then return end
        local fps = PerformanceMonitor.GetCurrentFPS()
        if fps > 0 and fps < Shared.Config.MinAcceptableFPS then
            StateManager.SetPaused(true, Shared.Config.LowFPSPauseSeconds)
            raidsSetStatus("Paused: low FPS") return
        end
        if not Shared.RaidsState.raidOpened then
            local opened = RaidsModule._OpenRaidWithRetry()
            if not opened then RaidsModule.StopRaiding(true) end return
        end
        if not TeleportationService.IsInRaidMap() then
            raidsSetStatus("Re-entering raid") TeleportationService.TeleportToRaid() return
        end
        if (now() - Shared.RaidsState.lastRefreshTime) >= Shared.Config.MonsterRefreshRaidInterval then
            RaidsModule._RefreshEnemies()
        end
        if #Shared.RaidsState.enemiesList == 0 then
            if Shared.RaidsState.emptySince == 0 then Shared.RaidsState.emptySince = now() end
            if (now() - Shared.RaidsState.emptySince) < Shared.Config.RaidWaveWaitTimeout then
                raidsSetStatus("Waiting for next wave") return
            end
            RaidsModule._CompleteRaid() return
        end
        Shared.RaidsState.emptySince = 0
        local target = MonsterTracker.GetNearestMonster("RAID")
        if not target then
            local enemies = Shared.RaidsState.enemiesList
            for i = 1, #enemies do
                local enemy = enemies[i]
                if enemy and enemy.Parent and CombatService.IsAlive(enemy) then target = enemy break end
            end
        end
        if target then RaidsModule._ProcessEnemy(target) else raidsSetStatus("Waiting for target") Shared.RaidsState.lastRefreshTime = 0 end
    end
    function RaidsModule.StartRaiding(config)
        config = type(config) == "table" and config or {}
        if Shared.RaidsState.isRaiding then return true end
        Shared.RaidsState.isRaiding = true Shared.RaidsState.raidOpened = false
        Shared.RaidsState.currentTarget = nil Shared.RaidsState.killsThisRaid = 0
        Shared.RaidsState.raidsCompleted = 0 Shared.RaidsState.autoRestart = config.autoRestart ~= false
        Shared.RaidsState.maxRaids = math.max(0, math.floor(tonumber(config.maxRaids) or 0))
        Shared.RaidsState.lastRefreshTime = 0 Shared.RaidsState.emptySince = 0
        Shared.RaidsState.loopToken += 1 clearArray(Shared.RaidsState.enemiesList)
        StateManager.SetMode("RAIDS") raidsSetStatus("Init")
        local myToken = Shared.RaidsState.loopToken
        task.spawn(function()
            while Shared.GlobalState.initialized and Shared.RaidsState.isRaiding and Shared.RaidsState.loopToken == myToken do
                local ok, err = pcall(RaidsModule._Tick)
                if not ok then Shared.RaidsState.errorCount += 1 ErrorHandler.Record("RAID_TICK", err) end
                task.wait(Shared.Config.RaidLoopInterval)
            end
        end)
        return true
    end
    function RaidsModule.StopRaiding(resumeFarm)
        Shared.RaidsState.isRaiding = false Shared.RaidsState.raidOpened = false
        Shared.RaidsState.currentTarget = nil Shared.RaidsState.emptySince = 0
        Shared.RaidsState.loopToken += 1 clearArray(Shared.RaidsState.enemiesList)
        raidsSetStatus("Stopped")
        if resumeFarm then task.spawn(function() pcall(function() CoreSystemManager.ResumePreviousMode() end) end)
        else StateManager.SetMode("IDLE") end
        return true
    end

    -- CoreSystemManager
    function CoreSystemManager.SetMode(mode, options)
        local ok, err = pcall(function()
            if mode == "RAIDS" then
                if Shared.RaidsState.isRaiding then return end
                if Shared.FarmState.isRunning then
                    Shared.GlobalState.lastMode = "FARM"
                    AutoFarmModule.StopFarming()
                    setToggleValue(Shared.UI.Components.FarmToggle, false)
                end
                RaidsModule.StartRaiding({ autoRestart = Shared.RaidsState.autoRestart, maxRaids = Shared.RaidsState.maxRaids })
                setToggleValue(Shared.UI.Components.RaidsToggle, true)
            elseif mode == "FARM" then
                if Shared.RaidsState.isRaiding then
                    RaidsModule.StopRaiding(false)
                    setToggleValue(Shared.UI.Components.RaidsToggle, false)
                end
                local started = AutoFarmModule.StartFarming()
                setToggleValue(Shared.UI.Components.FarmToggle, started)
            elseif mode == "IDLE" then
                if Shared.RaidsState.isRaiding then RaidsModule.StopRaiding(false) end
                if Shared.FarmState.isRunning then AutoFarmModule.StopFarming() end
                setToggleValue(Shared.UI.Components.FarmToggle, false)
                setToggleValue(Shared.UI.Components.RaidsToggle, false)
                StateManager.SetMode("IDLE")
            end
        end)
        if not ok then
            ErrorHandler.Record("SET_MODE_"..tostring(mode), err)
            notify("System", "Mode switch failed: "..tostring(mode), 3)
        end
    end
    function CoreSystemManager.ResumePreviousMode()
        if Shared.GlobalState.lastMode == "FARM" then
            CoreSystemManager.SetMode("FARM", { source = "ResumePreviousMode" })
        else
            CoreSystemManager.SetMode("IDLE", { source = "ResumePreviousMode" })
        end
    end
    function CoreSystemManager.OnRaidsToggled(enabled)
        if enabled then
            CoreSystemManager.SetMode("RAIDS", { source = "RaidToggle" })
        else
            if Shared.RaidsState.isRaiding then RaidsModule.StopRaiding(true)
            else CoreSystemManager.ResumePreviousMode() end
            setToggleValue(Shared.UI.Components.RaidsToggle, false)
        end
    end

