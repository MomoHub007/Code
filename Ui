-- ดึง inventory ของ LocalPlayer จาก ReplicatedStorage.Player_Data
local function getPlayerItems()
    local items = {}
    local ok = pcall(function()
        local pd = game:GetService("ReplicatedStorage"):FindFirstChild("Player_Data")
        if not pd then return end
        local myData = pd:FindFirstChild(LocalPlayer.Name)
        if not myData then return end
        local itemsFolder = myData:FindFirstChild("Items")
        if not itemsFolder then return end
        for _, folder in ipairs(itemsFolder:GetChildren()) do
            local amt = folder:FindFirstChild("Amount")
            items[folder.Name] = amt and amt.Value or 0
        end
    end)
    if not ok then
        warn("[MoMoHub Evolve] ไม่สามารถอ่าน Player_Data ได้")
    end
    return items
end

-- สร้างข้อความแสดง status ของ item 1 บรรทัด
local function itemLine(icon, name, have, need)
    return icon .. " " .. name .. "  (" .. tostring(have) .. "/" .. tostring(need) .. ")"
end

-- สร้าง description text แบบสมบูรณ์จาก unit ที่เลือก
local function buildEvolveDesc(unitName, playerItems)
    local data = EvolveData[unitName]
    if not data then return "ไม่พบข้อมูลสำหรับ Unit นี้" end

    local lines   = {}
    local missing = {}

    -- ─── Gold ───────────────────────────────────────────────
    table.insert(lines, "💰 Gold Required: " .. string.format("%d", data.Gold))

    -- ─── Takedown ───────────────────────────────────────────
    if data.TD and data.TD > 0 then
        table.insert(lines, "⚔️  Takedown Required: " .. tostring(data.TD))
    end

    -- ─── Currency ───────────────────────────────────────────
    local hasCurr = false
    for curr, need in pairs(data.Curr) do
        if not hasCurr then
            table.insert(lines, "")
            table.insert(lines, "━━ 💎 Currency ━━")
            hasCurr = true
        end
        local have = playerItems[curr] or 0
        local ok   = have >= need
        if not ok then table.insert(missing, curr) end
        table.insert(lines, itemLine(ok and "✅" or "❌", curr, have, need))
    end

    -- ─── Items ──────────────────────────────────────────────
    table.insert(lines, "")
    table.insert(lines, "━━ 🎒 Items ━━")

    for itemName, need in pairs(data.Items) do
        local have = playerItems[itemName] or 0
        local ok   = have >= need
        if not ok then table.insert(missing, itemName) end

        -- บรรทัดหลักของ item
        table.insert(lines, itemLine(ok and "✅" or "❌", itemName, have, need))

        -- ── Craftable? ──
        if CraftData[itemName] then
            table.insert(lines, "   🔨 Craftable — วัตถุดิบ:")
            for mat, qty in pairs(CraftData[itemName]) do
                local mhave = playerItems[mat] or 0
                local mok   = mhave >= qty
                local src   = ItemSources[mat]
                local srcTxt = src and ("  → " .. src) or "  → ❓ Gacha/Shop/Event"
                table.insert(lines,
                    "      " .. (mok and "✅" or "❌") ..
                    " " .. mat .. " (" .. mhave .. "/" .. qty .. ")" ..
                    srcTxt
                )
            end
        else
            -- ── Drop location ──
            local src = ItemSources[itemName]
            if src then
                table.insert(lines, "   📍 " .. src)
            else
                table.insert(lines, "   ❓ ไม่พบแหล่งดรอป (Gacha/Shop/Event)")
            end
        end
    end

    -- ─── Summary ────────────────────────────────────────────
    table.insert(lines, "")
    if #missing == 0 then
        table.insert(lines, "🎉 พร้อม Evolve! ไอเทมครบทุกอย่างแล้ว ✅")
    else
        table.insert(lines, "⚠️  ยังขาดอยู่ " .. #missing .. " รายการ:")
        for _, m in ipairs(missing) do
            table.insert(lines, "   • " .. m)
        end
    end

    return table.concat(lines, "\n")
end

