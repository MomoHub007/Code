    if not container then return false end
    for _, child in pairs(container:GetDescendants()) do
        if child:IsA("Model") and string.find(child.Name, "Yamato") and child:FindFirstChild("Humanoid") and child.Humanoid.Health > 0 and child:FindFirstChild("HumanoidRootPart") then return true end
    end
