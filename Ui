quickActions:Space()
quickActions:Button({
    Title = "🎲 Hop Server", Icon = "shuffle", Color = PurpleGlow,
    Callback = function()
        -- Server Hop Logic
        WindUI:Notify({ Title = "Server Hopping...", Content = "Looking for a new server...", Duration = 3 })
        local HttpService = game:GetService("HttpService")
        local TeleportService = game:GetService("TeleportService")
        local serversUrl = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"
        local success, response = pcall(function() return game:HttpGet(serversUrl) end)
        if success then
            local data = HttpService:JSONDecode(response)
            if data and data.data then
                for _, server in ipairs(data.data) do
                    if server.playing < server.maxPlayers and server.id ~= game.JobId then
                        TeleportService:TeleportToPlaceInstance(game.PlaceId, server.id, LocalPlayer)
                        return
                    end
                end
            end
        end
        WindUI:Notify({ Title = "No servers found", Content = "Please try again.", Duration = 3 })
    end,
})

