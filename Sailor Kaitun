local function HogyokuTweenFly(targetPos)
    local char = LP.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChild("Humanoid")
    if not root or not hum then return end
    
    local dist = (root.Position - targetPos).Magnitude
    if dist < 5 then return end
    
    hum:ChangeState(11)
    
    local speed = 5 
    local steps = math.ceil(dist / speed)
    local startPos = root.Position
    
    for i = 1, steps do
        if not root or not root.Parent then break end
        -- 🛑 [ FIX ] อนุญาตให้บินได้ถ้าอยู่ในโหมดไปซื้อของ (buy)
        if not MoMoConfig.AutoHogyokuQuest and not string.find(_G.KaitunPhase, "buy") then break end
        
        local nextPos = startPos:Lerp(targetPos, i / steps)
        char:PivotTo(CFrame.new(nextPos))
        
        root.Velocity = Vector3.new(0, 0, 0)
        root.RotVelocity = Vector3.new(0, 0, 0)
        RunService.Heartbeat:Wait()
    end
    
    if hum then hum:ChangeState(8) end
end

function getClosestTargetMobForIsland(islandName)
    local island = workspace:FindFirstChild(islandName)
    local islandMobs = island and (island:FindFirstChild("NPCs") or island:FindFirstChild("Mobs"))
    if islandMobs then
        local closestMob = nil
        local minDist = math.huge
        local root = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
        if root then
            for _, mob in pairs(islandMobs:GetChildren()) do
                local hum = mob:FindFirstChild("Humanoid")
                local mRoot = mob:FindFirstChild("HumanoidRootPart")
                if hum and mRoot and hum.Health > 0 then
                    local dist = (root.Position - mRoot.Position).Magnitude
                    if dist < minDist then
                        minDist = dist
                        closestMob = mob
                    end
                end
            end
        end
        return closestMob
    end
    return nil
end

local function SafeBypassWarp(targetPos, lookTarget, customSpeed)
    local char = LP.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChild("Humanoid")
    if not root or not hum then return end
    
    local dist = (root.Position - targetPos).Magnitude
    
    if dist < 300 then
        if lookTarget and (targetPos - lookTarget).Magnitude > 0.01 then
            char:PivotTo(CFrame.lookAt(targetPos, lookTarget))
        else
            char:PivotTo(CFrame.new(targetPos))
        end
        if root then
            root.Velocity = Vector3.new(0, 0, 0)
            root.RotVelocity = Vector3.new(0, 0, 0)
        end
        return
    end

    local steps = math.ceil(dist / 15)
    local startPos = root.Position

    for i = 1, steps do
        if not root or not root.Parent then break end
        
        -- 🛑 [ FIX ] รวม string.find(_G.KaitunPhase, "buy") เข้าไปให้ระบบรู้ว่ากำลังทำงานอยู่
        local farmActive = (MoMoConfig.AutoFarm or MoMoConfig.AutoBoss or MoMoConfig.AutoIsland or MoMoConfig.AutoSummon or MoMoConfig.AutoDungeon or MoMoConfig.AutoStrongestBoss or MoMoConfig.AutoTrueAizen or MoMoConfig.AutoHogyokuQuest or string.find(_G.KaitunPhase, "Haki") or string.find(_G.KaitunPhase, "buy"))
        if not farmActive then break end
        
        local nextPos = startPos:Lerp(targetPos, i / steps)
        
        if lookTarget and (targetPos - lookTarget).Magnitude > 0.01 then
            char:PivotTo(CFrame.lookAt(nextPos, lookTarget))
        else
            char:PivotTo(CFrame.new(nextPos))
        end
        
        root.Velocity = Vector3.new(0, 0, 0)
        root.RotVelocity = Vector3.new(0, 0, 0)
        
        task.wait(0.1)
    end
end

