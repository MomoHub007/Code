    -- =========================================================
    -- [PATH PATCH V2] Replace old getPathFolder/getProgressScore
    -- =========================================================

    local _cachedPathFolder = nil
    local _cachedPathFolderAt = 0
    local _cachedWaypointMap = setmetatable({}, { __mode = "k" })

    local function _extractNumericOrder(name)
        if not name then return nil end
        return tonumber(name) or tonumber(tostring(name):match("(%d+)"))
    end

    local function _getObjectWorldPosition(obj)
        if not obj then return nil end

        if obj:IsA("BasePart") then
            return obj.Position
        elseif obj:IsA("Attachment") then
            return obj.WorldPosition
        elseif obj:IsA("Model") then
            local primary = obj.PrimaryPart
            if primary then
                return primary.Position
            end
            local ok, pivot = pcall(function()
                return obj:GetPivot()
            end)
            if ok and pivot then
                return pivot.Position
            end
        end

        return nil
    end

    local function _collectWaypointCandidates(container, results, visited)
        if not container or visited[container] then return end
        visited[container] = true

        for _, child in ipairs(container:GetChildren()) do
            local pos = _getObjectWorldPosition(child)
            local lowerName = child.Name:lower()

            if pos then
                local order = _extractNumericOrder(child.Name)
                local looksLikeWaypoint =
                    order ~= nil or
                    lowerName:find("way") or
                    lowerName:find("node") or
                    lowerName:find("point") or
                    lowerName:find("wp")

                if looksLikeWaypoint then
                    table.insert(results, {
                        obj = child,
                        pos = pos,
                        order = order,
                        name = child.Name
                    })
                end
            end

            if child:IsA("Folder") or child:IsA("Model") then
                _collectWaypointCandidates(child, results, visited)
            end
        end
    end

    local function _getOrderedWaypoints(pathFolder)
        if not pathFolder then
            return {}
        end

        local cached = _cachedWaypointMap[pathFolder]
        if cached and cached.parent == pathFolder and tick() - cached.time < 3 then
            return cached.points
        end

        local raw = {}
        _collectWaypointCandidates(pathFolder, raw, {})

        if #raw == 0 then
            _cachedWaypointMap[pathFolder] = {
                parent = pathFolder,
                points = {},
                time = tick()
            }
            return {}
        end

        local numericCount = 0
        for _, item in ipairs(raw) do
            if item.order ~= nil then
                numericCount += 1
            end
        end

        if numericCount >= math.max(2, math.floor(#raw * 0.35)) then
            table.sort(raw, function(a, b)
                local ao = a.order or math.huge
                local bo = b.order or math.huge
                if ao == bo then
                    return a.name < b.name
                end
                return ao < bo
            end)
        else
            -- fallback: nearest-neighbor chain from a reasonable start point
            local startIndex = 1
            for i, item in ipairs(raw) do
                local lowerName = item.name:lower()
                if lowerName:find("start") or lowerName == "0" or lowerName == "1" then
                    startIndex = i
                    break
                end
            end

            local ordered = {}
            local used = {}
            local current = raw[startIndex]
            table.insert(ordered, current)
            used[startIndex] = true

            for _ = 2, #raw do
                local bestIdx, bestDist = nil, math.huge
                for i, item in ipairs(raw) do
                    if not used[i] then
                        local dist = (item.pos - current.pos).Magnitude
                        if dist < bestDist then
                            bestDist = dist
                            bestIdx = i
                        end
                    end
                end

                if not bestIdx then break end
                current = raw[bestIdx]
                used[bestIdx] = true
                table.insert(ordered, current)
            end

            raw = ordered
        end

        _cachedWaypointMap[pathFolder] = {
            parent = pathFolder,
            points = raw,
            time = tick()
        }

        return raw
    end

    local function _countDirectPosChildren(obj)
        if not obj then return 0 end
        local count = 0
        for _, child in ipairs(obj:GetChildren()) do
            if _getObjectWorldPosition(child) then
                count += 1
            end
        end
        return count
    end

    local function getPathFolder(forceRefresh)
        if not forceRefresh and _cachedPathFolder and _cachedPathFolder.Parent and tick() - _cachedPathFolderAt < 3 then
            return _cachedPathFolder
        end

        local candidates = {}

        local function consider(obj, bonus)
            if not obj then return end

            local lowerName = obj.Name:lower()
            local score = 0
            local directCount = _countDirectPosChildren(obj)
            local orderedCount = #_getOrderedWaypoints(obj)

            if lowerName == "path" or lowerName == "paths" or lowerName == "waypoints" then
                score += 120
            elseif lowerName:find("path") or lowerName:find("way") or lowerName:find("track") then
                score += 80
            end

            score += directCount * 6
            score += orderedCount * 10
            score += (bonus or 0)

            if orderedCount >= 3 then
                table.insert(candidates, {
                    obj = obj,
                    score = score
                })
            end
        end

        local roots = {
            workspace,
            workspace:FindFirstChild("map"),
            workspace:FindFirstChild("Map"),
            workspace:FindFirstChild("workspace"),
            workspace:FindFirstChild("Workspace"),
        }

        for _, root in ipairs(roots) do
            if root then
                consider(root:FindFirstChild("path"), 50)
                consider(root:FindFirstChild("Path"), 50)
                consider(root:FindFirstChild("paths"), 45)
                consider(root:FindFirstChild("Paths"), 45)
                consider(root:FindFirstChild("waypoints"), 40)
                consider(root:FindFirstChild("Waypoints"), 40)

                for _, d in ipairs(root:GetDescendants()) do
                    if d:IsA("Folder") or d:IsA("Model") then
                        consider(d, 0)
                    end
                end
            end
        end

        table.sort(candidates, function(a, b)
            return a.score > b.score
        end)

        _cachedPathFolder = candidates[1] and candidates[1].obj or nil
        _cachedPathFolderAt = tick()

        if _cachedPathFolder then
            local pts = _getOrderedWaypoints(_cachedPathFolder)
            print("[PathPatch] Selected path folder:", _cachedPathFolder:GetFullName(), "| waypoints =", #pts)
        else
            warn("[PathPatch] No valid path folder found")
        end

        return _cachedPathFolder
    end

    local function getProgressScore(worldPos, pathFolder)
        if not worldPos then
            return -1
        end

        pathFolder = pathFolder or getPathFolder()
        if not pathFolder then
            return -1
        end

        local waypoints = _getOrderedWaypoints(pathFolder)
        if #waypoints == 0 then
            return -1
        end

        if #waypoints == 1 then
            return 0
        end

        local bestSegmentIndex = 1
        local bestDistance = math.huge
        local bestT = 0

        for i = 1, #waypoints - 1 do
            local a = waypoints[i].pos
            local b = waypoints[i + 1].pos
            local ab = b - a
            local ap = worldPos - a

            local abLenSq = ab:Dot(ab)
            local t = 0
            if abLenSq > 0 then
                t = math.clamp(ap:Dot(ab) / abLenSq, 0, 1)
            end

            local closest = a + ab * t
            local dist = (worldPos - closest).Magnitude

            if dist < bestDistance then
                bestDistance = dist
                bestSegmentIndex = i
                bestT = t
            end
        end

        -- progress เป็นเลขต่อเนื่อง: segment index + offset ใน segment
        return (bestSegmentIndex - 1) + bestT
    end

    -- 4. หาจุดวางป้อม (ล็อกเป้ามอนสเตอร์ที่คะแนนจุดตรวจ "สูงสุด")
    local function findSpot()
        local map = workspace:FindFirstChild("mapFolder") or workspace:FindFirstChild("Map")
        local areas = map and map:FindFirstChild("PlaceAreas")
        local pathFolder = getPathFolder()
        
        if not areas or not pathFolder then return nil, "ไม่เจอ PlaceAreas หรือ PathFolder" end

        local targetEnemy = nil
        local maxProgress = -1
        local enemies = workspace:FindFirstChild("enemiesModels")
        
        -- 🌟 [New Logic]: หามอนสเตอร์ที่คะแนน Waypoint สูงที่สุด (หัวขบวน)
        if enemies then
            for _, e in pairs(enemies:GetChildren()) do
                local hrp = e:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local prog = getProgressScore(hrp.Position, pathFolder)
                    if prog > maxProgress then
                        maxProgress = prog
                        targetEnemy = e
                    end
                end
            end
        end

        if not targetEnemy or not targetEnemy:FindFirstChild("HumanoidRootPart") then return nil, "ไม่มีมอนสเตอร์บนแมพ" end

        local enemyHRP = targetEnemy.HumanoidRootPart
        
        -- สุ่มจุดวาง 360 องศารอบตัวมอนสเตอร์ (แก้บั๊กจุดซ้ำ)
        local checkRadius = math.random(4, 9)
        local angle = math.random(0, 360)
        local rad = math.rad(angle)
        local randomOffset = Vector3.new(math.cos(rad) * checkRadius, 0, math.sin(rad) * checkRadius)
        local checkPos = enemyHRP.Position + randomOffset

        for _, pType in ipairs({"ground", "air"}) do
            local folder = areas:FindFirstChild(pType)
            if folder then
                local rP = RaycastParams.new()
                rP.FilterType = Enum.RaycastFilterType.Include
                rP.FilterDescendantsInstances = {folder}

                local res = workspace:Raycast(checkPos + Vector3.new(0, 50, 0), Vector3.new(0, -100, 0), rP)

                if res then
                    local cf = CFrame.new(res.Position + Vector3.new(0, 1, 0))
                    local occupied = false
                    
                    for _, p in pairs(workspace:GetPartBoundsInBox(cf, Vector3.new(3.5, 3.5, 3.5))) do
                        if p.Parent and p.Parent.Name:match("^tower%-") then occupied = true break end
                    end
                    
                    if not occupied then 
                        pcall(function()
                            local p = Instance.new("Part", workspace)
                            p.Size, p.Color, p.Anchored, p.CanCollide = Vector3.new(1.5,1.5,1.5), Color3.fromRGB(0,255,100), true, false
                            p.CFrame = cf
                            game.Debris:AddItem(p, 1.5)
                        end)
                        return cf, pType 
                    end
                end
            end
        end
        return nil, "สุ่มจุดแล้วแต่พื้นที่ไม่ว่าง"
    end

    -- 🧠 สมุดบัญชีจำแนกตัวฟาร์ม (พิกัด)
