-- 1. เช็คว่าตอนนี้เล่นโหมดอะไรอยู่ (Normal หรือ Nightmare)
local function getCurrentDifficulty()
    local diff = "Normal" -- ค่าเริ่มต้น
    pcall(function()
        for _, gui in pairs(LocalPlayer.PlayerGui:GetDescendants()) do
            if gui:IsA("TextLabel") and gui.Name:lower() == "difficulty" then
                -- เช็คว่าป้ายนี้แสดงผลอยู่จริงๆ (ไม่ได้โดนซ่อน)
                if gui.Visible and (not gui.Parent or gui.Parent.Visible) then
                    local txt = gui.Text:lower()
                    if txt:match("nightmare") then diff = "Nightmare"
                    elseif txt:match("normal") then diff = "Normal" end
                end
            end
        end
    end)
    return diff
end

-- 2. ดึงโฟลเดอร์จุดตรวจ (Waypoints) ให้ตรงกับโหมดที่เล่น
local function getPathFolder()
    local diff = getCurrentDifficulty()
    local mapFolder = workspace:FindFirstChild("mapFolder")
    if mapFolder then
        local legacy = mapFolder:FindFirstChild("Paths") and mapFolder.Paths:FindFirstChild("legacy")
        if legacy then
            return legacy:FindFirstChild(diff) or legacy:FindFirstChild("Normal")
        end
    end
    return nil
end

-- 3. ให้คะแนนจุดตรวจ (หาสิ่งมีชีวิตว่าอยู่ใกล้ป้ายหมายเลขอะไรที่สุด)
local function getProgressScore(position, pathFolder)
    if not pathFolder then return 0 end
    local minD = math.huge
    local bestScore = 0
    
    for _, wp in pairs(pathFolder:GetChildren()) do
        if wp:IsA("BasePart") then
            local d = (position - wp.Position).Magnitude
            if d < minD then
                minD = d
                local num = tonumber(wp.Name) -- แปลงชื่อ "015" เป็นเลข 15
                if num then bestScore = num end
            end
        end
    end
    return bestScore
end

-- 4. หาจุดวางป้อม (ล็อกเป้ามอนสเตอร์ที่คะแนนจุดตรวจ "สูงสุด")
local function findSpot()
    local map = workspace:FindFirstChild("mapFolder") or workspace:FindFirstChild("Map")
    local areas = map and map:FindFirstChild("PlaceAreas")
    local pathFolder = getPathFolder()
    
    if not areas or not pathFolder then return nil, "ไม่เจอ PlaceAreas หรือ PathFolder" end

    local targetEnemy = nil
    local maxProgress = -1
    local enemies = workspace:FindFirstChild("enemiesModels")
    
    -- 🌟 [New Logic]: หามอนสเตอร์ที่คะแนน Waypoint สูงที่สุด (หัวขบวน)
    if enemies then
        for _, e in pairs(enemies:GetChildren()) do
            local hrp = e:FindFirstChild("HumanoidRootPart")
            if hrp then
                local prog = getProgressScore(hrp.Position, pathFolder)
                if prog > maxProgress then
                    maxProgress = prog
                    targetEnemy = e
                end
            end
        end
    end

    if not targetEnemy or not targetEnemy:FindFirstChild("HumanoidRootPart") then return nil, "ไม่มีมอนสเตอร์บนแมพ" end

    local enemyHRP = targetEnemy.HumanoidRootPart
    
    -- สุ่มจุดวาง 360 องศารอบตัวมอนสเตอร์ (แก้บั๊กจุดซ้ำ)
    local checkRadius = math.random(4, 9)
    local angle = math.random(0, 360)
    local rad = math.rad(angle)
    local randomOffset = Vector3.new(math.cos(rad) * checkRadius, 0, math.sin(rad) * checkRadius)
    local checkPos = enemyHRP.Position + randomOffset

    for _, pType in ipairs({"ground", "air"}) do
        local folder = areas:FindFirstChild(pType)
        if folder then
            local rP = RaycastParams.new()
            rP.FilterType = Enum.RaycastFilterType.Include
            rP.FilterDescendantsInstances = {folder}

            local res = workspace:Raycast(checkPos + Vector3.new(0, 50, 0), Vector3.new(0, -100, 0), rP)

            if res then
                local cf = CFrame.new(res.Position + Vector3.new(0, 1, 0))
                local occupied = false
                
                for _, p in pairs(workspace:GetPartBoundsInBox(cf, Vector3.new(3.5, 3.5, 3.5))) do
                    if p.Parent and p.Parent.Name:match("^tower%-") then occupied = true break end
                end
                
                if not occupied then 
                    pcall(function()
                        local p = Instance.new("Part", workspace)
                        p.Size, p.Color, p.Anchored, p.CanCollide = Vector3.new(1.5,1.5,1.5), Color3.fromRGB(0,255,100), true, false
                        p.CFrame = cf
                        game.Debris:AddItem(p, 1.5)
                    end)
                    return cf, pType 
                end
            end
        end
    end
    return nil, "สุ่มจุดแล้วแต่พื้นที่ไม่ว่าง"
end

-- 🧠 สมุดบัญชีจำแนกตัวฟาร์ม (พิกัด)
local farmPositions = {} 

-- 🚜 ฟังก์ชันหาพื้นที่ฟาร์ม (หลบฉากอยู่หลังยานอวกาศ ไม่แย่งที่แนวหน้า)
local function findFarmSpot()
    local map = workspace:FindFirstChild("mapFolder") or workspace:FindFirstChild("Map")
    local areas = map and map:FindFirstChild("PlaceAreas")
    if not areas then return nil end

    local base = workspace:FindFirstChild("Base") or workspace:FindFirstChild("base")
    local basePos = base and base.Position or Vector3.new(0,0,0)

    -- สุ่มระยะให้ไกลจากฐาน (20-40 เมตร) เพื่อหลบเส้นทางมอนสเตอร์
    local checkRadius = math.random(20, 40) 
    local angle = math.random(0, 360)
    local checkPos = basePos + Vector3.new(math.cos(math.rad(angle)) * checkRadius, 0, math.sin(math.rad(angle)) * checkRadius)

    local groundFolder = areas:FindFirstChild("ground")
    if groundFolder then
        local rP = RaycastParams.new()
        rP.FilterType = Enum.RaycastFilterType.Include
        rP.FilterDescendantsInstances = {groundFolder}

        local res = workspace:Raycast(checkPos + Vector3.new(0, 50, 0), Vector3.new(0, -100, 0), rP)
        if res then
            local cf = CFrame.new(res.Position + Vector3.new(0, 1, 0))
            local occupied = false
            for _, p in pairs(workspace:GetPartBoundsInBox(cf, Vector3.new(3.5, 3.5, 3.5))) do
                if p.Parent and p.Parent.Name:match("^tower%-") then occupied = true break end
            end
            if not occupied then return cf end
        end
    end
    return nil
end

-- 5. ตรวจจับมอนหลุดแนว (เปรียบเทียบคะแนน ป้อม VS มอนสเตอร์)
-- 5. ตรวจจับมอนหลุดแนว (ระบบผสม V.PRO: จุดตรวจ + สายวัดระยะห่างฟิสิกส์)
local function isDefenseBreached()
    local pathFolder = getPathFolder()
    if not pathFolder then return true end 

    local placedFolder = workspace:FindFirstChild("placedTowers")
    if not placedFolder or #placedFolder:GetChildren() == 0 then 
        return true 
    end

    -- 🌟 หาคะแนนป้อมที่ด่านหน้าสุด พร้อม "จำพิกัด" เอาไว้
    local maxTowerProgress = -1
    local frontTowerPos = nil
    for _, obj in pairs(placedFolder:GetChildren()) do
        if obj:IsA("Model") and obj.Name:match("^tower%-") then
            local pos = obj:GetPivot().Position
            local prog = getProgressScore(pos, pathFolder)
            if prog > maxTowerProgress then 
                maxTowerProgress = prog 
                frontTowerPos = pos
            end
        end
    end

    -- 🌟 หาคะแนนมอนสเตอร์หัวขบวน พร้อม "จำพิกัด" เอาไว้
    local maxEnemyProgress = -1
    local frontEnemyPos = nil
    local enemies = workspace:FindFirstChild("enemiesModels")
    if enemies then
        for _, e in pairs(enemies:GetChildren()) do
            local hrp = e:FindFirstChild("HumanoidRootPart")
            if hrp then
                local prog = getProgressScore(hrp.Position, pathFolder)
                if prog > maxEnemyProgress then 
                    maxEnemyProgress = prog 
                    frontEnemyPos = hrp.Position
                end
            end
        end
    end

    -- 🚨 การตัดสินใจ (The Hybrid Verdict)
    if maxEnemyProgress > maxTowerProgress then 
        -- กรณี 1: มอนเดินข้ามไปโซนเสาต้นใหม่แล้ว = หลุดแน่นอน วางดักเลย!
        return true 
    elseif maxEnemyProgress == maxTowerProgress and frontTowerPos and frontEnemyPos then
        -- กรณี 2: มอนอยู่โซนเสาเดียวกับป้อม ให้ควัก "ตลับเมตร" ออกมาวัด!
        local dist = (frontEnemyPos - frontTowerPos).Magnitude
        
        -- 📏 จุดปรับแต่งระยะห่าง: ถ้ามอนเดินห่างจากป้อมสุดท้ายเกิน X เมตร ให้วางป้อมใหม่
        if dist > 15 then 
            return true
        end
    end
    
    return false
end

