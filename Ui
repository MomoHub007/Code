task.spawn(function()
    task.wait(1) -- รอ UI และระบบ ConfigManager โหลดเสร็จชัวร์ๆ
    
    -- ถ้าเคยเปิด Auto Load ไว้ และมีชื่อ Config บันทึกอยู่
    if isAutoLoadEnabled and cfgName ~= "" then
        local startupCfg = cfgMgr:CreateConfig(cfgName)
        
        if startupCfg:Load() then
            pcall(function()
                WindUI:Notify({
                    Title   = "⚡ Auto Loaded!",
                    Content = "Loaded [" .. cfgName .. "] successfully",
                    Duration = 4,
                })
            end)
            
            -- ป้องกันบัค! เขียนทับสถานะ Auto Load อีกรอบ เผื่อไฟล์ JSON ที่โหลดมาดันจำค่าปุ่มเป็นปิด
            task.wait(0.5)
            getgenv().MoMoHub.AutoLoad = true
            if writefile then
                pcall(function() writefile("MoMoHub_AutoLoad.txt", cfgName) end)
            end
        end
    end
end)

