local function getDeckSnapshot()
	local result = {
		Success = false,
		Cards = {},
		Reason = nil,
	}

	local hud = LocalPlayer.PlayerGui:FindFirstChild("HUD")
	if not hud then
		result.Reason = "HUDMissing"
		return result
	end

	local bottomFrame = hud:FindFirstChild("BottomFrame") or hud:FindFirstChild("Main")
	if not bottomFrame then
		result.Reason = "BottomFrameMissing"
		return result
	end

	local unitFrame = bottomFrame:FindFirstChild("Unit")
	if not unitFrame then
		result.Reason = "UnitFrameMissing"
		return result
	end

	for index, slotName in ipairs({"One", "Two", "Three", "Four", "Five", "Six"}) do
		local slot = unitFrame:FindFirstChild(slotName)
		if slot and slot:FindFirstChild("Unit") and slot.Unit.Value ~= "" then
			local cost = 9999

			for _, obj in ipairs(slot:GetDescendants()) do
				if (obj:IsA("TextLabel") or obj:IsA("TextButton")) and obj.Text:match("%d+") then
					cost = tonumber(obj.Text:match("%d+")) or cost
					break
				end
			end

			table.insert(result.Cards, {
				Index = index,
				SlotName = slotName,
				Name = tostring(slot.Unit.Value),
				Cost = cost,
			})
		end
	end

	result.Success = true
	result.Reason = "OK"
	return result
end

local function resolveCardByIndex(cardIndex)
	local deckResult = getDeckSnapshot()
	if not deckResult.Success then
		return {
			Success = false,
			Reason = deckResult.Reason,
			Card = nil,
		}
	end

	for _, card in ipairs(deckResult.Cards) do
		if card.Index == tonumber(cardIndex) then
			return {
				Success = true,
				Reason = "OK",
				Card = card,
			}
		end
	end

	return {
		Success = false,
		Reason = "CardIndexNotFound",
		Card = nil,
	}
end

local function countOwnedUnitsByName(unitName)
	local count = 0
	local unitFolder = workspace:FindFirstChild("Unit")
	if not unitFolder then
		return count
	end

	for _, unit in ipairs(unitFolder:GetChildren()) do
		if unit:FindFirstChild("Owner") and unit.Owner.Value == LocalPlayer and unit.Name == unitName then
			count += 1
		end
	end

	return count
end

local function normalizeToCFrame(positionOrCFrame)
	if typeof(positionOrCFrame) == "CFrame" then
		return positionOrCFrame
	end
	if typeof(positionOrCFrame) == "Vector3" then
		return CFrame.new(positionOrCFrame)
	end
	return nil
end

function Module4.PlaceTowerAtPosition(cardIndex, positionOrCFrame, towerType)
	local result = {
		Success = false,
		CardIndex = tonumber(cardIndex),
		Card = nil,
		TowerType = towerType or "Base",
		CFrame = nil,
		Reason = nil,
		LearningUpdated = false,
		Debug = {},
	}

	local cardResult = resolveCardByIndex(cardIndex)
	if not cardResult.Success then
		result.Reason = cardResult.Reason
		return result
	end
	result.Card = cardResult.Card

	local cf = normalizeToCFrame(positionOrCFrame)
	if not cf then
		result.Reason = "InvalidPlacementCFrame"
		return result
	end
	result.CFrame = cf

	local moneyObj = LocalPlayer:FindFirstChild("Money")
	local beforeMoney = moneyObj and tonumber(moneyObj.Value) or nil
	local beforeCount = countOwnedUnitsByName(result.Card.Name)

	local fireOk, fireErr = pcall(function()
		inputRemote:FireServer("Summon", {
			Rotation = 0,
			cframe = cf,
			Unit = result.Card.Name
		})
	end)

	if not fireOk then
		result.Reason = "RemoteFailed:" .. tostring(fireErr)
		dwarn("Summon remote failed:", result.Card.Name, "|", tostring(fireErr))
		return result
	end

	task.wait(0.35)

	local afterMoney = moneyObj and tonumber(moneyObj.Value) or beforeMoney
	local afterCount = countOwnedUnitsByName(result.Card.Name)

	result.Debug.BeforeMoney = beforeMoney
	result.Debug.AfterMoney = afterMoney
	result.Debug.BeforeCount = beforeCount
	result.Debug.AfterCount = afterCount
	result.Debug.Position = cf.Position

	dlog(
		"Summon result:",
		result.Card.Name,
		"| beforeMoney =", tostring(beforeMoney),
		"| afterMoney =", tostring(afterMoney),
		"| beforeCount =", tostring(beforeCount),
		"| afterCount =", tostring(afterCount)
	)

	if (beforeMoney and afterMoney and afterMoney < beforeMoney) or (afterCount > beforeCount) then
		learnedPlacements[result.Card.Name] = result.TowerType
		result.LearningUpdated = true
		result.Success = true
		result.Reason = "OK"
		return result
	end

	result.Reason = "PlacementRejected"
	dwarn("Placement rejected:", result.Card.Name, "| pos =", tostring(cf.Position), "| towerType =", result.TowerType)
	return result
end

function Module4.RetryPlacementWithFallback(cardIndex, primaryPosition, fallbackPositions, towerType)
	local result = {
		Success = false,
		CardIndex = tonumber(cardIndex),
		TowerType = towerType or "Base",
		Attempts = {},
		AttemptCount = 0,
		WinningAttempt = nil,
		Reason = nil,
	}

	local positions = {primaryPosition}
	if type(fallbackPositions) == "table" then
		for i = 1, math.min(3, #fallbackPositions) do
			table.insert(positions, fallbackPositions[i])
		end
	end

	for attemptIndex, pos in ipairs(positions) do
		local attempt = Module4.PlaceTowerAtPosition(cardIndex, pos, towerType)
		attempt.AttemptIndex = attemptIndex

		table.insert(result.Attempts, attempt)
		result.AttemptCount = #result.Attempts

		if attempt.Success then
			result.Success = true
			result.WinningAttempt = attempt
			result.Reason = "OK"
			return result
		end

		if attemptIndex < #positions then
			task.wait(0.2)
		end
	end

	result.Reason = "AllPlacementAttemptsFailed"
	m4Warn("RetryPlacementWithFallback failed | cardIndex =", tostring(cardIndex))
	return result
end

